{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif

  assign primary_url = section.settings.cta_link
  if section.settings.cta_collection != blank
    assign primary_url = section.settings.cta_collection.url
  endif
-%}
<section
  class="{% unless section.settings.transparent_bg %}lusena-bg-brand {% endunless %}lusena-final-cta lusena-spacing--spacious"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container--narrow lusena-text-center lusena-content-flow{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    <h2 class="lusena-type-h1">
      {{ section.settings.heading | escape }}
    </h2>
    {%- if section.settings.body != blank -%}
      <p class="lusena-type-body">
        {{ section.settings.body | escape }}
      </p>
    {%- endif -%}

    {%- if primary_url != blank -%}
      <div class="lusena-gap-cta-top lusena-final-cta__actions">
        <a
          href="{{ primary_url }}"
          class="lusena-btn lusena-btn--primary lusena-btn--size-default"
        >
          {{ section.settings.cta_label | escape }}
        </a>

        {%- assign secondary_label = section.settings.secondary_label | strip -%}
        {%- if secondary_label != blank and section.settings.secondary_link != blank -%}
          <a
            href="{{ section.settings.secondary_link }}"
            class="lusena-final-cta__secondary-link"
          >
            {{ secondary_label | escape }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  /* CTA actions layout */
  .lusena-final-cta__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--lusena-space-2);
  }


  /* Secondary link */
  .lusena-final-cta__secondary-link {
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--lusena-accent-cta);
    text-decoration: underline;
    text-underline-offset: 0.4rem;
  }

  @media (hover: hover) {
    .lusena-final-cta__secondary-link:hover {
      text-decoration: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Final CTA",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "transparent_bg",
      "label": "Transparent background (inherit page color)",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Przekonaj się sama"
    },
    {
      "type": "text",
      "id": "body",
      "label": "Body",
      "default": "Wybierz produkt i poczuj różnicę już pierwszej nocy."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary button label",
      "default": "Zobacz kolekcję"
    },
    {
      "type": "collection",
      "id": "cta_collection",
      "label": "Primary collection (optional)"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary link (fallback)",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary link label"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link URL"
    }
  ],
  "presets": [
    {
      "name": "LUSENA Final CTA"
    }
  ]
}
{% endschema %}
