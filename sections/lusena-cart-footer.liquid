{%- comment -%}
  LUSENA Cart Footer - styled to match cart drawer footer.
  All JS-required IDs and classes preserved for cart.js compatibility.
{%- endcomment -%}

<div
  class="lusena-cart-footer{% if cart == empty %} is-empty{% endif %}"
  id="main-cart-footer"
  data-id="{{ section.id }}"
>
  <div class="lusena-container">
    <div class="lusena-cart-footer__inner">
      {%- if cart != empty -%}
        {%- comment -%} Gift note / Cart note {%- endcomment -%}
        {%- if settings.lusena_enable_gift_mode -%}
          <details class="lusena-accordion lusena-cart-gift"
            id="Details-Cart-GiftNote"
            {% if cart.note != blank %} open{% endif %}
          >
            <summary class="lusena-accordion__summary">
              <span class="lusena-type-body" style="font-weight: 500;">
                Kupuję na prezent
              </span>
              <span class="lusena-accordion__icon">
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </summary>
            <div class="lusena-accordion__content">
              <cart-note class="lusena-form__field">
                <label class="lusena-visually-hidden" for="Cart-GiftNote">Dedykacja</label>
                <textarea
                  id="Cart-GiftNote"
                  class="lusena-textarea"
                  name="note"
                  form="cart"
                  rows="3"
                  placeholder="{{ settings.lusena_gift_note_placeholder | default: 'Wpisz krótką dedykację (opcjonalnie)' | escape }}"
                >{{ cart.note }}</textarea>
                <p class="lusena-form__hint">Dedykację dodamy jako notatkę do zamówienia.</p>
              </cart-note>
            </div>
          </details>
        {%- elsif settings.show_cart_note -%}
          <div class="lusena-cart-note">
            <cart-note class="lusena-form__field">
              <label class="lusena-form__label" for="Cart-note">Specjalne instrukcje do zamówienia</label>
              <textarea
                class="lusena-textarea"
                name="note"
                form="cart"
                id="Cart-note"
                rows="3"
                placeholder="Specjalne instrukcje do zamówienia"
              >{{ cart.note }}</textarea>
            </cart-note>
          </div>
        {%- endif -%}
      {%- endif -%}

      <div class="lusena-cart-footer__blocks">
        {%- if cart != empty -%}
          {%- comment -%} Free shipping bar {%- endcomment -%}
          <div class="lusena-cart-meta">
            {%- liquid
              assign free_shipping_threshold_zl = settings.lusena_free_shipping_threshold | default: 0 | plus: 0
              assign free_shipping_threshold_cents = free_shipping_threshold_zl | times: 100
            -%}

            {%- if settings.lusena_enable_free_shipping_progress and free_shipping_threshold_cents > 0 -%}
              {%- liquid
                assign cart_total_cents = cart.total_price
                assign free_shipping_progress = 0
                if free_shipping_threshold_cents > 0
                  assign free_shipping_progress = cart_total_cents | times: 100 | divided_by: free_shipping_threshold_cents
                endif
                if free_shipping_progress > 100
                  assign free_shipping_progress = 100
                endif
                assign free_shipping_remaining_cents = free_shipping_threshold_cents | minus: cart_total_cents
                assign free_shipping_remaining_formatted = free_shipping_remaining_cents | money_without_trailing_zeros
                assign free_shipping_threshold_formatted = free_shipping_threshold_cents | money_without_trailing_zeros
              -%}

              <div class="lusena-free-shipping" role="region" aria-label="Darmowa wysyłka">
                <div class="lusena-free-shipping__msg">
                  {%- if free_shipping_remaining_cents > 0 -%}
                    {%- render 'lusena-icon', name: 'truck', class: 'lusena-icon-sm lusena-shrink-0', stroke_width: 2 -%}
                    <span class="lusena-free-shipping__text">
                      Brakuje Ci <span class="lusena-free-shipping__amount">{{ free_shipping_remaining_formatted }}</span> do darmowej dostawy
                    </span>
                  {%- else -%}
                    {%- render 'lusena-icon', name: 'truck', class: 'lusena-icon-sm lusena-shrink-0', stroke_width: 2 -%}
                    <span class="lusena-free-shipping__text lusena-free-shipping__text--qualified">
                      Masz darmową dostawę!
                    </span>
                  {%- endif -%}
                </div>
                <div class="lusena-free-shipping__track">
                  <span
                    class="lusena-free-shipping__fill{% if free_shipping_remaining_cents <= 0 %} lusena-free-shipping__fill--qualified{% endif %}"
                    style="width: {{ free_shipping_progress }}%;"
                  ></span>
                </div>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} Section blocks (subtotal, buttons, apps) {%- endcomment -%}
        {% for block in section.blocks %}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}

            {%- when 'subtotal' -%}
              <div class="js-contents" {{ block.shopify_attributes }}>
                <div>
                  {%- if cart.cart_level_discount_applications.size > 0 -%}
                    <ul class="lusena-cart-discounts" role="list" aria-label="Rabat">
                      {%- for discount in cart.cart_level_discount_applications -%}
                        <li class="lusena-cart-discounts__item">
                          <span class="lusena-cart-discounts__icon">{{- 'icon-discount.svg' | inline_asset_content -}}</span>
                          {{ discount.title | escape }}
                          (-{{ discount.total_allocated_amount | money_without_trailing_zeros }})
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </div>

                <div class="lusena-cart-totals">
                  <span class="lusena-cart-totals__label">Suma</span>
                  <span class="lusena-cart-totals__value">{{ cart.total_price | money_without_trailing_zeros }}</span>
                </div>

                <p class="lusena-cart-tax lusena-type-caption">
                  {%- if cart.duties_included and cart.taxes_included -%}
                    {%- if shop.shipping_policy.body == blank -%}
                      Z wliczonymi cłami i podatkami. Obliczenie rabatów i wysyłki przy realizacji zakupu.
                    {%- else -%}
                      Z wliczonymi cłami i podatkami. Obliczenie rabatów i <a href="{{ shop.shipping_policy.url }}">wysyłki</a> przy realizacji zakupu.
                    {%- endif -%}
                  {%- elsif cart.duties_included == false and cart.taxes_included -%}
                    {%- if shop.shipping_policy.body == blank -%}
                      Z wliczonymi podatkami. Obliczenie rabatów i wysyłki przy realizacji zakupu.
                    {%- else -%}
                      Z wliczonymi podatkami. Obliczenie rabatów i <a href="{{ shop.shipping_policy.url }}">wysyłki</a> przy realizacji zakupu.
                    {%- endif -%}
                  {%- elsif cart.duties_included and cart.taxes_included == false -%}
                    {%- if shop.shipping_policy.body == blank -%}
                      Z wliczonymi cłami. Obliczenie podatków, rabatów i wysyłki przy realizacji zakupu.
                    {%- else -%}
                      Z wliczonymi cłami. Obliczenie podatków, rabatów i <a href="{{ shop.shipping_policy.url }}">wysyłki</a> przy realizacji zakupu.
                    {%- endif -%}
                  {%- elsif cart.duties_included == false and cart.taxes_included == false -%}
                    {%- if shop.shipping_policy.body == blank -%}
                      Obliczenie podatków, rabatów i wysyłki przy realizacji zakupu.
                    {%- else -%}
                      Obliczenie podatków, rabatów i <a href="{{ shop.shipping_policy.url }}">wysyłki</a> przy realizacji zakupu.
                    {%- endif -%}
                  {%- endif -%}
                </p>
              </div>

            {%- else -%}
              {%- comment -%} Buttons block {%- endcomment -%}
              <div class="lusena-cart-ctas" {{ block.shopify_attributes }}>
                <button
                  type="submit"
                  id="checkout"
                  name="checkout"
                  form="cart"
                  class="lusena-btn lusena-btn--primary lusena-btn--size-lg lusena-btn--full-width"
                  data-lusena-page-checkout
                  {% if cart == empty %}disabled{% endif %}
                >
                  <span class="lusena-btn__content">Przejdź do kasy</span>
                  <span class="loading__spinner hidden">
                    <span class="lusena-btn__loading-text">Przekierowuję...</span>
                  </span>
                </button>

                {%- if cart != empty -%}
                  <div class="lusena-cart-ctas__trust">
                    {%- render 'lusena-icon', name: 'shield-check', class: 'lusena-icon-sm lusena-shrink-0', stroke_width: 2 -%}
                    <span class="lusena-cart-ctas__trust-text">60 dni na zwrot · Bezpieczna płatność</span>
                  </div>
                {%- endif -%}

                <div class="lusena-cart-ctas__continue">
                  <a href="{{ routes.all_products_collection_url }}" class="lusena-cart-ctas__continue-link">
                    Kontynuuj zakupy
                  </a>
                </div>
              </div>

              {%- if additional_checkout_buttons -%}
                <div class="lusena-cart-dynamic-checkout">
                  {{ content_for_additional_checkout_buttons }}
                </div>
              {%- endif -%}
          {%- endcase -%}
        {% endfor %}

        <div id="cart-errors"></div>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  /* CSS extracted to assets/lusena-cart-page.css */
{% endstylesheet %}

<script>
  (() => {
    const btn = document.querySelector('[data-lusena-page-checkout]');
    if (!btn) return;

    btn.addEventListener('click', () => {
      if (btn.disabled) return;
      btn.classList.add('loading');
      btn.setAttribute('aria-busy', 'true');
      const spinner = btn.querySelector('.loading__spinner');
      if (spinner) spinner.classList.remove('hidden');
    });

    window.addEventListener('pageshow', (event) => {
      if (!event.persisted) return;
      if (!btn.classList.contains('loading')) return;
      btn.classList.remove('loading');
      btn.removeAttribute('aria-busy');
      const spinner = btn.querySelector('.loading__spinner');
      if (spinner) spinner.classList.add('hidden');
    });
  })();
</script>

{% schema %}
{
  "name": "LUSENA koszyk - suma",
  "class": "lusena-cart-footer-wrapper",
  "settings": [],
  "blocks": [
    {
      "type": "subtotal",
      "name": "t:sections.main-cart-footer.blocks.subtotal.name",
      "limit": 1
    },
    {
      "type": "buttons",
      "name": "t:sections.main-cart-footer.blocks.buttons.name",
      "limit": 1
    },
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
