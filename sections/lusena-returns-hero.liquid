{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-brand lusena-text-center lusena-returns-hero lusena-spacing--hero lusena-spacing--snug-top"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-returns-hero__shield" aria-hidden="true">
    {% render 'lusena-icon', name: 'shield-check', class: 'lusena-returns-hero__shield-icon', stroke_width: 0.5 %}
  </div>

  <div class="lusena-container lusena-returns-hero__container lusena-content-flow">
    <span class="lusena-kicker lusena-returns-hero__kicker{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {{ section.settings.hero_kicker | escape }}
    </span>
    <h1 class="lusena-type-hero lusena-returns-hero__title{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {{ section.settings.hero_heading_line_1 | escape }}<br>
      <em>{{ section.settings.hero_heading_line_2 | escape }}</em>
    </h1>
    <p class="lusena-type-body lusena-returns-hero__body{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {{ section.settings.hero_body | escape }}
    </p>

    {%- if section.blocks.size > 0 -%}
      <div class="lusena-returns-hero__chips{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}>
        {%- for block in section.blocks -%}
          {%- if block.type == 'proof' and block.settings.text != blank -%}
            <span class="lusena-returns-hero__chip{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }}>
              {% render 'lusena-icon', name: 'check', class: 'lusena-returns-hero__chip-icon', stroke_width: 2 %}
              {{ block.settings.text | escape }}
            </span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="lusena-returns-hero__badge-wrap{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div class="lusena-returns-hero__badge">
        {% render 'lusena-icon', name: 'rotate-ccw', class: 'lusena-returns-hero__badge-icon', stroke_width: 1.5 %}
        <span class="lusena-returns-hero__badge-text">{{ section.settings.hero_badge | escape }}</span>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .lusena-returns-hero {
    position: relative;
    overflow: hidden;
  }

  /* Shield overlay */
  .lusena-returns-hero__shield {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.03;
    pointer-events: none;
  }

  .lusena-returns-hero__shield-icon {
    width: 44.8rem;
    height: 44.8rem;
  }

  /* Container narrowing - 0-2-0 to beat foundations .lusena-container */
  .lusena-returns-hero .lusena-returns-hero__container {
    position: relative;
    max-width: 89.6rem;
  }

  /* Kicker color - 0-2-0 */
  .lusena-returns-hero .lusena-returns-hero__kicker {
    color: var(--lusena-accent-2);
  }

  /* Heading custom sizing */
  .lusena-returns-hero .lusena-returns-hero__title {
    font-size: 3.6rem;
    line-height: 1.05;
  }

  @media (min-width: 768px) {
    .lusena-returns-hero .lusena-returns-hero__title {
      font-size: 6rem;
      line-height: 1;
    }
  }

  /* Body constrained width - 0-2-0 for margin-inline */
  .lusena-returns-hero .lusena-returns-hero__body {
    max-width: 64rem;
    margin-inline: auto;
  }

  /* Proof chips row */
  .lusena-returns-hero__chips {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--lusena-space-2);
    margin-top: var(--lusena-space-2);
  }

  @media (min-width: 768px) {
    .lusena-returns-hero__chips {
      gap: var(--lusena-space-3);
    }
  }

  .lusena-returns-hero__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 1.4rem;
    color: var(--lusena-text-1);
  }

  .lusena-returns-hero__chip-icon {
    width: 1.6rem;
    height: 1.6rem;
    color: var(--lusena-accent-cta);
  }

  /* Badge */
  .lusena-returns-hero__badge-wrap {
    margin-top: var(--lusena-space-2);
  }

  .lusena-returns-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1.2rem 2.4rem;
    border: 1px solid color-mix(in srgb, var(--lusena-accent-2) 30%, transparent);
    border-radius: 9999px;
    background-color: rgb(255 255 255 / 0.5);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
  }

  .lusena-returns-hero__badge-icon {
    width: 1.6rem;
    height: 1.6rem;
    color: var(--lusena-accent-2);
  }

  .lusena-returns-hero__badge-text {
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--lusena-accent-2);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Returns: Hero",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "hero_kicker",
      "label": "Hero kicker",
      "default": "Zero Ryzyka"
    },
    {
      "type": "text",
      "id": "hero_heading_line_1",
      "label": "Hero heading line 1",
      "default": "60 Dni Gwarancji"
    },
    {
      "type": "text",
      "id": "hero_heading_line_2",
      "label": "Hero heading line 2 (italic)",
      "default": "Przespanych Nocy"
    },
    {
      "type": "textarea",
      "id": "hero_body",
      "label": "Hero body",
      "default": "Jesteśmy tak pewni jakości LUSENA, że dajemy Ci 60 nocy na testy. Śpij na niej, pierz ją, używaj. Jeśli nie poczujesz różnicy - oddamy Ci pieniądze."
    },
    {
      "type": "text",
      "id": "hero_badge",
      "label": "Hero badge",
      "default": "Zwrot nawet używanego produktu"
    }
  ],
  "blocks": [
    {
      "type": "proof",
      "name": "Proof chip",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "60 dni na test"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LUSENA Returns: Hero",
      "blocks": [
        {
          "type": "proof",
          "settings": {
            "text": "60 dni na test"
          }
        },
        {
          "type": "proof",
          "settings": {
            "text": "Zwrot używanego produktu"
          }
        },
        {
          "type": "proof",
          "settings": {
            "text": "Pełny zwrot środków"
          }
        }
      ]
    }
  ]
}
{% endschema %}
