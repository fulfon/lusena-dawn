      "default": "Kolor"
    },
    {
      "type": "header",
      "content": "Add to cart"
    },
    {
      "type": "text",
      "id": "add_to_cart_label",
      "label": "Add to cart label",
      "default": "Dodaj do koszyka"
    },
    {
      "type": "header",
      "content": "Delivery"
