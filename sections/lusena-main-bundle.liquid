    {
      "type": "text",
      "id": "delivery_eta_label",
      "label": "Delivery ETA",
      "default": "Dostawa: 1\u20132 dni robocze"
    },
    {
      "type": "text",
      "id": "delivery_returns_link_label",
      "label": "Returns link label",
      "default": "60 dni na zwrot"
    },
    {
      "type": "header",
      "content": "Guarantee"
    },
    {
      "type": "text",
      "id": "guarantee_heading",
      "label": "Guarantee heading",
      "default": "60 dni gwarancji spokojnego snu"
    },
    {
      "type": "text",
      "id": "guarantee_link_label",
      "label": "Guarantee link label",
      "default": "Jak to dzia\u0142a?"
    },
    {
      "type": "header",
      "content": "Payment"
    },
    {
      "type": "text",
      "id": "secure_payment_label",
      "label": "Secure payment label",
      "default": "Bezpieczna p\u0142atno\u015b\u0107"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Bundle benefit text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LUSENA bundle (PDP)",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "text": "Oszcz\u0119dzasz w por\u00f3wnaniu do zakupu osobno"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "text": "Produkty zaprojektowane tak, by si\u0119 uzupe\u0142nia\u0107"
          }
        },
        {
          "type": "benefit",
