{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-surface-1 lusena-quality-certificates lusena-spacing--standard"
  id="certificates"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container lusena-split">
    <div class="lusena-content-flow{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}>
      <h2 class="lusena-type-h1">
        {{ section.settings.cert_heading | escape }}
      </h2>
      <div class="lusena-type-body">
        {{ section.settings.cert_body }}
      </div>

      {%- assign oeko_number = section.settings.oeko_number | strip -%}
      {%- if shop.metafields.lusena.oeko_tex_certificate_number != blank -%}
        {%- assign oeko_number_value = shop.metafields.lusena.oeko_tex_certificate_number.value -%}
        {%- if oeko_number_value != blank -%}
          {%- assign oeko_number = oeko_number_value | strip -%}
        {%- endif -%}
      {%- endif -%}

      {%- assign verify_label = section.settings.oeko_verify_label -%}
      {%- if verify_label == blank -%}
        {%- assign verify_label = 'Zweryfikuj certyfikat online' -%}
      {%- endif -%}

      {%- assign verify_url = section.settings.oeko_verify_url -%}
      {%- if verify_url == blank -%}
        {%- if oeko_number != blank -%}
          {%- assign oeko_number_encoded = oeko_number | url_encode -%}
          {%- assign verify_url = 'https://www.oeko-tex.com/en/detail/?number=' | append: oeko_number_encoded -%}
        {%- endif -%}
      {%- endif -%}

      {%- assign certificate_url = blank -%}
      {%- assign certificate_label = section.settings.cert_button_label -%}
      {%- if certificate_label == blank -%}
        {%- assign certificate_label = 'Pobierz Certyfikat (PDF)' -%}
      {%- endif -%}

      {%- if shop.metafields.lusena.oeko_tex_certificate != blank -%}
        {%- assign certificate_file = shop.metafields.lusena.oeko_tex_certificate.value -%}
        {%- if certificate_file != blank -%}
          {%- if certificate_file.url != blank -%}
            {%- assign certificate_url = certificate_file.url -%}
          {%- endif -%}
        {%- endif -%}
      {%- endif -%}

      {%- if certificate_url == blank -%}
        {%- if section.settings.cert_button_link != blank -%}
          {%- assign certificate_url = section.settings.cert_button_link -%}
        {%- endif -%}
      {%- endif -%}

      {%- if oeko_number != blank -%}
        <p class="lusena-type-caption">
          Numer certyfikatu: <span class="lusena-quality-certificates__oeko-number">{{ oeko_number | escape }}</span>
        </p>
      {%- endif -%}

      {%- if certificate_url != blank or verify_url != blank -%}
        <div class="lusena-quality-certificates__actions">
          {%- if certificate_url != blank -%}
            <a
              href="{{ certificate_url }}"
              target="_blank"
              rel="noopener"
              class="lusena-btn lusena-btn--outline lusena-btn--size-default"
            >
              {{ certificate_label | escape }}
            </a>
          {%- endif -%}
          {%- if verify_url != blank -%}
            <a
              href="{{ verify_url }}"
              target="_blank"
              rel="noopener"
              class="lusena-quality-certificates__verify-link"
            >
              {{ verify_label | escape }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="lusena-quality-certificates__logos{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}>
      <div class="lusena-quality-certificates__logo-cell">
        {%- if section.settings.cert_logo_1 != blank -%}
          {{ section.settings.cert_logo_1 | image_url: width: 400 | image_tag: loading: 'lazy' }}
        {%- else -%}
          <span class="lusena-quality-certificates__logo-placeholder">{{ section.settings.cert_logo_1_placeholder | escape }}</span>
        {%- endif -%}
      </div>
      <div class="lusena-quality-certificates__logo-cell">
        {%- if section.settings.cert_logo_2 != blank -%}
          {{ section.settings.cert_logo_2 | image_url: width: 400 | image_tag: loading: 'lazy' }}
        {%- else -%}
          <span class="lusena-quality-certificates__logo-placeholder">{{ section.settings.cert_logo_2_placeholder | escape }}</span>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  /* OEKO number styling */
  .lusena-quality-certificates__oeko-number {
    font-weight: 500;
    color: var(--lusena-text-1);
  }

  /* Actions layout */
  .lusena-quality-certificates__actions {
    display: flex;
    flex-direction: column;
    gap: var(--lusena-space-2);
    align-items: flex-start;
  }

  @media (min-width: 576px) {
    .lusena-quality-certificates__actions {
      flex-direction: row;
      align-items: center;
    }
  }

  /* Verify link */
  .lusena-quality-certificates__verify-link {
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--lusena-accent-cta);
    text-decoration: underline;
    text-underline-offset: 0.4rem;
  }

  @media (hover: hover) {
    .lusena-quality-certificates__verify-link:hover {
      text-decoration: none;
    }
  }

  /* Logo grid */
  .lusena-quality-certificates__logos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--lusena-space-2);
  }

  .lusena-quality-certificates__logo-cell {
    background-color: var(--lusena-color-n100);
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--lusena-color-n200);
  }

  .lusena-quality-certificates__logo-placeholder {
    font-size: 1.2rem;
    color: var(--lusena-color-n400);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Quality: Certs",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "cert_heading",
      "label": "Certificates heading",
      "default": "Certyfikaty Bezpieczeństwa"
    },
    {
      "type": "richtext",
      "id": "cert_body",
      "label": "Certificates body",
      "default": "<p>Twoja skóra dotyka poduszki przez 8 godzin dziennie. Musisz mieć pewność, że jest wolna od chemii. Nasz jedwab posiada certyfikat <strong>OEKO-TEX® Standard 100</strong> (Klasa I — bezpieczne nawet dla niemowląt).</p>"
    },
    {
      "type": "text",
      "id": "oeko_number",
      "label": "OEKO-TEX certificate number (fallback)"
    },
    {
      "type": "text",
      "id": "oeko_verify_label",
      "label": "Verify link label",
      "default": "Zweryfikuj certyfikat online"
    },
    {
      "type": "url",
      "id": "oeko_verify_url",
      "label": "Verify link URL (optional override)",
      "info": "Domyślnie budowane z numeru certyfikatu: https://www.oeko-tex.com/en/detail/?number={NUMER}. Preferowane źródło numeru: metafield sklepu `lusena.oeko_tex_certificate_number`."
    },
    {
      "type": "text",
      "id": "cert_button_label",
      "label": "Certificate button label",
      "default": "Pobierz Certyfikat (PDF)"
    },
    {
      "type": "url",
      "id": "cert_button_link",
      "label": "Certificate button link (fallback)",
      "info": "Preferowane: metafield sklepu `lusena.oeko_tex_certificate` (file_reference). Jeśli metafield jest pusty, użyty zostanie ten link."
    },
    {
      "type": "image_picker",
      "id": "cert_logo_1",
      "label": "Certificate logo 1"
    },
    {
      "type": "text",
      "id": "cert_logo_1_placeholder",
      "label": "Certificate logo 1 placeholder",
      "default": "Logo OEKO-TEX"
    },
    {
      "type": "image_picker",
      "id": "cert_logo_2",
      "label": "Certificate logo 2"
    },
    {
      "type": "text",
      "id": "cert_logo_2_placeholder",
      "label": "Certificate logo 2 placeholder",
      "default": "Logo 6A Grade"
    }
  ],
  "presets": [
    {
      "name": "LUSENA Quality: Certs"
    }
  ]
}
{% endschema %}
