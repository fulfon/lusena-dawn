{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-surface-2 lusena-quality-origin lusena-spacing--spacious"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container lusena-split">
    <div class="lusena-content-flow{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}>
      <div class="lusena-content-flow--tight">
        <span class="lusena-type-caption lusena-kicker lusena-quality-origin__kicker">
          {{ section.settings.origin_kicker | escape }}
        </span>
        <h2 class="lusena-type-h1 lusena-quality-origin__heading">
          {{ section.settings.origin_heading | escape }}
        </h2>
      </div>
      <div class="lusena-content-flow--tight lusena-type-body">
        {{ section.settings.origin_body }}
      </div>
      {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
        <a href="{{ section.settings.cta_link }}" class="lusena-quality-origin__cta lusena-type-body">
          {{ section.settings.cta_label | escape }}
        </a>
      {%- endif -%}
    </div>

    <div class="lusena-quality-origin__image-wrap{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}>
      {%- if section.settings.origin_image != blank -%}
        {{
          section.settings.origin_image
          | image_url: width: 1400
          | image_tag:
            class: 'lusena-quality-origin__image',
            loading: 'lazy',
            widths: '600, 900, 1200, 1400',
            sizes: '(min-width: 768px) 45vw, 90vw'
        }}
      {%- else -%}
        <span class="lusena-quality-origin__placeholder">
          {{ section.settings.origin_image_placeholder | escape }}
        </span>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  /* Kicker color */
  .lusena-quality-origin .lusena-quality-origin__kicker {
    color: var(--lusena-accent-2);
  }

  /* Image wrap */
  .lusena-quality-origin__image-wrap {
    aspect-ratio: 4 / 5;
    background-color: var(--lusena-color-n100);
    border-radius: 0.2rem;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lusena-quality-origin__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lusena-quality-origin__placeholder {
    color: var(--lusena-color-n400);
    font-weight: 300;
    font-style: italic;
    text-align: center;
    padding-inline: var(--lusena-space-3);
  }

  /* CTA link */
  .lusena-quality-origin__cta {
    color: var(--lusena-accent-2);
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.2s ease;
  }

  .lusena-quality-origin__cta:hover {
    opacity: 0.75;
  }

  /* Desktop: image on left (reorder) + nowrap heading */
  @media (min-width: 768px) {
    .lusena-quality-origin__image-wrap {
      order: -1;
    }

    .lusena-quality-origin__heading {
      white-space: nowrap;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Quality: Origin",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "origin_kicker",
      "label": "Origin kicker",
      "default": "Pochodzenie"
    },
    {
      "type": "text",
      "id": "origin_heading",
      "label": "Origin heading",
      "default": "Suzhou: Stolica Jedwabiu od 1430 roku"
    },
    {
      "type": "richtext",
      "id": "origin_body",
      "label": "Origin body",
      "default": "<p>Nie kupujemy od anonimowych pośredników. Nasz jedwab pochodzi bezpośrednio z Shengze (prefektura Suzhou) - miejsca płacącego jedwabiem podatki cesarzowi od czasów dynastii Ming.</p><p>To tutaj tradycja spotyka się z nowoczesną technologią. Od kokonu jedwabnika morwowego klasy 6A do gotowej poszewki.</p>"
    },
    {
      "type": "image_picker",
      "id": "origin_image",
      "label": "Origin image"
    },
    {
      "type": "text",
      "id": "origin_image_placeholder",
      "label": "Origin image placeholder",
      "default": "Zdjęcie: Mapa regionu Suzhou / Manufaktura"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    }
  ],
  "presets": [
    {
      "name": "LUSENA Quality: Origin"
    }
  ]
}
{% endschema %}
