{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-brand lusena-returns-editorial lusena-spacing--standard"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container lusena-split">
    <div class="lusena-content-flow{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <span class="lusena-type-caption lusena-kicker lusena-returns-editorial__kicker">
        {{ section.settings.kicker | escape }}
      </span>
      <h2 class="lusena-type-h1 lusena-returns-editorial__heading">
        {{ section.settings.heading_line_1 | escape }}
        <em>{{ section.settings.heading_line_2 | escape }}</em>
      </h2>
      <div class="lusena-type-body lusena-returns-editorial__body">
        {{ section.settings.body_paragraph_1 }}
      </div>
      <div class="lusena-type-body lusena-returns-editorial__body">
        {{ section.settings.body_paragraph_2 }}
      </div>
      {%- if section.settings.link_label != blank and section.settings.link_url != blank -%}
        <a href="{{ section.settings.link_url }}" class="lusena-returns-editorial__link">
          {{ section.settings.link_label | escape }}
          {% render 'lusena-icon', name: 'arrow-right', class: 'lusena-returns-editorial__link-icon', stroke_width: 1.8 %}
        </a>
      {%- endif -%}
    </div>

    <div class="lusena-returns-editorial__compare{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div class="lusena-returns-editorial__compare-header">
        <span class="lusena-returns-editorial__compare-label">
          {{ section.settings.standard_label | escape }}
        </span>
        <span class="lusena-returns-editorial__compare-label lusena-returns-editorial__compare-label--lusena">
          {{ section.settings.lusena_label | escape }}
        </span>
      </div>

      <div
        class="lusena-returns-editorial__compare-rows"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        {%- for block in section.blocks -%}
          {%- if block.type == 'compare_row' -%}
            <div
              class="lusena-returns-editorial__compare-row{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {{ block.shopify_attributes }}
            >
              <div class="lusena-returns-editorial__row lusena-returns-editorial__row--standard">
                <div class="lusena-returns-editorial__row-icon lusena-returns-editorial__row-icon--x">
                  <span>&times;</span>
                </div>
                <span class="lusena-returns-editorial__row-text">{{ block.settings.standard | escape }}</span>
              </div>
              <div class="lusena-returns-editorial__row lusena-returns-editorial__row--lusena">
                <div class="lusena-returns-editorial__row-icon lusena-returns-editorial__row-icon--check">
                  {% render 'lusena-icon', name: 'check', class: 'lusena-returns-editorial__check-icon', stroke_width: 2.5 %}
                </div>
                <span class="lusena-returns-editorial__row-text lusena-returns-editorial__row-text--lusena">{{ block.settings.lusena | escape }}</span>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  /* Kicker color — 0-2-0 */
  .lusena-returns-editorial .lusena-returns-editorial__kicker {
    color: var(--lusena-accent-2);
  }

  /* Heading italic — 0-2-0 */
  .lusena-returns-editorial .lusena-returns-editorial__heading em {
    font-style: italic;
  }

  /* Body text contrast on cream bg — 0-2-0 */
  .lusena-returns-editorial .lusena-returns-editorial__body {
    color: var(--lusena-text-1);
  }

  /* Fix: reset <p> margins inside richtext body divs to prevent margin collapse-through */
  .lusena-returns-editorial .lusena-returns-editorial__body p { margin: 0; }

  /* Link style — 32px CTA gap (was 40px from p margin + content-flow) */
  .lusena-returns-editorial .lusena-returns-editorial__link { margin-top: var(--lusena-space-4); }

  .lusena-returns-editorial__link {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    color: var(--lusena-accent-cta);
    font-weight: 500;
    font-size: 1.6rem;
    transition: gap var(--lusena-transition-med);
  }

  .lusena-returns-editorial__link:hover {
    gap: 1.2rem;
  }

  .lusena-returns-editorial__link-icon {
    width: 1.6rem;
    height: 1.6rem;
  }

  /* Comparison grid */
  .lusena-returns-editorial__compare {
    display: flex;
    flex-direction: column;
    gap: var(--lusena-space-2);
  }

  .lusena-returns-editorial__compare-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--lusena-space-2);
  }

  .lusena-returns-editorial__compare-label {
    text-align: center;
    font-size: 1.2rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--lusena-text-2);
  }

  .lusena-returns-editorial__compare-label--lusena {
    color: var(--lusena-accent-cta);
  }

  .lusena-returns-editorial__compare-rows {
    display: flex;
    flex-direction: column;
    gap: var(--lusena-space-2);
  }

  .lusena-returns-editorial__compare-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--lusena-space-2);
  }

  /* Row cells */
  .lusena-returns-editorial__row {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 1.6rem;
    border-radius: var(--lusena-btn-radius);
  }

  .lusena-returns-editorial__row--standard {
    background-color: var(--lusena-color-n0);
  }

  .lusena-returns-editorial__row--lusena {
    background-color: color-mix(in srgb, var(--lusena-accent-cta) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--lusena-accent-cta) 10%, transparent);
  }

  /* Icon circles */
  .lusena-returns-editorial__row-icon {
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .lusena-returns-editorial__row-icon--x {
    background-color: var(--lusena-color-n100);
    color: var(--lusena-text-2);
    font-size: 1.4rem;
    line-height: 1;
  }

  .lusena-returns-editorial__row-icon--check {
    background-color: color-mix(in srgb, var(--lusena-accent-cta) 10%, transparent);
  }

  .lusena-returns-editorial__check-icon {
    width: 1.4rem;
    height: 1.4rem;
    color: var(--lusena-accent-cta);
  }

  /* Row text */
  .lusena-returns-editorial__row-text {
    font-size: 1.4rem;
    color: var(--lusena-text-2);
  }

  .lusena-returns-editorial__row-text--lusena {
    color: var(--lusena-text-1);
    font-weight: 500;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Returns: Editorial",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Nasza Filozofia"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading line 1",
      "default": "Dlaczego 60 dni,"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading line 2 (italic)",
      "default": "a nie 14?"
    },
    {
      "type": "richtext",
      "id": "body_paragraph_1",
      "label": "Body paragraph 1",
      "default": "<p>Prawdziwe korzyści jedwabiu - mniej łamania włosów, gładsza skóra, lepszy sen - ujawniają się po tygodniach codziennego użytkowania.</p>"
    },
    {
      "type": "richtext",
      "id": "body_paragraph_2",
      "label": "Body paragraph 2",
      "default": "<p>Dlatego dajemy Ci pełne dwa miesiące. A jeśli mimo wszystko nie pokochasz efektu, zwrot jest bezproblemowy.</p>"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "Dowiedz się więcej o naszej jakości"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "text",
      "id": "standard_label",
      "label": "Comparison label left",
      "default": "Standard rynkowy"
    },
    {
      "type": "text",
      "id": "lusena_label",
      "label": "Comparison label right",
      "default": "LUSENA"
    }
  ],
  "blocks": [
    {
      "type": "compare_row",
      "name": "Comparison row",
      "settings": [
        {
          "type": "text",
          "id": "standard",
          "label": "Standard text",
          "default": "14 dni na zwrot"
        },
        {
          "type": "text",
          "id": "lusena",
          "label": "LUSENA text",
          "default": "60 dni na zwrot"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LUSENA Returns: Editorial",
      "blocks": [
        {
          "type": "compare_row",
          "settings": {
            "standard": "14 dni na zwrot",
            "lusena": "60 dni na zwrot"
          }
        },
        {
          "type": "compare_row",
          "settings": {
            "standard": "Produkt musi być nieużywany",
            "lusena": "Zwrot nawet po użyciu"
          }
        },
        {
          "type": "compare_row",
          "settings": {
            "standard": "Skomplikowane formularze",
            "lusena": "Jeden krótki e-mail"
          }
        },
        {
          "type": "compare_row",
          "settings": {
            "standard": "Zwrot po 14+ dniach",
            "lusena": "Pieniądze w 3-5 dni"
          }
        }
      ]
    }
  ]
}
{% endschema %}
