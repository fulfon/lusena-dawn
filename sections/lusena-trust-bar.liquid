{%- assign known_icons = 'layers,shield-check,truck,clock,star,sparkles' | split: ',' -%}

{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: 'padding-top:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: 'padding-bottom:' | append: section.settings.padding_bottom | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-surface-1"
  data-lusena-trust-bar
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container">
    <ul class="lusena-trust-bar" role="list"
      {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}
    >
      {%- for block in section.blocks -%}
        <li class="lusena-trust-bar__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            {%- if known_icons contains block.settings.icon -%}
              {% render 'lusena-icon', name: block.settings.icon, class: 'lusena-trust-bar__icon-svg', stroke_width: 1.5 %}
            {%- else -%}
              <span class="lusena-trust-bar__icon-fallback" aria-hidden="true">
                {{ block.settings.icon }}
              </span>
            {%- endif -%}
          {%- endif -%}
          <span class="lusena-trust-bar__text">
            <span class="lusena-trust-bar__title">{{ block.settings.title | escape }}</span>
            {%- if block.settings.subtitle != blank -%}
              <span class="lusena-trust-bar__subtitle lusena-type-caption">{{ block.settings.subtitle | escape }}</span>
            {%- endif -%}
          </span>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>

{% stylesheet %}
  /* All trust bar CSS moved to lusena-foundations.css to avoid compiled_assets truncation. */
{% endstylesheet %}

