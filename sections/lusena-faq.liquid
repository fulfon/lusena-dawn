{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif

  assign faq_bg = section.settings.bg_style | default: 'surface-1'
-%}
<section
  class="lusena-bg-{{ faq_bg }} lusena-faq lusena-spacing--standard"
  data-lusena-faq
  {% if section.settings.anchor_id != blank %}
    id="{{ section.settings.anchor_id }}"
  {% endif %}
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container--narrow">
    <div class="lusena-text-center lusena-gap-section-intro lusena-content-flow--tight{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <h2 class="lusena-type-h1">
        {{ section.settings.heading | escape }}
      </h2>
      {%- if section.settings.subheading != blank -%}
        <p class="lusena-type-body">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>

    <div class="lusena-faq__list">
      {%- for block in section.blocks -%}
        <details
          class="lusena-accordion lusena-faq__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {% if block.settings.is_returns_target %}
            data-lusena-accordion-returns
          {% endif %}
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
          {% endif %}
          {{ block.shopify_attributes }}
        >
          <summary class="lusena-accordion__summary lusena-faq__summary">
            {{ block.settings.question | escape }}
            {% render 'lusena-icon',
              name: 'chevron-down',
              class: 'lusena-accordion__icon lusena-faq__chevron',
              stroke_width: 2
            %}
          </summary>
          <div class="lusena-faq__content">
            <div class="lusena-faq__content-inner lusena-type-body">
              {{ block.settings.answer }}
            </div>
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  /* Containment for animation performance */
  .lusena-faq__item {
    contain: layout style;
  }

  /* Custom font overrides for summary (foundations .lusena-accordion__summary handles layout) */
  .lusena-faq__summary {
    font-family: var(--lusena-font-brand);
    font-size: 1.6rem;
    line-height: 2.4rem;
    font-weight: 500;
    transition: color var(--lusena-transition-fast);
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }

  .lusena-faq__summary:hover {
    color: var(--lusena-accent-cta);
  }

  /* Chevron sizing + data-state rotation for JS animation */
  .lusena-faq__chevron {
    width: 1.6rem;
    height: 1.6rem;
    flex-shrink: 0;
  }

  .lusena-faq__item[data-state='open'] .lusena-faq__chevron {
    transform: rotate(180deg);
  }

  /* Height animation wrapper */
  .lusena-faq__content {
    overflow: hidden;
    height: 0;
    transition: height 0.15s cubic-bezier(0.25, 0.1, 0.25, 1);
    will-change: height;
  }

  /* Content inner: padding + GPU-composited fade */
  .lusena-faq__content-inner {
    padding-bottom: var(--lusena-space-3);
  }

  /* Normalize paragraph spacing to match line-height leading (8px) */
  .lusena-faq__content-inner p { margin: 0 0 var(--lusena-space-1); }
  .lusena-faq__content-inner > :first-child { margin-top: 0; }
  .lusena-faq__content-inner > :last-child { margin-bottom: 0; }

  /* All FAQ lists flush left - scannable, consistent, mobile-friendly */
  .lusena-faq__content-inner ul { padding-left: 0; list-style-position: inside; }

  /* Inline links inside FAQ answers - teal + underline, matching .lusena-richtext a */
  .lusena-faq__content-inner a {
    color: var(--lusena-accent-cta);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    transition: color var(--lusena-transition-fast);
  }
  .lusena-faq__content-inner a:hover {
    color: var(--lusena-accent-cta-hover);
  }

  @supports (touch-action: manipulation) {
    .lusena-faq__content-inner {
      opacity: 1;
      transform: translateY(0);
      transition: opacity 0.18s ease, transform 0.18s ease;
    }
    .lusena-faq__item[data-state='closed'] .lusena-faq__content-inner,
    .lusena-faq__item[data-state='closing'] .lusena-faq__content-inner {
      opacity: 0;
      transform: translateY(-6px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lusena-faq__content {
      transition: none;
      will-change: auto;
    }
    .lusena-faq__content-inner {
      transition: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
{% endstylesheet %}

<script>
  (function() {
    var root = document.querySelector('[data-lusena-faq]');
    if (!root) return;

    var prefersReducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var items = Array.from(root.querySelectorAll('details.lusena-faq__item'));

    function getContent(details) { return details.querySelector('.lusena-faq__content'); }
    function getInner(content) { return content.querySelector('.lusena-faq__content-inner') || content.firstElementChild; }
    function clearPendingEnd(content) {
      if (typeof content._lusenaFaqOnEnd === 'function') {
        content.removeEventListener('transitionend', content._lusenaFaqOnEnd);
        content._lusenaFaqOnEnd = null;
      }
    }

    function closeItem(details) {
      var content = getContent(details);
      if (!content) return;
      clearPendingEnd(content);

      if (prefersReducedMotion) {
        details.open = false;
        details.dataset.state = 'closed';
        content.style.height = '0px';
        return;
      }

      var h = content.offsetHeight;
      content.style.height = h + 'px';
      details.dataset.state = 'closing';

      requestAnimationFrame(function() {
        content.style.height = '0px';
      });

      var onEnd = function(e) {
        if (e.target !== content || e.propertyName !== 'height') return;
        content.removeEventListener('transitionend', onEnd);
        content._lusenaFaqOnEnd = null;
        details.dataset.state = 'closed';
        details.open = false;
        content.style.height = '0px';
      };
      content._lusenaFaqOnEnd = onEnd;
      content.addEventListener('transitionend', onEnd);
    }

    function openItem(details) {
      var content = getContent(details);
      if (!content) return;
      clearPendingEnd(content);

      // Accordion: close all others
      items.forEach(function(other) {
        if (other !== details && other.open) closeItem(other);
      });

      if (prefersReducedMotion) {
        details.open = true;
        details.dataset.state = 'open';
        content.style.height = 'auto';
        return;
      }

      details.open = true;
      content.style.height = '0px';
      details.dataset.state = 'open';

      var inner = getInner(content);
      var targetH = inner ? inner.scrollHeight : content.scrollHeight;

      requestAnimationFrame(function() {
        content.style.height = targetH + 'px';
      });

      // No transitionend handler - keep the pixel height as-is.
      // No snap to 'auto', so no layout jump at the end.
    }

    // Init
    items.forEach(function(details) {
      var content = getContent(details);
      if (!content) return;
      if (details.open) {
        details.dataset.state = 'open';
        content.style.height = 'auto';
      } else {
        details.dataset.state = 'closed';
        content.style.height = '0px';
      }
    });

    function onFastTap(el, callback) {
      var startX, startY, handled;
      el.addEventListener('touchstart', function(e) {
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
        handled = false;
      }, { passive: true });
      el.addEventListener('touchend', function(e) {
        var t = e.changedTouches[0];
        if (Math.abs(t.clientX - startX) < 10 && Math.abs(t.clientY - startY) < 10) {
          handled = true;
          e.preventDefault();
          callback(e);
        }
      }, { passive: false });
      el.addEventListener('click', function(e) {
        e.preventDefault();
        if (!handled) callback(e);
        handled = false;
      });
    }

    items.forEach(function(details) {
      var summary = details.querySelector('summary');
      if (!summary) return;
      onFastTap(summary, function() {
        if (details.open) closeItem(details);
        else openItem(details);
      });
    });

    if (window.Shopify && window.Shopify.designMode) {
      document.addEventListener('shopify:section:load', function() {
        items.forEach(function(details) {
          var content = getContent(details);
          if (!content) return;
          if (details.open) {
            details.dataset.state = 'open';
            content.style.height = 'auto';
          } else {
            details.dataset.state = 'closed';
            content.style.height = '0px';
          }
        });
      });
    }
  })();
</script>

{% schema %}
{
  "name": "LUSENA FAQ",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "select",
      "id": "bg_style",
      "label": "Background style",
      "options": [
        { "value": "surface-1", "label": "White (surface-1)" },
        { "value": "surface-2", "label": "Cream (surface-2)" },
        { "value": "brand", "label": "Warm porcelain (brand)" }
      ],
      "default": "surface-1"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID (for deep-linking)",
      "info": "Used as the section id attribute, e.g. 'details' to enable #details links."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Common Questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Everything you need to know about sleeping on silk."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Is it real mulberry silk?"
        },
