{{ 'lusena-search.css' | asset_url | stylesheet_tag }}
<script src="{{ 'main-search.js' | asset_url }}" defer="defer"></script>
<script>
  /* Override Dawn's scrollIntoView-on-focus - field is already visible */
  customElements.whenDefined('main-search').then(() => {
    const el = document.querySelector('.lusena-search-page main-search');
    if (el) el.scrollIntoView = () => {};
  });
</script>

{%- liquid
  assign terms = search.terms | escape
-%}

{%- paginate search.results by 16 -%}
  <section class="lusena-search-page lusena-spacing--standard{% unless search.performed %} lusena-search-page--initial{% endunless %}">
    <div class="lusena-container">

      {%- comment -%} ── HEADER: title + search form ── {%- endcomment -%}
      <div class="lusena-search-page__header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        <h1 class="lusena-type-h1">
          {%- if search.performed -%}
            Wyniki wyszukiwania
          {%- else -%}
            Szukaj
          {%- endif -%}
        </h1>

        {%- if settings.predictive_search_enabled -%}
          <predictive-search data-loading-text="{{ 'accessibility.loading' | t }}">
        {%- endif -%}
          <main-search>
            <form action="{{ routes.search_url }}" method="get" role="search">
              <div class="lusena-search">
                {%- render 'lusena-icon', name: 'search', class: 'lusena-search__icon' -%}
                <input
                  class="lusena-input lusena-search__input"
                  id="Search-In-Template"
                  type="search"
                  name="q"
                  value="{{ search.terms | escape }}"
                  placeholder="Szukaj produktów..."
                  {%- if settings.predictive_search_enabled -%}
                    role="combobox"
                    aria-expanded="false"
                    aria-owns="predictive-search-results"
                    aria-controls="predictive-search-results"
                    aria-haspopup="listbox"
                    aria-autocomplete="list"
                    autocorrect="off"
                    autocomplete="off"
                    autocapitalize="off"
                    spellcheck="false"
                  {%- endif -%}
                >
                <input name="options[prefix]" type="hidden" value="last">

                {%- if settings.predictive_search_enabled -%}
                  <div class="predictive-search predictive-search--search-template" tabindex="-1" data-predictive-search>
                    {%- render 'loading-spinner', class: 'predictive-search__loading-state' -%}
                  </div>
                  <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
                {%- endif -%}

                <button
                  type="reset"
                  class="lusena-search__reset{% if search.terms == blank %} hidden{% endif %}"
                  aria-label="{{ 'general.search.reset' | t }}"
                >
                  {%- render 'lusena-icon', name: 'x', class: 'lusena-search__reset-icon' -%}
                </button>
              </div>
            </form>
          </main-search>
        {%- if settings.predictive_search_enabled -%}
          </predictive-search>
        {%- endif -%}

        {%- if search.performed and search.results_count > 0 -%}
          {%- liquid
            assign count = search.results_count
            assign count_mod10 = count | modulo: 10
            assign count_mod100 = count | modulo: 100
            if count == 1
              assign result_word = 'wynik'
            elsif count_mod10 >= 2 and count_mod10 <= 4 and count_mod100 != 12 and count_mod100 != 13 and count_mod100 != 14
              assign result_word = 'wyniki'
            else
              assign result_word = 'wyników'
            endif
          -%}
          <p class="lusena-type-caption" role="status">
            {{ count }} {{ result_word }} dla &bdquo;{{ search.terms }}&rdquo;
          </p>
        {%- endif -%}
      </div>

      {%- comment -%} ── RESULTS ── {%- endcomment -%}
      {%- if search.performed -%}
        {%- if search.results_count > 0 -%}

          {%- comment -%} Product results {%- endcomment -%}
          {%- assign has_products = false -%}
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {%- assign has_products = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if has_products -%}
            <div class="lusena-search-page__grid">
              {%- for item in search.results -%}
                {%- if item.object_type == 'product' -%}
                  <div
                    {% if settings.animations_reveal_on_scroll %}
                      class="scroll-trigger animate--slide-in"
                      data-cascade
                    {% endif %}
                  >
                    {% render 'lusena-product-card',
                      product: item,
                      show_secondary_image: true
                    %}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- comment -%} Non-product results (articles, pages) {%- endcomment -%}
          {%- assign has_other = false -%}
          {%- for item in search.results -%}
            {%- if item.object_type == 'article' or item.object_type == 'page' -%}
              {%- assign has_other = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if has_other -%}
            <div class="lusena-search-page__other">
              <h2 class="lusena-type-h2">Inne wyniki</h2>
              <ul class="lusena-search-page__links">
                {%- for item in search.results -%}
                  {%- if item.object_type == 'article' -%}
                    <li>
                      <a href="{{ item.url }}">{{ item.title | escape }}</a>
                      <span class="lusena-search-page__type-label">Artykuł</span>
                    </li>
                  {%- elsif item.object_type == 'page' -%}
                    <li>
                      <a href="{{ item.url }}">{{ item.title | escape }}</a>
                      <span class="lusena-search-page__type-label">Strona</span>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          {%- comment -%} Pagination - "Load more" pattern {%- endcomment -%}
          {%- if paginate.pages > 1 -%}
            <div class="lusena-search-page__pagination lusena-text-center{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
              {%- if paginate.next -%}
                <a
                  href="{{ paginate.next.url }}"
                  class="lusena-btn lusena-btn--outline lusena-btn--size-default"
                >
                  <span class="lusena-btn__content">Załaduj więcej</span>
                </a>
              {%- else -%}
                <span class="lusena-type-caption">Wyświetlono wszystkie wyniki.</span>
              {%- endif -%}
            </div>
          {%- endif -%}

        {%- else -%}

          {%- comment -%} ── EMPTY STATE ── {%- endcomment -%}
          <div class="lusena-empty">
            {%- render 'lusena-icon', name: 'search', class: 'lusena-search-page__empty-icon' -%}
            <p class="lusena-type-body">Brak wyników dla &bdquo;{{ search.terms }}&rdquo;</p>
            <p class="lusena-type-caption">Spróbuj innej frazy lub zobacz nasze propozycje:</p>
          </div>

          {%- comment -%} Bestsellers fallback {%- endcomment -%}
          <div class="lusena-search-page__suggestions-grid">
            <h2 class="lusena-type-h2 lusena-search-page__suggestions-heading">Może Cię zainteresować</h2>
            <div class="lusena-search-page__grid">
              {%- for product in collections.all.products limit: 4 -%}
                <div
                  {% if settings.animations_reveal_on_scroll %}
                    class="scroll-trigger animate--slide-in"
                    data-cascade
                  {% endif %}
                >
                  {% render 'lusena-product-card',
                    product: product,
                    show_secondary_image: true
                  %}
                </div>
              {%- endfor -%}
            </div>
          </div>

        {%- endif -%}
      {%- endif -%}

    </div>
  </section>
{%- endpaginate -%}

{% stylesheet %}
  /* CSS extracted to assets/lusena-search.css */
{% endstylesheet %}

{% schema %}
{
  "name": "Wyniki wyszukiwania",
  "tag": "section",
  "class": "section"
}
{% endschema %}
