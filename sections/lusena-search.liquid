<script src="{{ 'main-search.js' | asset_url }}" defer="defer"></script>
<script>
  /* Override Dawn's scrollIntoView-on-focus — field is already visible */
  customElements.whenDefined('main-search').then(() => {
    const el = document.querySelector('.lusena-search-page main-search');
    if (el) el.scrollIntoView = () => {};
  });
</script>

{%- liquid
  assign terms = search.terms | escape
-%}

{%- paginate search.results by 16 -%}
  <section class="lusena-search-page lusena-spacing--standard{% unless search.performed %} lusena-search-page--initial{% endunless %}">
    <div class="lusena-container">

      {%- comment -%} ── HEADER: title + search form ── {%- endcomment -%}
      <div class="lusena-search-page__header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        <h1 class="lusena-type-h1">
          {%- if search.performed -%}
            Wyniki wyszukiwania
          {%- else -%}
            Szukaj
          {%- endif -%}
        </h1>

        {%- if settings.predictive_search_enabled -%}
          <predictive-search data-loading-text="{{ 'accessibility.loading' | t }}">
        {%- endif -%}
          <main-search>
            <form action="{{ routes.search_url }}" method="get" role="search">
              <div class="lusena-search">
                {%- render 'lusena-icon', name: 'search', class: 'lusena-search__icon' -%}
                <input
                  class="lusena-input lusena-search__input"
                  id="Search-In-Template"
                  type="search"
                  name="q"
                  value="{{ search.terms | escape }}"
                  placeholder="Szukaj produktów..."
                  {%- if settings.predictive_search_enabled -%}
                    role="combobox"
                    aria-expanded="false"
                    aria-owns="predictive-search-results"
                    aria-controls="predictive-search-results"
                    aria-haspopup="listbox"
                    aria-autocomplete="list"
                    autocorrect="off"
                    autocomplete="off"
                    autocapitalize="off"
                    spellcheck="false"
                  {%- endif -%}
                >
                <input name="options[prefix]" type="hidden" value="last">

                {%- if settings.predictive_search_enabled -%}
                  <div class="predictive-search predictive-search--search-template" tabindex="-1" data-predictive-search>
                    {%- render 'loading-spinner', class: 'predictive-search__loading-state' -%}
                  </div>
                  <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
                {%- endif -%}

                <button
                  type="reset"
                  class="lusena-search__reset{% if search.terms == blank %} hidden{% endif %}"
                  aria-label="{{ 'general.search.reset' | t }}"
                >
                  {%- render 'lusena-icon', name: 'x', class: 'lusena-search__reset-icon' -%}
                </button>
              </div>
            </form>
          </main-search>
        {%- if settings.predictive_search_enabled -%}
          </predictive-search>
        {%- endif -%}

        {%- if search.performed and search.results_count > 0 -%}
          {%- liquid
            assign count = search.results_count
            assign count_mod10 = count | modulo: 10
            assign count_mod100 = count | modulo: 100
            if count == 1
              assign result_word = 'wynik'
            elsif count_mod10 >= 2 and count_mod10 <= 4 and count_mod100 != 12 and count_mod100 != 13 and count_mod100 != 14
              assign result_word = 'wyniki'
            else
              assign result_word = 'wyników'
            endif
          -%}
          <p class="lusena-type-caption" role="status">
            {{ count }} {{ result_word }} dla &bdquo;{{ search.terms }}&rdquo;
          </p>
        {%- endif -%}
      </div>

      {%- comment -%} ── RESULTS ── {%- endcomment -%}
      {%- if search.performed -%}
        {%- if search.results_count > 0 -%}

          {%- comment -%} Product results {%- endcomment -%}
          {%- assign has_products = false -%}
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {%- assign has_products = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if has_products -%}
            <div class="lusena-search-page__grid">
              {%- for item in search.results -%}
                {%- if item.object_type == 'product' -%}
                  <div
                    {% if settings.animations_reveal_on_scroll %}
                      class="scroll-trigger animate--slide-in"
                      data-cascade
                    {% endif %}
                  >
                    {% render 'lusena-product-card',
                      product: item,
                      show_secondary_image: true
                    %}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- comment -%} Non-product results (articles, pages) {%- endcomment -%}
          {%- assign has_other = false -%}
          {%- for item in search.results -%}
            {%- if item.object_type == 'article' or item.object_type == 'page' -%}
              {%- assign has_other = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if has_other -%}
            <div class="lusena-search-page__other">
              <h2 class="lusena-type-h2">Inne wyniki</h2>
              <ul class="lusena-search-page__links">
                {%- for item in search.results -%}
                  {%- if item.object_type == 'article' -%}
                    <li>
                      <a href="{{ item.url }}">{{ item.title | escape }}</a>
                      <span class="lusena-search-page__type-label">Artykuł</span>
                    </li>
                  {%- elsif item.object_type == 'page' -%}
                    <li>
                      <a href="{{ item.url }}">{{ item.title | escape }}</a>
                      <span class="lusena-search-page__type-label">Strona</span>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          {%- comment -%} Pagination — "Load more" pattern {%- endcomment -%}
          {%- if paginate.pages > 1 -%}
            <div class="lusena-search-page__pagination lusena-text-center{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
              {%- if paginate.next -%}
                <a
                  href="{{ paginate.next.url }}"
                  class="lusena-btn lusena-btn--outline lusena-btn--size-default"
                >
                  <span class="lusena-btn__content">Załaduj więcej</span>
                </a>
              {%- else -%}
                <span class="lusena-type-caption">Wyświetlono wszystkie wyniki.</span>
              {%- endif -%}
            </div>
          {%- endif -%}

        {%- else -%}

          {%- comment -%} ── EMPTY STATE ── {%- endcomment -%}
          <div class="lusena-empty">
            {%- render 'lusena-icon', name: 'search', class: 'lusena-search-page__empty-icon' -%}
            <p class="lusena-type-body">Brak wyników dla &bdquo;{{ search.terms }}&rdquo;</p>
            <p class="lusena-type-caption">Spróbuj innej frazy lub zobacz nasze propozycje:</p>
          </div>

          {%- comment -%} Bestsellers fallback {%- endcomment -%}
          <div class="lusena-search-page__suggestions-grid">
            <h2 class="lusena-type-h2 lusena-search-page__suggestions-heading">Może Cię zainteresować</h2>
            <div class="lusena-search-page__grid">
              {%- for product in collections.all.products limit: 4 -%}
                <div
                  {% if settings.animations_reveal_on_scroll %}
                    class="scroll-trigger animate--slide-in"
                    data-cascade
                  {% endif %}
                >
                  {% render 'lusena-product-card',
                    product: product,
                    show_secondary_image: true
                  %}
                </div>
              {%- endfor -%}
            </div>
          </div>

        {%- endif -%}
      {%- endif -%}

    </div>
  </section>
{%- endpaginate -%}

{% stylesheet %}
  /* Push footer below fold — min-height on main, not flex stretch */
  main:has(.lusena-search-page) {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
  }
  main:has(.lusena-search-page) > .shopify-section {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  /* Initial state (no query): position search in upper third of viewport.
     Not dead-center (keyboard + predictive dropdown need space below). */
  .lusena-search-page--initial {
    flex: 1;
    padding-top: 18vh;
  }

  /* Results state: content flows from top, section grows to fill */
  .lusena-search-page:not(.lusena-search-page--initial) {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .lusena-search-page:not(.lusena-search-page--initial) > .lusena-container {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  /* Header — centered search form */
  .lusena-search-page .lusena-search-page__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--lusena-space-3);
    text-align: center;
    margin-bottom: var(--lusena-space-4);
  }

  /* Search form width constrained */
  .lusena-search-page__header predictive-search,
  .lusena-search-page__header main-search,
  .lusena-search-page__header form {
    width: 100%;
    max-width: 60rem;
  }

  /* Reset (X) button inside search input */
  .lusena-search__reset {
    position: absolute;
    right: var(--lusena-space-2);
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--lusena-text-2);
    transition: color var(--lusena-transition-fast);
  }
  .lusena-search__reset:hover { color: var(--lusena-text-1); }
  .lusena-search__reset-icon { width: 1.8rem; height: 1.8rem; }

  /* Product grid — 2 / 3 / 4 columns (matches collection page) */
  .lusena-search-page .lusena-search-page__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--lusena-space-5) var(--lusena-space-1);
  }
  @media (min-width: 768px) {
    .lusena-search-page .lusena-search-page__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--lusena-space-5) var(--lusena-space-3);
    }
  }
  @media (min-width: 1024px) {
    .lusena-search-page .lusena-search-page__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--lusena-space-6) var(--lusena-space-4);
    }
  }

  /* Non-product results */
  .lusena-search-page .lusena-search-page__other {
    margin-top: var(--lusena-space-8);
    border-top: 1px solid var(--lusena-color-n200);
    padding-top: var(--lusena-space-6);
  }
  .lusena-search-page .lusena-search-page__links {
    list-style: none;
    padding: 0;
    margin-top: var(--lusena-space-3);
    display: flex;
    flex-direction: column;
    gap: var(--lusena-space-2);
  }
  .lusena-search-page__links li {
    display: flex;
    align-items: baseline;
    gap: var(--lusena-space-2);
  }
  .lusena-search-page__links a {
    font-family: var(--lusena-font-ui);
    font-size: 1.6rem;
    color: var(--lusena-accent-cta);
    text-decoration: underline;
    text-underline-offset: 0.3em;
    text-decoration-thickness: 1px;
  }
  .lusena-search-page__links a:hover {
    color: var(--lusena-accent-cta-hover);
  }
  .lusena-search-page__type-label {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--lusena-text-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Soften search input focus — teal outline only, no black border */
  .lusena-search-page .lusena-search__input:focus {
    border-color: var(--lusena-accent-cta);
    outline: none;
    box-shadow: 0 0 0 2px rgba(14, 94, 90, 0.15);
  }

  /* Empty state — minimal padding, content flows tightly */
  .lusena-search-page .lusena-empty {
    padding: var(--lusena-space-2) 0 var(--lusena-space-2);
  }
  .lusena-search-page .lusena-search-page__empty-icon {
    width: 4.8rem;
    height: 4.8rem;
    stroke-width: 1;
    color: var(--lusena-color-n400);
  }

  /* Suggestions heading after empty state */
  .lusena-search-page .lusena-search-page__suggestions-heading {
    text-align: center;
    margin-bottom: var(--lusena-space-4);
  }


  /* Pagination spacing */
  .lusena-search-page .lusena-search-page__pagination {
    margin-top: var(--lusena-space-6);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Wyniki wyszukiwania",
  "tag": "section",
  "class": "section"
}
{% endschema %}
