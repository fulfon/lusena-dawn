{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-surface-2 lusena-newsletter lusena-spacing--standard"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container">
    <div class="lusena-newsletter__inner{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- if section.settings.heading != blank -%}
        <h2 class="lusena-newsletter__heading">
          {{ section.settings.heading | escape }}
        </h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="lusena-newsletter__subheading">
          {{ section.settings.subheading | escape }}
        </p>
      {%- endif -%}

      {%- form 'customer', id: 'LusenaNewsletter', class: 'lusena-newsletter__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">

        {%- if form.posted_successfully? -%}
          <div class="lusena-newsletter__success" role="status">
            <p>{{ section.settings.success_message | escape }}</p>
          </div>
        {%- else -%}
          {%- if form.errors -%}
            <div class="lusena-newsletter__error" role="alert">
              <p>{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
            </div>
          {%- endif -%}

          <label class="lusena-newsletter__sr-only" for="LusenaNewsletterEmail">Twój adres email</label>
          <div class="lusena-newsletter__field-group">
            <input
              id="LusenaNewsletterEmail"
              type="email"
              name="contact[email]"
              class="lusena-newsletter__input"
              placeholder="Twój adres email"
              required
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              {% if form.errors %}
                autofocus
                aria-invalid="true"
                aria-describedby="LusenaNewsletter-error"
              {% endif %}
            >
            <button
              type="submit"
              class="lusena-newsletter__btn"
            >
              {{ section.settings.button_label | default: 'Dołącz' | escape }}
            </button>
          </div>
        {%- endif -%}
      {%- endform -%}

      {%- if section.settings.privacy_text != blank -%}
        <p class="lusena-newsletter__privacy">
          {{ section.settings.privacy_text | escape }}
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .lusena-newsletter__inner {
    max-width: 520px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
  }

  .lusena-newsletter__heading {
    font-family: var(--lusena-font-brand);
    font-size: 28px;
    line-height: 1.2;
    margin: 0;
    color: var(--lusena-text-1);
  }

  @media (min-width: 768px) {
    .lusena-newsletter__heading {
      font-size: 36px;
    }
  }

  .lusena-newsletter__subheading {
    font-size: 16px;
    line-height: 1.5;
    color: var(--lusena-text-2);
    margin: 0;
    max-width: 420px;
  }

  .lusena-newsletter__form {
    width: 100%;
    margin-top: 8px;
  }

  .lusena-newsletter__field-group {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
  }

  @media (min-width: 480px) {
    .lusena-newsletter__field-group {
      flex-direction: row;
      gap: 0;
    }
  }

  .lusena-newsletter__input {
    height: 48px;
    padding: 0 16px;
    font-size: 15px;
    border: 1px solid var(--lusena-color-n300);
    border-radius: 6px;
    background: #fff;
    color: var(--lusena-text-1);
    outline: none;
    transition: border-color 0.15s ease;
  }

  @media (min-width: 480px) {
    .lusena-newsletter__input {
      flex: 1;
      border-radius: 6px 0 0 6px;
      border-right: none;
    }
  }

  .lusena-newsletter__input:focus {
    border-color: var(--lusena-accent-cta);
    box-shadow: 0 0 0 1px var(--lusena-accent-cta);
  }

  .lusena-newsletter__input::placeholder {
    color: var(--lusena-color-n400);
  }

  .lusena-newsletter__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 48px;
    padding: 0 28px;
    font-size: 15px;
    font-weight: 600;
    white-space: nowrap;
    border: none;
    border-radius: 6px;
    background: var(--lusena-accent-cta);
    color: #fff;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  @media (min-width: 480px) {
    .lusena-newsletter__btn {
      border-radius: 0 6px 6px 0;
    }
  }

  .lusena-newsletter__btn:hover {
    background: #0a4e4a;
  }

  .lusena-newsletter__btn:focus-visible {
    outline: 2px solid var(--lusena-accent-cta);
    outline-offset: 2px;
  }

  .lusena-newsletter__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .lusena-newsletter__privacy {
    font-size: 12px;
    line-height: 1.5;
    color: var(--lusena-color-n700);
    margin: 4px 0 0;
  }

  .lusena-newsletter__success {
    padding: 16px 24px;
    background: #f0faf4;
    border: 1px solid #2F7D4E;
    border-radius: 8px;
    color: #2F7D4E;
    font-size: 15px;
    font-weight: 500;
    text-align: center;
    width: 100%;
  }

  .lusena-newsletter__error {
    padding: 12px 16px;
    background: #fef2f2;
    border: 1px solid #B91C1C;
    border-radius: 8px;
    color: #B91C1C;
    font-size: 14px;
    margin-bottom: 8px;
    width: 100%;
    text-align: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Dołącz do Klubu LUSENA"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Zapisz się i odbierz kod -10% na pierwsze zamówienie."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Dołącz"
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Privacy text",
      "default": "Bez spamu. Wypisz się w każdej chwili."
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Dziękujemy! Sprawdź swoją skrzynkę email."
    }
  ],
  "presets": [
    {
      "name": "LUSENA Newsletter"
    }
  ]
}
{% endschema %}
