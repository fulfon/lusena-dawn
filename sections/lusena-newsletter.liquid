{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-surface-2 lusena-spacing--standard"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container">
    <div class="lusena-newsletter__inner{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- if section.settings.heading != blank -%}
        <h2 class="lusena-type-h1">
          {{ section.settings.heading | escape }}
        </h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="lusena-type-body lusena-newsletter__subheading">
          {{ section.settings.subheading | escape }}
        </p>
      {%- endif -%}

      {%- form 'customer', id: 'LusenaNewsletter', class: 'lusena-newsletter__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">

        {%- if form.posted_successfully? -%}
          <div class="lusena-form-msg lusena-form-msg--success lusena-newsletter__msg" role="status">
            {{ section.settings.success_message | escape }}
          </div>
        {%- else -%}
          {%- if form.errors -%}
            <div class="lusena-form-msg lusena-form-msg--error lusena-newsletter__msg" role="alert">
              {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
            </div>
          {%- endif -%}

          <label class="lusena-visually-hidden" for="LusenaNewsletterEmail">Twój adres email</label>
          <div class="lusena-newsletter lusena-newsletter__field-group">
            <input
              id="LusenaNewsletterEmail"
              type="email"
              name="contact[email]"
              class="lusena-input"
              placeholder="Twój adres email"
              required
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              {% if form.errors %}
                autofocus
                aria-invalid="true"
                aria-describedby="LusenaNewsletter-error"
              {% endif %}
            >
            <button
              type="submit"
              class="lusena-newsletter__btn"
            >
              {{ section.settings.button_label | default: 'Dołącz' | escape }}
            </button>
          </div>
        {%- endif -%}
      {%- endform -%}

      {%- if section.settings.privacy_text != blank -%}
        <p class="lusena-type-caption">
          {{ section.settings.privacy_text | escape }}
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  /* Foundations handles: .lusena-newsletter (flex col → row layout), .lusena-input (editorial border-radius: 0),
     .lusena-form-msg / --success / --error, .lusena-visually-hidden, .lusena-type-h1/body/caption. */

  /* Inner wrapper: centered narrow column */
  .lusena-newsletter__inner {
    max-width: 52.0rem;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--lusena-space-2);
    align-items: center;
  }

  /* Subheading max-width */
  .lusena-newsletter__subheading {
    max-width: 42.0rem;
  }

  /* Form container */
  .lusena-newsletter__form {
    width: 100%;
    margin-top: var(--lusena-space-1);
  }

  /* Override foundations .lusena-newsletter gap for joined look on desktop */
  .lusena-newsletter__field-group {
    width: 100%;
  }

  /* Submit button (editorial: no border-radius) */
  .lusena-newsletter__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 4.4rem;
    padding: var(--lusena-space-2) var(--lusena-space-4);
    font-family: var(--lusena-font-ui);
    font-size: 1.6rem;
    font-weight: 600;
    white-space: nowrap;
    border: none;
    border-radius: var(--lusena-btn-radius);
    background: var(--lusena-accent-cta);
    color: var(--lusena-color-n0);
    cursor: pointer;
    transition: background var(--lusena-transition-fast);
  }

  .lusena-newsletter__btn:hover {
    background: var(--lusena-accent-cta-hover);
  }

  .lusena-newsletter__btn:focus-visible {
    outline: 2px solid var(--lusena-accent-cta);
    outline-offset: 2px;
  }

  /* Form messages: slightly larger for newsletter context */
  .lusena-newsletter__msg {
    width: 100%;
    font-size: 1.4rem;
    padding: var(--lusena-space-2);
    text-align: center;
    justify-content: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Dołącz do Klubu LUSENA"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Zapisz się i odbierz kod -10% na pierwsze zamówienie."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Dołącz"
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Privacy text",
      "default": "Bez spamu. Wypisz się w każdej chwili."
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Dziękujemy! Sprawdź swoją skrzynkę email."
    }
  ],
  "presets": [
    {
      "name": "LUSENA Newsletter"
    }
  ]
}
{% endschema %}
