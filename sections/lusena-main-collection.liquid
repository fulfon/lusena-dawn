{%- liquid
  assign override_style = ''
  comment
    Always emit top-padding overrides (even when 0) so the value explicitly
    overrides the lusena-spacing--compact tier default.  This matches the
    draft-shop layout where content starts right below the header.
  endcomment
  assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif

  assign count = collection.products_count
  assign count_mod10 = count | modulo: 10
  assign count_mod100 = count | modulo: 100
  if count == 1
    assign product_word = 'produkt'
  elsif count_mod10 >= 2 and count_mod10 <= 4 and count_mod100 != 12 and count_mod100 != 13 and count_mod100 != 14
    assign product_word = 'produkty'
  else
    assign product_word = 'produktów'
  endif
-%}
<section
  class="lusena-main-collection lusena-spacing--compact"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  {%- paginate collection.products by section.settings.products_per_page -%}
    <div class="lusena-container">
      {% render 'lusena-breadcrumbs', page_type: 'collection', collection: collection %}

      <div class="lusena-main-collection__header lusena-gap-section-intro{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <div>
          <h1 class="lusena-type-h1">{{ collection.title | escape }}</h1>
          {%- if collection.description != blank -%}
            <p class="lusena-type-body">{{ collection.description | strip_html }}</p>
          {%- else -%}
            <p class="lusena-type-body">{{ section.settings.default_description | escape }}</p>
          {%- endif -%}
        </div>

        <div class="lusena-main-collection__meta">
          <span class="lusena-type-caption">
            {{ count }} {{ product_word }}
          </span>
        </div>
      </div>

      <div class="lusena-main-collection__grid">
        {%- for product in collection.products -%}
          <div
            {% if settings.animations_reveal_on_scroll %}
              class="scroll-trigger animate--slide-in"
              data-cascade
            {% endif %}
          >
            {% render 'lusena-product-card',
              product: product,
              show_secondary_image: section.settings.show_secondary_image
            %}
          </div>
        {%- endfor -%}
      </div>

      <div class="lusena-gap-cta-top lusena-text-center{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {%- if paginate.next -%}
          <a
            href="{{ paginate.next.url }}"
            class="lusena-btn lusena-btn--outline lusena-btn--size-default"
          >
            <span class="lusena-btn__content">Załaduj więcej</span>
          </a>
        {%- else -%}
          <span class="lusena-type-caption">Wyświetlono wszystkie produkty.</span>
        {%- endif -%}
      </div>
    </div>
  {%- endpaginate -%}
</section>

{% stylesheet %}
  .lusena-main-collection .lusena-main-collection__header {
    display: flex;
    flex-direction: column;
    align-items: baseline;
  }
  .lusena-main-collection .lusena-main-collection__header p {
    margin-top: var(--lusena-space-1);
  }
  .lusena-main-collection .lusena-main-collection__meta {
    display: flex;
    align-items: center;
    gap: var(--lusena-space-05);
    margin-top: var(--lusena-space-2);
  }
  .lusena-main-collection .lusena-main-collection__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--lusena-space-5) var(--lusena-space-1);
  }
  @media (min-width: 768px) {
    .lusena-main-collection .lusena-main-collection__header {
      flex-direction: row;
      justify-content: space-between;
    }
    .lusena-main-collection .lusena-main-collection__meta {
      margin-top: 0;
    }
    .lusena-main-collection .lusena-main-collection__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--lusena-space-5) var(--lusena-space-3);
    }
  }
  @media (min-width: 1024px) {
    .lusena-main-collection .lusena-main-collection__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--lusena-space-6) var(--lusena-space-4);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA collection (draft)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 36,
      "step": 4,
      "label": "Products per page",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show hover image",
      "default": true
    },
    {
      "type": "text",
      "id": "default_description",
      "label": "Fallback description",
      "default": "Jedwab morwowy premium dla lepszego snu."
    }
  ],
  "presets": [
    {
      "name": "LUSENA collection (draft)"
    }
  ]
}
{% endschema %}
