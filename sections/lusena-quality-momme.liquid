{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-brand lusena-quality-momme lusena-spacing--standard"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container lusena-split">
    <div class="lusena-quality-momme__image-wrap{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}>
      {%- if section.settings.momme_image != blank -%}
        {{
          section.settings.momme_image
          | image_url: width: 1400
          | image_tag:
            class: 'lusena-quality-momme__image',
            loading: 'lazy',
            widths: '600, 900, 1200, 1400',
            sizes: '(min-width: 768px) 45vw, 90vw'
        }}
      {%- else -%}
        <span class="lusena-quality-momme__placeholder">
          {{ section.settings.momme_image_placeholder | escape }}
        </span>
      {%- endif -%}
    </div>

    <div class="lusena-content-flow{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}>
      <h2 class="lusena-type-h1">
        {{ section.settings.momme_heading | escape }}
      </h2>
      <div class="lusena-content-flow--tight lusena-type-body">
        {{ section.settings.momme_body }}
        {%- if section.blocks.size > 0 -%}
          <ul class="lusena-content-flow--tight">
            {%- for block in section.blocks -%}
              {%- if block.type == 'momme_benefit' -%}
                <li class="lusena-quality-momme__bullet" {{ block.shopify_attributes }}>
                  <span class="lusena-quality-momme__bullet-dot" aria-hidden="true"></span>
                  <span class="lusena-quality-momme__bullet-text">{{- block.settings.text | escape -}}</span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .lusena-quality-momme ul { padding-left: 0; }

  /* Image wrap */
  .lusena-quality-momme__image-wrap {
    aspect-ratio: 1;
    background-color: var(--lusena-color-n100);
    border-radius: 0.2rem;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lusena-quality-momme__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lusena-quality-momme__placeholder {
    color: var(--lusena-color-n400);
    font-weight: 300;
    font-style: italic;
    text-align: center;
    padding-inline: var(--lusena-space-3);
  }

  /* Gold bullet list */
  .lusena-quality-momme__bullet {
    display: flex;
    flex-wrap: nowrap;
    align-items: flex-start;
    gap: 0.8rem;
    list-style: none;
  }

  .lusena-quality-momme__bullet-dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background-color: var(--lusena-accent-2);
    flex-shrink: 0;
    margin-top: calc((1.625em - 0.6rem) / 2);
  }

  .lusena-quality-momme__bullet-text {
    min-width: 0;
    flex: 1;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Quality: 22 momme",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "image_picker",
      "id": "momme_image",
      "label": "Momme image"
    },
    {
      "type": "text",
      "id": "momme_image_placeholder",
      "label": "Momme image placeholder",
      "default": "Zdjęcie mikroskopowe: 19 vs 22 momme"
    },
    {
      "type": "text",
      "id": "momme_heading",
      "label": "Momme heading",
      "default": "Dlaczego 22 momme?"
    },
    {
      "type": "richtext",
      "id": "momme_body",
      "label": "Momme body",
      "default": "<p>Standard rynkowy to 16-19 momme. Dla nas to za mało.</p><p>LUSENA używa wyłącznie jedwabiu o gramaturze <strong>22 momme</strong> - gęstszego i trwalszego niż standard. Przekłada się to na:</p>"
    }
  ],
  "blocks": [
    {
      "type": "momme_benefit",
      "name": "Momme benefit",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Wyższą trwałość - znosi pranie znacznie lepiej niż cieńsze odpowiedniki."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LUSENA Quality: 22 momme",
      "blocks": [
        {
          "type": "momme_benefit",
          "settings": {
            "text": "Wyższą trwałość - znosi pranie znacznie lepiej niż cieńsze odpowiedniki."
          }
        },
        {
          "type": "momme_benefit",
          "settings": {
            "text": "Gładszą fakturę - mniejsze tarcie dla Twojej skóry i włosów."
          }
        },
        {
          "type": "momme_benefit",
          "settings": {
            "text": "Lepszą termoregulację - chłodzi latem, grzeje zimą."
          }
        }
      ]
    }
  ]
}
{% endschema %}
