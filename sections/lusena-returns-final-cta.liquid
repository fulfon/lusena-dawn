{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-text-center lusena-returns-final-cta lusena-spacing--spacious"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container lusena-returns-final-cta__container lusena-content-flow--relaxed">
    <div class="lusena-returns-final-cta__icon-wrap{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {% render 'lusena-icon', name: 'clock', class: 'lusena-returns-final-cta__icon', stroke_width: 1.5 %}
    </div>
    <h2 class="lusena-type-h1 lusena-returns-final-cta__heading{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {{ section.settings.heading_line_1 | escape }}
      <em>{{ section.settings.heading_line_2 | escape }}</em>
    </h2>
    <p class="lusena-type-body lusena-returns-final-cta__body{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {{ section.settings.body | escape }}
    </p>
    <div class="lusena-returns-final-cta__actions lusena-gap-cta-top{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- if section.settings.primary_button_label != blank and section.settings.primary_button_link != blank -%}
        <a
          href="{{ section.settings.primary_button_link }}"
          class="lusena-btn lusena-btn--primary lusena-btn--size-default lusena-returns-final-cta__primary"
        >
          {{ section.settings.primary_button_label | escape }}
        </a>
      {%- endif -%}

      {%- if section.settings.secondary_button_label != blank and section.settings.secondary_button_link != blank -%}
        <a
          href="{{ section.settings.secondary_button_link }}"
          class="lusena-returns-final-cta__secondary-link"
        >
          {{ section.settings.secondary_button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  /* Inverted teal background */
  .lusena-returns-final-cta {
    background-color: var(--lusena-accent-cta);
  }

  /* Selection colors */
  .lusena-returns-final-cta::selection,
  .lusena-returns-final-cta *::selection {
    background-color: rgb(255 255 255);
    color: var(--lusena-accent-cta);
  }

  /* Container narrow — 0-2-0 */
  .lusena-returns-final-cta .lusena-returns-final-cta__container {
    max-width: 80rem;
  }

  /* Icon circle — frosted glass */
  .lusena-returns-final-cta__icon-wrap {
    width: 4.8rem;
    height: 4.8rem;
    margin-inline: auto;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgb(255 255 255 / 0.1);
  }

  .lusena-returns-final-cta__icon {
    width: 2.4rem;
    height: 2.4rem;
    color: #fff;
  }

  /* Heading — white text at 0-2-0 */
  .lusena-returns-final-cta .lusena-returns-final-cta__heading {
    color: #fff;
  }

  /* Body — semi-transparent white at 0-2-0 */
  .lusena-returns-final-cta .lusena-returns-final-cta__body {
    color: rgb(255 255 255 / 0.8);
    max-width: 56rem;
    margin-inline: auto;
  }

  /* Actions layout */
  .lusena-returns-final-cta__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.6rem;
  }

  /* Primary button — inverted: white bg, teal text */
  .lusena-returns-final-cta .lusena-returns-final-cta__primary {
    background-color: #fff;
    color: var(--lusena-accent-cta);
    border-color: #fff;
  }

  .lusena-returns-final-cta .lusena-returns-final-cta__primary:hover {
    background-color: rgb(255 255 255 / 0.9);
  }

  /* Secondary link — white, underlined */
  .lusena-returns-final-cta__secondary-link {
    font-size: 1.4rem;
    font-weight: 500;
    color: rgb(255 255 255 / 0.85);
    text-decoration: underline;
    text-underline-offset: 0.4rem;
    transition: color var(--lusena-transition-med);
  }

  @media (hover: hover) {
    .lusena-returns-final-cta__secondary-link:hover {
      color: #fff;
      text-decoration: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Returns: Final CTA",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading line 1",
      "default": "Wypróbuj Przez"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading line 2 (italic)",
      "default": "60 Nocy"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Dołącz do tysięcy kobiet, które obudziły się piękniejsze. Bez ryzyka, bez zobowiązań - jedynie piękniejsze poranki."
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Kup Bez Ryzyka"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "Masz pytanie? Napisz do nas"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "LUSENA Returns: Final CTA"
    }
  ]
}
{% endschema %}
