{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-surface-1 lusena-returns-steps lusena-spacing--spacious"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container">
    <div class="lusena-text-center lusena-gap-section-intro lusena-content-flow--tight">
      <span class="lusena-type-caption lusena-kicker lusena-returns-steps__kicker{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.steps_kicker | escape }}
      </span>
      <h2 class="lusena-type-h1{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.steps_heading | escape }}
      </h2>
    </div>

    <div
      class="lusena-returns-steps__grid"
      {% if settings.animations_reveal_on_scroll %}
        data-cascade
      {% endif %}
    >
      <div class="lusena-returns-steps__connector" aria-hidden="true"><span></span></div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          {%- liquid
            assign icon_name = block.settings.icon | strip | downcase
            case icon_name
              when '🛒'
                assign icon_name = 'shopping-bag'
              when 'shopping-bag', 'shopping bag', 'shoppingbag'
                assign icon_name = 'shopping-bag'
              when '📧'
                assign icon_name = 'mail'
              when 'mail', 'email', 'envelope'
                assign icon_name = 'mail'
              when '💰'
                assign icon_name = 'banknote'
              when 'banknote', 'money'
                assign icon_name = 'banknote'
              else
                assign icon_name = 'shopping-bag'
            endcase
          -%}
          <div
            class="lusena-returns-steps__card-wrap{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
          >
            <div class="lusena-returns-steps__card lusena-content-flow--tight">
              <span class="lusena-returns-steps__step-label">
                {{ section.settings.step_label_prefix | escape }}
                {{ forloop.index }}
              </span>
              <div class="lusena-returns-steps__icon-circle">
                {% render 'lusena-icon', name: icon_name, class: 'lusena-returns-steps__step-icon', stroke_width: 1.5 %}
              </div>
              <h3 class="lusena-returns-steps__card-title">{{ block.settings.title | escape }}</h3>
              <p class="lusena-type-body">{{ block.settings.text | escape }}</p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  /* Grid: 1 col → 3 col at 768px */
  .lusena-returns-steps__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--lusena-space-4);
    position: relative;
  }

  @media (min-width: 768px) {
    .lusena-returns-steps__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Card wrap — equal height */
  .lusena-returns-steps__card-wrap {
    position: relative;
    z-index: 10;
    height: 100%;
  }

  /* Card styling */
  .lusena-returns-steps__card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--lusena-space-4);
    text-align: center;
    background-color: var(--lusena-color-n50);
    border-radius: var(--lusena-radius-sm);
    transition: transform var(--lusena-transition-med);
  }

  @media (hover: hover) and (pointer: fine) {
    .lusena-returns-steps__card:hover {
      transform: translateY(-0.4rem);
    }
  }

  /* Step label — gold kicker style */
  .lusena-returns-steps .lusena-returns-steps__step-label {
    font-size: 1.2rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--lusena-accent-2);
  }

  /* Icon circle */
  .lusena-returns-steps__icon-circle {
    width: 6.4rem;
    height: 6.4rem;
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background-color: var(--lusena-color-n0);
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.06);
    color: var(--lusena-accent-cta);
  }

  .lusena-returns-steps__step-icon {
    width: 2.8rem;
    height: 2.8rem;
  }

  /* Card title */
  .lusena-returns-steps__card-title {
    font-family: var(--lusena-font-brand);
    font-size: 2rem;
    line-height: 2.4rem;
    color: var(--lusena-text-1);
  }

  /* Kicker color — 0-2-0 */
  .lusena-returns-steps .lusena-returns-steps__kicker {
    color: var(--lusena-accent-2);
  }

  /* Connector dashed line (desktop only) */
  .lusena-returns-steps__connector {
    display: none;
    position: absolute;
    top: 4rem;
    left: 20%;
    right: 20%;
    pointer-events: none;
    z-index: 0;
  }

  .lusena-returns-steps__connector span {
    display: block;
    height: 0;
    border-top: 1px dashed rgb(74 74 74 / 0.2);
  }

  @media (min-width: 768px) {
    .lusena-returns-steps__connector {
      display: block;
    }
  }
{% endstylesheet %}

{% schema %}
