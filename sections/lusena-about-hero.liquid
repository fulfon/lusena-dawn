{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-brand lusena-about-hero lusena-spacing--hero lusena-spacing--snug-top"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container lusena-split">
    <div class="lusena-content-flow{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}>
      <div class="lusena-content-flow--tight">
        <span class="lusena-kicker lusena-about-hero__kicker">
          {{ section.settings.hero_kicker | escape }}
        </span>
        <h1 class="lusena-type-hero">
          {{ section.settings.hero_heading_line_1 | escape }}<br>
          <span class="lusena-about-hero__heading-line2">{{ section.settings.hero_heading_line_2 | escape }}</span>
        </h1>
      </div>
      <div class="lusena-type-body lusena-content-flow">
        {{ section.settings.hero_body }}
      </div>
      {%- if section.settings.hero_cta_label != blank and section.settings.hero_cta_link != blank -%}
        <div class="lusena-gap-cta-top">
          <a href="{{ section.settings.hero_cta_link }}" class="lusena-btn lusena-btn--primary lusena-btn--size-default">
            {{ section.settings.hero_cta_label | escape }}
          </a>
        </div>
      {%- endif -%}
    </div>

    <div class="lusena-about-hero__image-wrap{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}>
      {%- if section.settings.hero_image != blank -%}
        {{
          section.settings.hero_image
          | image_url: width: 1600
          | image_tag:
            class: 'lusena-about-hero__image',
            loading: 'lazy',
            widths: '600, 900, 1200, 1600',
            sizes: '(min-width: 768px) 45vw, 90vw'
        }}
      {%- else -%}
        <span class="lusena-about-hero__placeholder">
          {{ section.settings.hero_image_placeholder | escape }}
        </span>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  /* Kicker color - 0-2-0 for safety */
  .lusena-about-hero .lusena-about-hero__kicker {
    color: var(--lusena-accent-2);
  }

  /* Heading line 2 - italic, muted */
  .lusena-about-hero__heading-line2 {
    font-style: italic;
    color: var(--lusena-text-2);
    opacity: 0.6;
  }

  /* Image container */
  .lusena-about-hero__image-wrap {
    position: relative;
    height: 60rem;
    width: 100%;
    background-color: var(--lusena-color-n100);
    border-radius: var(--lusena-radius-sm);
    overflow: hidden;
  }

  /* Image fill */
  .lusena-about-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Mobile: shorter image */
  @media (max-width: 767px) {
    .lusena-about-hero__image-wrap {
      height: 40rem;
    }
  }

  /* Placeholder text */
  .lusena-about-hero__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--lusena-color-n400);
    font-weight: 300;
    font-style: italic;
  }
{% endstylesheet %}

