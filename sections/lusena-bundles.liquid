{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-surface-2 lusena-bundles lusena-spacing--spacious"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container lusena-split lusena-bundles__split">
    <div class="lusena-bundles__image-col{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            class: 'lusena-bundles__image',
            widths: '600, 800, 1000, 1400',
            sizes: '(min-width: 768px) 45vw, 90vw',
            loading: 'lazy'
        }}
      {%- else -%}
        <div class="lusena-bundles__placeholder">
          {{ section.settings.image_placeholder | escape }}
        </div>
      {%- endif -%}
    </div>

    <div class="lusena-bundles__content{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div class="lusena-content-flow--tight lusena-gap-section-intro">
        {%- if section.settings.kicker != blank -%}
          <span class="lusena-type-caption lusena-kicker">
            {{ section.settings.kicker | escape }}
          </span>
        {%- endif -%}

        <h2 class="lusena-type-h1">
          {{ section.settings.heading | newline_to_br }}
        </h2>
      </div>

      {%- if section.settings.body != blank -%}
        <p class="lusena-type-body lusena-gap-body">
          {{ section.settings.body | escape }}
        </p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="lusena-content-flow--tight lusena-gap-cta">
          {%- for block in section.blocks -%}
            <li class="lusena-bundles__benefit" {{ block.shopify_attributes }}>
              <span class="lusena-bundles__bullet"></span>
              {{ block.settings.text | escape }}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <a
          href="{{ section.settings.button_link }}"
          class="lusena-bundles__button"
        >
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  /* Foundations handles: .lusena-split (flex col → row, gap space-4 → space-8),
     .lusena-type-caption .lusena-kicker, .lusena-type-h1, .lusena-type-body. */

  /* Mobile order: content first, image second; desktop: image left, content right */
  .lusena-bundles__image-col {
    order: 2;
  }

  .lusena-bundles__content {
    order: 1;
  }

  @media (min-width: 768px) {
    .lusena-bundles__image-col { order: 1; }
    .lusena-bundles__content { order: 2; }
  }

  /* Image (editorial: flat, no rotation/shadow/frame) */
  .lusena-bundles__image-col {
    overflow: hidden;
  }

  .lusena-bundles__image {
    width: 100%;
    height: auto;
    display: block;
  }

  .lusena-bundles__placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--lusena-surface-2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--lusena-text-2);
    font-size: 1.4rem;
  }

  /* Benefit list items */
  .lusena-bundles__benefit {
    display: flex;
    align-items: center;
    gap: var(--lusena-space-2);
    color: var(--lusena-text-2);
  }

  .lusena-bundles__bullet {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: var(--lusena-accent-2);
    flex-shrink: 0;
  }

  /* CTA button (editorial: no border-radius) */
  .lusena-bundles__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    font-family: var(--lusena-font-ui);
    font-size: 1.6rem;
    font-weight: 500;
    height: var(--lusena-space-6);
    padding: 0 var(--lusena-space-5);
    background: var(--lusena-accent-cta);
    color: var(--lusena-color-n0);
    border: none;
    border-radius: var(--lusena-btn-radius);
    text-decoration: none;
    transition: background var(--lusena-transition-fast);
  }

  .lusena-bundles__button:hover {
    background: var(--lusena-accent-cta-hover);
  }

  .lusena-bundles__button:focus-visible {
    outline: 2px solid var(--lusena-accent-cta);
    outline-offset: 2px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Gift",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Gift Ready"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "The Perfect Gift,\nWrapped in Luxury."
    },
    {
      "type": "text",
      "id": "body",
      "label": "Body",
      "default": "Every LUSENA order arrives in our signature premium box. Perfect for birthdays, holidays, or a treat for yourself."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_placeholder",
      "label": "Image placeholder text",
      "default": "Gift box image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Gift Sets"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Save up to 20% on sets"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LUSENA Gift",
      "settings": {
        "button_link": "shopify://collections/all"
      },
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "text": "Save up to 20% on sets"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "text": "Signature gift box included"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "text": "Free shipping on bundles"
          }
        }
      ]
    }
  ]
}
{% endschema %}
