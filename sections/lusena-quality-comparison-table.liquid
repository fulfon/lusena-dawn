{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="bg-brand-bg lusena-quality-comparison-table lusena-spacing--standard"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="container">
    <div class="text-center lusena-gap-section-intro lusena-content-flow--tight{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <h2 class="text-3xl md:text-4xl font-serif text-primary">
        {{ section.settings.heading | escape }}
      </h2>
      {%- if section.settings.subheading != blank -%}
        <p class="text-secondary max-w-2xl mx-auto">
          {{ section.settings.subheading | escape }}
        </p>
      {%- endif -%}
    </div>

    <div class="lusena-quality-comparison-table__desktop{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div class="overflow-x-auto border border-secondary/10 bg-white rounded-sm">
        <table class="w-full text-left" aria-label="{{ section.settings.heading | escape }}">
          <thead class="bg-surface-2">
            <tr>
              <th class="p-4 text-xs uppercase tracking-wider text-secondary font-semibold" scope="col">
                {{ section.settings.metric_label | escape }}
              </th>
              <th class="p-4 text-xs uppercase tracking-wider text-secondary font-semibold" scope="col">
                {{ section.settings.lusena_label | escape }}
              </th>
              <th class="p-4 text-xs uppercase tracking-wider text-secondary font-semibold" scope="col">
                {{ section.settings.marketplace_label | escape }}
              </th>
              <th class="p-4 text-xs uppercase tracking-wider text-secondary font-semibold" scope="col">
                {{ section.settings.premium_label | escape }}
              </th>
            </tr>
          </thead>
          <tbody{% if settings.animations_reveal_on_scroll %} data-cascade{% endif %}>
            {%- for block in section.blocks -%}
              {%- if block.type == 'row' -%}
                <tr class="border-t border-secondary/10{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }}>
                  <th class="p-4 font-medium text-primary align-top" scope="row">
                    {{ block.settings.metric | escape }}
                  </th>
                  <td class="p-4 text-secondary align-top">
                    {{ block.settings.lusena_value | escape }}
                  </td>
                  <td class="p-4 text-secondary align-top">
                    {{ block.settings.marketplace_value | escape }}
                  </td>
                  <td class="p-4 text-secondary align-top">
                    {{ block.settings.premium_value | escape }}
                  </td>
                </tr>
              {%- endif -%}
            {%- endfor -%}
          </tbody>
        </table>
      </div>
    </div>

    <div class="lusena-quality-comparison-table__mobile grid grid-cols-1 gap-3"{% if settings.animations_reveal_on_scroll %} data-cascade{% endif %}>
      {%- for block in section.blocks -%}
        {%- if block.type == 'row' -%}
          <article class="bg-white border border-secondary/10 rounded-sm p-5{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }}>
            <h3 class="font-serif text-lg text-primary mb-4">
              {{ block.settings.metric | escape }}
            </h3>
            <div class="grid grid-cols-1 gap-3 text-sm">
              <div class="p-3 rounded-sm bg-surface-2">
                <div class="text-[11px] uppercase tracking-wider font-semibold text-accent-cta">
                  {{ section.settings.lusena_label | escape }}
                </div>
                <div class="mt-1 text-secondary">
                  {{ block.settings.lusena_value | escape }}
                </div>
              </div>
              <div class="p-3 rounded-sm bg-neutral-50">
                <div class="text-[11px] uppercase tracking-wider font-semibold text-secondary">
                  {{ section.settings.marketplace_label | escape }}
                </div>
                <div class="mt-1 text-secondary">
                  {{ block.settings.marketplace_value | escape }}
                </div>
              </div>
              <div class="p-3 rounded-sm bg-neutral-50">
                <div class="text-[11px] uppercase tracking-wider font-semibold text-secondary">
                  {{ section.settings.premium_label | escape }}
                </div>
                <div class="mt-1 text-secondary">
                  {{ block.settings.premium_value | escape }}
                </div>
              </div>
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- assign footer_note = section.settings.footer_note | strip -%}
    {%- if footer_note != blank -%}
      <p class="text-xs text-secondary mt-4 max-w-3xl mx-auto text-center{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ footer_note | escape }}
      </p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .lusena-quality-comparison-table__desktop {
    display: none;
  }

  @media (min-width: 1024px) {
    .lusena-quality-comparison-table__desktop {
      display: block;
    }

    .lusena-quality-comparison-table__mobile {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Quality: Compare",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tabela porównawcza"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Nie prosimy o wiarę. Pokazujemy parametry."
    },
    {
      "type": "text",
      "id": "metric_label",
      "label": "Column label: metric",
      "default": "Parametr"
    },
    {
      "type": "text",
      "id": "lusena_label",
      "label": "Column label: LUSENA",
      "default": "LUSENA"
    },
    {
      "type": "text",
      "id": "marketplace_label",
      "label": "Column label: marketplace",
      "default": "Typowa oferta z marketplace"
    },
    {
      "type": "text",
      "id": "premium_label",
      "label": "Column label: premium",
      "default": "Marka premium importowana"
    },
    {
      "type": "textarea",
      "id": "footer_note",
      "label": "Footer note"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        {
          "type": "text",
          "id": "metric",
          "label": "Metric",
          "default": "Materiał"
        },
        {
          "type": "text",
          "id": "lusena_value",
          "label": "LUSENA value",
          "default": "100% jedwab morwowy"
        },
        {
          "type": "text",
          "id": "marketplace_value",
          "label": "Marketplace value",
          "default": "Satyna poliestrowa / mieszanka"
        },
        {
          "type": "text",
          "id": "premium_value",
          "label": "Premium import value",
          "default": "100% jedwab morwowy"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LUSENA Quality: Compare",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "metric": "Materiał",
            "lusena_value": "100% jedwab morwowy",
            "marketplace_value": "Satyna poliestrowa / mieszanka",
            "premium_value": "100% jedwab morwowy"
          }
        },
        {
          "type": "row",
          "settings": {
            "metric": "Gramatura",
            "lusena_value": "22 momme",
            "marketplace_value": "Brak danych / 16 momme",
            "premium_value": "19–22 momme"
          }
        },
        {
          "type": "row",
          "settings": {
            "metric": "Certyfikat",
            "lusena_value": "OEKO-TEX Standard 100",
            "marketplace_value": "Brak",
            "premium_value": "Czasami"
          }
        },
        {
          "type": "row",
          "settings": {
            "metric": "Wysyłka",
            "lusena_value": "24h z Polski",
            "marketplace_value": "14–30 dni",
            "premium_value": "5–7 dni"
          }
        },
        {
          "type": "row",
          "settings": {
            "metric": "Gwarancja",
            "lusena_value": "60 dni testu",
            "marketplace_value": "14 dni (prawo)",
            "premium_value": "14–30 dni"
          }
        },
        {
          "type": "row",
          "settings": {
            "metric": "Cena",
            "lusena_value": "249 zł",
            "marketplace_value": "49–79 zł",
            "premium_value": "400–600 zł"
          }
        }
      ]
    }
  ]
}
{% endschema %}
