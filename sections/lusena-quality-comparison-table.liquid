{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-surface-1 lusena-quality-comparison-table lusena-spacing--standard"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container--narrow lusena-text-center lusena-content-flow--tight lusena-gap-section-intro{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    <h2 class="lusena-type-h1">
      {{ section.settings.heading | escape }}
    </h2>
    {%- if section.settings.subheading != blank -%}
      <p class="lusena-type-body">
        {{ section.settings.subheading | escape }}
      </p>
    {%- endif -%}
  </div>

  <div class="lusena-container--narrow">
    {%- comment -%} Desktop table (visible ≥1024px) {%- endcomment -%}
    <div class="lusena-truth-table__table-wrap{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <table class="lusena-truth-table__table" aria-label="{{ section.settings.heading | escape }}">
        <thead>
          <tr>
            <th scope="col">{{ section.settings.metric_label | default: 'Porównanie' | escape }}</th>
            <th scope="col">{{ section.settings.lusena_label | escape }}</th>
            <th scope="col">{{ section.settings.others_label | escape }}</th>
          </tr>
        </thead>
        <tbody{% if settings.animations_reveal_on_scroll %} data-cascade{% endif %}>
          {%- for block in section.blocks -%}
            {%- if block.type == 'row' -%}
              <tr class="{% if settings.animations_reveal_on_scroll %}scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }}>
                <th scope="row">{{ block.settings.metric | escape }}</th>
                <td>
                  <span class="lusena-truth-table__value lusena-truth-table__value--lusena">
                    {% render 'lusena-icon', name: 'circle-check', class: 'lusena-truth-table__icon', stroke_width: 2 %}
                    <span>{{ block.settings.lusena_value | escape }}</span>
                  </span>
                </td>
                <td>
                  <span class="lusena-truth-table__value lusena-truth-table__value--others">
                    {% render 'lusena-icon', name: 'circle-x', class: 'lusena-truth-table__icon', stroke_width: 2 %}
                    <span>{{ block.settings.others_value | escape }}</span>
                  </span>
                </td>
              </tr>
            {%- endif -%}
          {%- endfor -%}
        </tbody>
      </table>
    </div>

    {%- comment -%} Mobile cards (visible <1024px) {%- endcomment -%}
    <div class="lusena-truth-table__cards"{% if settings.animations_reveal_on_scroll %} data-cascade{% endif %}>
      {%- for block in section.blocks -%}
        {%- if block.type == 'row' -%}
          <article class="lusena-truth-table__card{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }}>
            <h3 class="lusena-truth-table__card-metric">{{ block.settings.metric | escape }}</h3>
            <div class="lusena-truth-table__card-line lusena-truth-table__card-line--lusena">
              <span class="lusena-truth-table__card-label lusena-truth-table__card-label--lusena">{{ section.settings.lusena_label | escape }}</span>
              <span class="lusena-truth-table__value lusena-truth-table__value--lusena">
                {% render 'lusena-icon', name: 'circle-check', class: 'lusena-truth-table__icon', stroke_width: 2 %}
                <span>{{ block.settings.lusena_value | escape }}</span>
              </span>
            </div>
            <div class="lusena-truth-table__card-line">
              <span class="lusena-truth-table__card-label">{{ section.settings.others_label | escape }}</span>
              <span class="lusena-truth-table__value lusena-truth-table__value--others">
                {% render 'lusena-icon', name: 'circle-x', class: 'lusena-truth-table__icon', stroke_width: 2 %}
                <span>{{ block.settings.others_value | escape }}</span>
              </span>
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- assign footer_note = section.settings.footer_note | strip -%}
    {%- if footer_note != blank -%}
      <p class="lusena-truth-table__note{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ footer_note | escape }}
      </p>
    {%- endif -%}

    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <div class="lusena-text-center lusena-gap-cta-top{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <a href="{{ section.settings.cta_link }}" class="lusena-btn lusena-btn--primary lusena-btn--size-default">
          {{ section.settings.cta_label | escape }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "LUSENA Quality: Compare",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Nie prosimy o wiarę"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Pokazujemy parametry."
    },
    {
      "type": "text",
      "id": "metric_label",
      "label": "Column label: Metric",
      "default": "Porównanie"
    },
    {
      "type": "text",
      "id": "lusena_label",
      "label": "Column label: LUSENA",
      "default": "LUSENA"
    },
    {
      "type": "text",
      "id": "others_label",
      "label": "Column label: Others",
      "default": "Typowe oferty"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Zobacz kolekcję"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link",
      "default": "/collections/all"
    },
    {
      "type": "textarea",
      "id": "footer_note",
      "label": "Footer note"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Row",
      "settings": [
        {
          "type": "text",
          "id": "metric",
          "label": "Metric",
          "default": "Materiał"
        },
        {
          "type": "text",
          "id": "lusena_value",
          "label": "LUSENA value",
          "default": "100% jedwab morwowy"
        },
        {
          "type": "text",
          "id": "others_value",
          "label": "Others value",
          "default": "Satyna poliestrowa lub mieszanka"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LUSENA Quality: Compare",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "metric": "Materiał",
            "lusena_value": "100% jedwab morwowy",
            "others_value": "Satyna poliestrowa lub mieszanka"
          }
        },
        {
          "type": "row",
          "settings": {
            "metric": "Gramatura",
            "lusena_value": "22 momme - gęstszy i trwalszy splot",
            "others_value": "16-19 momme lub brak danych"
          }
        },
        {
          "type": "row",
          "settings": {
            "metric": "Klasa włókna",
            "lusena_value": "6A - najwyższa klasyfikacja",
            "others_value": "Nieokreślona"
          }
        },
        {
          "type": "row",
          "settings": {
            "metric": "Certyfikat",
            "lusena_value": "OEKO-TEX® Standard 100",
            "others_value": "Brak lub nieokreślony"
          }
        },
        {
          "type": "row",
          "settings": {
            "metric": "Magazyn i wysyłka",
            "lusena_value": "Polska - wysyłka 24h",
            "others_value": "Import 14-30 dni"
          }
        },
        {
          "type": "row",
          "settings": {
            "metric": "Gwarancja",
            "lusena_value": "60 dni testu, nawet po użyciu",
            "others_value": "14 dni (prawo konsumenta)"
          }
        }
      ]
    }
  ]
}
{% endschema %}
