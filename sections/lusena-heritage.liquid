{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-surface-2 lusena-heritage lusena-spacing--spacious"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container">
    {%- comment -%} Section heading {%- endcomment -%}
    {%- if section.settings.heading != blank -%}
      <div class="lusena-text-center lusena-gap-section-intro{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <h2 class="lusena-type-h1">
          {{ section.settings.heading | escape }}
        </h2>
      </div>
    {%- endif -%}

    {%- comment -%} 3-tile evidence grid {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div
        class="lusena-grid lusena-grid--3"
        {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}
      >
        {%- for block in section.blocks -%}
          <div
            class="lusena-content-card lusena-heritage__tile{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank -%}
              <div class="lusena-heritage__tile-image">
                {{ block.settings.image | image_url: width: 600 | image_tag:
                  loading: 'lazy',
                  class: 'lusena-heritage__tile-img',
                  widths: '300, 400, 600',
                  sizes: '(min-width: 768px) 33vw, 100vw'
                }}
              </div>
            {%- else -%}
              <div class="lusena-icon-circle lusena-heritage__icon-circle">
                {%- if block.settings.icon != blank -%}
                  {% render 'lusena-icon', name: block.settings.icon, class: 'lusena-heritage__icon-svg', stroke_width: 1.5 %}
                {%- endif -%}
              </div>
            {%- endif -%}
            <div class="lusena-heritage__tile-text">
              {%- if block.settings.title != blank -%}
                <h3 class="lusena-type-h2">{{ block.settings.title | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.subtitle != blank -%}
                <p class="lusena-type-caption">{{ block.settings.subtitle | escape }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} CTA button {%- endcomment -%}
    {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
      <div class="lusena-text-center lusena-gap-cta-top{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <a
          href="{{ section.settings.button_link }}"
          class="lusena-heritage__button"
        >
          {{ section.settings.button_label | escape }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  /* Foundations handles: .lusena-content-card (top border, transparent bg, no shadow),
     .lusena-grid / .lusena-grid--3, .lusena-icon-circle, .lusena-type-h1/h2/caption. */

  .lusena-heritage {
    overflow: hidden;
    position: relative;
  }

  /* Tile layout: editorial left-aligned column */
  .lusena-heritage__tile {
    display: flex;
    flex-direction: column;
    gap: var(--lusena-space-2);
  }

  /* Image variant (no border-radius — editorial) */
  .lusena-heritage__tile-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .lusena-heritage__tile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Icon circle accent color override */
  .lusena-heritage__icon-circle {
    color: var(--lusena-accent-cta);
  }

  .lusena-heritage__icon-svg {
    width: 2.4rem;
    height: 2.4rem;
  }

  /* Text stack */
  .lusena-heritage__tile-text {
    display: flex;
    flex-direction: column;
    gap: var(--lusena-space-1);
  }

  /* Ghost button */
  .lusena-heritage__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    font-size: 1.6rem;
    font-weight: 500;
    height: var(--lusena-space-6);
    padding: 0 var(--lusena-space-5);
    border: 1px solid var(--lusena-accent-cta);
    border-radius: var(--lusena-btn-radius);
    background: transparent;
    color: var(--lusena-accent-cta);
    text-decoration: none;
    transition: background-color var(--lusena-transition-fast);
  }

  .lusena-heritage__button:hover {
    background-color: rgba(14, 94, 90, 0.05);
  }

  .lusena-heritage__button:focus-visible {
    outline: 2px solid var(--lusena-accent-cta);
    outline-offset: 2px;
  }

  /* Center tiles on mobile (single column) */
  @media (max-width: 767px) {
    .lusena-heritage .lusena-heritage__tile {
      align-items: center;
      text-align: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Heritage",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
