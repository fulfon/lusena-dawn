{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-brand lusena-heritage lusena-spacing--spacious"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container">
    {%- comment -%} Section heading {%- endcomment -%}
    {%- if section.settings.heading != blank -%}
      <div class="lusena-text-center lusena-gap-section-intro{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <h2 class="lusena-heritage__heading">
          {{ section.settings.heading | escape }}
        </h2>
      </div>
    {%- endif -%}

    {%- comment -%} 3-tile evidence grid {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div
        class="lusena-heritage__grid"
        {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}
      >
        {%- for block in section.blocks -%}
          <div
            class="lusena-heritage__tile{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank -%}
              <div class="lusena-heritage__tile-image">
                {{ block.settings.image | image_url: width: 600 | image_tag:
                  loading: 'lazy',
                  class: 'lusena-heritage__tile-img',
                  widths: '300, 400, 600',
                  sizes: '(min-width: 768px) 33vw, 100vw'
                }}
              </div>
            {%- else -%}
              <div class="lusena-heritage__tile-icon">
                {%- if block.settings.icon != blank -%}
                  {% render 'lusena-icon', name: block.settings.icon, class: 'lusena-heritage__icon-svg', stroke_width: 1.5 %}
                {%- endif -%}
              </div>
            {%- endif -%}
            <div class="lusena-heritage__tile-text">
              {%- if block.settings.title != blank -%}
                <h3 class="lusena-heritage__tile-title">{{ block.settings.title | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.subtitle != blank -%}
                <p class="lusena-heritage__tile-subtitle">{{ block.settings.subtitle | escape }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} CTA button {%- endcomment -%}
    {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
      <div class="lusena-text-center lusena-gap-cta{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <a
          href="{{ section.settings.button_link }}"
          class="lusena-heritage__button"
        >
          {{ section.settings.button_label | escape }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .lusena-heritage {
    overflow: hidden;
    position: relative;
  }

  .lusena-heritage__heading {
    font-family: var(--lusena-font-brand);
    font-size: 3.0rem;
    line-height: 1.2;
    color: var(--lusena-text-1);
    text-wrap: balance;
    margin: 0;
  }

  @media (min-width: 768px) {
    .lusena-heritage__heading {
      font-size: 4.0rem;
    }
  }

  /* Heritage 3-tile grid */
  .lusena-heritage__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-top: 40px;
    margin-bottom: 40px;
  }

  @media (min-width: 768px) {
    .lusena-heritage__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
      margin-top: 48px;
      margin-bottom: 48px;
    }
  }

  /* Individual tile */
  .lusena-heritage__tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    padding: 32px 24px;
    background: var(--lusena-surface-1);
    border-radius: 12px;
    transition: box-shadow 0.2s ease;
  }

  .lusena-heritage__tile:hover {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }

  /* Image variant */
  .lusena-heritage__tile-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 8px;
    overflow: hidden;
  }

  .lusena-heritage__tile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Icon fallback variant */
  .lusena-heritage__tile-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 9999px;
    background: var(--lusena-brand-bg);
    color: var(--lusena-accent-cta);
    flex-shrink: 0;
  }

  .lusena-heritage__icon-svg {
    width: 28px;
    height: 28px;
  }

  /* Text */
  .lusena-heritage__tile-text {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .lusena-heritage__tile-title {
    font-size: 16px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--lusena-text-1);
    margin: 0;
  }

  .lusena-heritage__tile-subtitle {
    font-size: 14px;
    line-height: 1.5;
    color: var(--lusena-text-2);
    margin: 0;
  }

  .lusena-heritage__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    font-size: 1.6rem;
    font-weight: 500;
    height: 4.8rem;
    padding: 0 4.0rem;
    border: 1px solid var(--lusena-accent-cta);
    border-radius: 6px;
    background: transparent;
    color: var(--lusena-accent-cta);
    text-decoration: none;
    transition: background-color var(--lusena-transition-fast);
  }

  .lusena-heritage__button:hover {
    background-color: rgba(14, 94, 90, 0.05);
  }

  .lusena-heritage__button:focus-visible {
    outline: 2px solid var(--lusena-accent-cta);
    outline-offset: 2px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Heritage",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
