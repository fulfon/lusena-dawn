{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-surface-1 lusena-about-values lusena-spacing--standard"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container">
    <div class="lusena-text-center lusena-gap-section-intro lusena-content-flow--tight{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <span class="lusena-type-caption lusena-kicker lusena-about-values__kicker">
        {{ section.settings.values_kicker | escape }}
      </span>
      <h2 class="lusena-type-h1">
        {{ section.settings.values_heading | escape }}
      </h2>
    </div>

    <div class="lusena-about-values__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'value' -%}
          <div class="lusena-about-values__grid-item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}>
            <div class="lusena-about-values__card lusena-content-flow--tight" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                <div class="lusena-about-values__icon">
                  {% render 'lusena-icon', name: block.settings.icon, class: 'lusena-about-values__icon-svg', stroke_width: 1.5 %}
                </div>
              {%- endif -%}
              <h3 class="lusena-about-values__title">{{ block.settings.title | escape }}</h3>
              <p class="lusena-type-body">
                {{ block.settings.text | escape }}
              </p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  /* Responsive card grid: 1 col → 2 col (tablet) → 3 col (desktop), centered incomplete rows */
  .lusena-about-values__grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--lusena-space-4);
    justify-content: center;
  }

  .lusena-about-values__grid-item {
    width: 100%;
  }

  @media (min-width: 768px) {
    .lusena-about-values__grid-item {
      flex: 0 0 calc(50% - var(--lusena-space-4) / 2);
    }
  }

  @media (min-width: 1024px) {
    .lusena-about-values__grid-item {
      flex: 0 0 calc(33.333% - var(--lusena-space-4) * 2 / 3);
    }
  }

  /* Card styling */
  .lusena-about-values__card {
    height: 100%;
    padding: var(--lusena-space-4);
    background-color: var(--lusena-color-n50);
    border-radius: var(--lusena-radius-sm);
    transition: transform var(--lusena-transition-med);
  }

  @media (hover: hover) {
    .lusena-about-values__card:hover {
      transform: translateY(-0.4rem);
    }
  }

  /* Kicker color — 0-2-0 to beat foundations .lusena-type-caption */
  .lusena-about-values .lusena-about-values__kicker {
    color: var(--lusena-accent-2);
  }

  /* Icon */
  .lusena-about-values__icon {
    margin-bottom: var(--lusena-space-2);
    color: var(--lusena-accent-cta);
  }

  .lusena-about-values__icon-svg {
    width: 3.2rem;
    height: 3.2rem;
  }

  /* Card title */
  .lusena-about-values__title {
    font-family: var(--lusena-font-brand);
    font-size: 2.0rem;
    line-height: 2.4rem;
    color: var(--lusena-text-1);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA About: Values",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "values_kicker",
      "label": "Values kicker",
      "default": "Wartości"
    },
    {
      "type": "text",
      "id": "values_heading",
      "label": "Values heading",
      "default": "Czym się kierujemy?"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name",
          "info": "e.g. gem, handshake, leaf, hourglass, home-heart"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Jakość bez kompromisów"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Zawsze 22 momme. Zawsze klasa 6A. Nigdy \"jedwab satynowy\" (poliester)."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LUSENA About: Values",
      "blocks": [
        {
          "type": "value",
          "settings": {
            "icon": "gem",
            "title": "Jakość bez kompromisów",
            "text": "Zawsze 22 momme. Zawsze klasa 6A. Nigdy \"jedwab satynowy\" (poliester)."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "handshake",
            "title": "Szczerość",
            "text": "Nie obiecujemy, że jedwab cofnie zmarszczki o 10 lat. Obiecujemy, że przestanie je utrwalać każdej nocy."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "leaf",
            "title": "Prostota",
            "text": "Minimalistyczny design. Opakowania bez plastiku. Przejrzysta oferta."
          }
        },
        {
          "type": "value",
          "settings": {
            "icon": "home-heart",
            "title": "Lokalność",
            "text": "Jesteśmy stąd. Podatki płacimy w Polsce. Obsługa klienta mówi po polsku."
          }
        }
      ]
    }
  ]
}
{% endschema %}
