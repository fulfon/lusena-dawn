{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-surface-1 lusena-problem-solution lusena-spacing--spacious"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container">
    <div class="lusena-split-problem-solution{% if section.settings.cta_label != blank and section.settings.cta_link != blank %} lusena-gap-body{% endif %}">
      <div
        class="lusena-split__problem{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
      >
        <div class="lusena-content-flow--tight lusena-gap-section-intro">
          <span class="lusena-type-caption lusena-kicker lusena-problem-solution__kicker--problem">
            {{ section.settings.problem_label | escape }}
          </span>
          <h3 class="lusena-type-h1 lusena-problem-solution__headline--problem">
            {{ section.settings.problem_heading | newline_to_br }}
          </h3>
        </div>
        <div class="lusena-content-flow">
          {%- for block in section.blocks -%}
            {%- if block.type == 'problem_item' -%}
              <div class="lusena-problem-solution__item" {{ block.shopify_attributes }}>
                {% render 'lusena-icon', name: 'x', class: 'lusena-problem-solution__icon lusena-problem-solution__icon--problem', stroke_width: 1.5 %}
                <div>
                  <h4 class="lusena-type-h2 lusena-problem-solution__item-title">{{ block.settings.title | escape }}</h4>
                  <p class="lusena-type-body">{{ block.settings.text | escape }}</p>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <div
        class="lusena-split__solution{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
      >
        <div class="lusena-content-flow--tight lusena-gap-section-intro">
          <span class="lusena-type-caption lusena-kicker lusena-problem-solution__kicker--solution">
            {{ section.settings.solution_label | escape }}
          </span>
          <h3 class="lusena-type-h1">
            {{ section.settings.solution_heading | newline_to_br }}
          </h3>
        </div>
        <div class="lusena-content-flow">
          {%- for block in section.blocks -%}
            {%- if block.type == 'solution_item' -%}
              <div class="lusena-problem-solution__item" {{ block.shopify_attributes }}>
                {% render 'lusena-icon',
                  name: 'check',
                  class: 'lusena-problem-solution__icon lusena-problem-solution__icon--solution',
                  stroke_width: 1.5
                %}
                <div>
                  <h4 class="lusena-type-h2 lusena-problem-solution__item-title">{{ block.settings.title | escape }}</h4>
                  <p class="lusena-type-body">{{ block.settings.text | escape }}</p>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>

    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <div class="lusena-text-center lusena-gap-cta-top{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <a href="{{ section.settings.cta_link }}" class="lusena-problem-solution__cta">
          {{ section.settings.cta_label | escape }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  /* Foundations handles: .lusena-split-problem-solution (grid 1fr → 1fr 1fr, gap space-6 → space-12),
     .lusena-split__problem / .lusena-split__solution (2px red/green top borders + padding-top).
     Foundations handles: .lusena-type-caption .lusena-kicker, .lusena-type-h1, .lusena-type-h2, .lusena-type-body. */

  /* Kicker color variants */
  .lusena-problem-solution__kicker--problem {
    color: var(--lusena-text-2);
  }

  .lusena-problem-solution__kicker--solution {
    color: var(--lusena-accent-2);
  }

  /* Problem headline opacity */
  .lusena-problem-solution__headline--problem {
    opacity: 0.8;
  }

  /* Item layout (icon + text side by side) */
  .lusena-problem-solution__item {
    display: flex;
    gap: var(--lusena-space-4);
  }

  .lusena-problem-solution__icon {
    width: 2.0rem;
    height: 2.0rem;
    flex-shrink: 0;
    margin-top: var(--lusena-space-05);
  }

  .lusena-problem-solution__icon--problem {
    color: rgba(185, 28, 28, 0.4);
  }

  .lusena-problem-solution__icon--solution {
    color: rgba(47, 125, 78, 0.4);
  }

  /* Item title spacing below (foundations .lusena-type-h2 sets margin: 0) */
  .lusena-problem-solution__item-title {
    margin-bottom: var(--lusena-space-1);
  }

  /* Extra breathing room before CTA */
  .lusena-problem-solution .lusena-gap-cta-top {
    margin-top: var(--lusena-space-6);
  }

  /* CTA link */
  .lusena-problem-solution__cta {
    display: inline-flex;
    align-items: center;
    color: var(--lusena-accent-cta);
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid rgba(14, 94, 90, 0.3);
    padding-bottom: var(--lusena-space-05);
    transition: border-color var(--lusena-transition-fast);
  }

  .lusena-problem-solution__cta:hover {
    border-bottom-color: var(--lusena-accent-cta);
  }
{% endstylesheet %}

