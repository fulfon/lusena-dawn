<footer class="lusena-footer">
  <div class="lusena-container lusena-footer__grid">
    <div class="lusena-footer__col">
      <div class="lusena-footer__brand">{{ section.settings.brand_heading | escape }}</div>
      <div class="lusena-footer__brand-text">
        {{ section.settings.brand_text }}
      </div>
    </div>

    <div>
      <h4 class="lusena-footer__heading">{{ section.settings.shop_heading | escape }}</h4>
      {%- if section.settings.shop_menu != blank -%}
        <ul class="lusena-footer__menu">
          {%- for link in section.settings.shop_menu.links -%}
            <li>
              <a href="{{ link.url }}" class="lusena-footer__link">{{ link.title | escape }}</a>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <div>
      <h4 class="lusena-footer__heading">{{ section.settings.help_heading | escape }}</h4>
      {%- if section.settings.help_menu != blank -%}
        <ul class="lusena-footer__menu">
          {%- for link in section.settings.help_menu.links -%}
            <li>
              <a href="{{ link.url }}" class="lusena-footer__link">{{ link.title | escape }}</a>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <div>
      <h4 class="lusena-footer__heading">{{ section.settings.newsletter_heading | escape }}</h4>
      <div class="lusena-footer__newsletter">
        <p class="lusena-footer__newsletter-text">{{ section.settings.newsletter_text | escape }}</p>
        {%- form 'customer', id: 'LusenaFooterNewsletter', class: 'lusena-footer__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label class="lusena-visually-hidden" for="LusenaFooterNewsletterEmail">{{ 'newsletter.label' | t }}</label>
          <input
            id="LusenaFooterNewsletterEmail"
            type="email"
            name="contact[email]"
            autocomplete="email"
            placeholder="{{ 'newsletter.label' | t }}"
            class="lusena-footer__input"
            required
          >
          <button type="submit" class="lusena-visually-hidden">{{ section.settings.newsletter_button_label | escape }}</button>
        {%- endform -%}
      </div>
    </div>
  </div>

  <div class="lusena-container lusena-footer__bottom">
    © {{ 'now' | date: '%Y' }}
    {{ section.settings.brand_heading | escape }}. All rights reserved.
  </div>
</footer>

{% stylesheet %}
  /* CSS moved to assets/lusena-footer.css (standalone asset) to avoid compiled_assets truncation. */
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA footer (draft)",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "text",
      "id": "brand_heading",
      "label": "Brand heading",
      "default": "LUSENA"
    },
    {
      "type": "richtext",
      "id": "brand_text",
      "label": "Brand text",
      "default": "<p>22 momme silk from Suzhou. Certified OEKO-TEX 100.<br>Sleep better, wake up beautiful.</p>"
    },
    {
      "type": "header",
      "content": "Menus"
    },
    {
      "type": "text",
      "id": "shop_heading",
      "label": "Shop heading",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "Shop menu"
    },
    {
      "type": "text",
      "id": "help_heading",
      "label": "Help heading",
      "default": "Help"
    },
    {
      "type": "link_list",
      "id": "help_menu",
      "label": "Help menu"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter text",
      "default": "Join the circle for early access and care tips."
    },
    {
      "type": "text",
      "id": "newsletter_button_label",
      "label": "Newsletter button label",
      "default": "Sign up"
    }
  ],
  "presets": [
    {
      "name": "LUSENA footer (draft)"
    }
  ]
}
{% endschema %}
