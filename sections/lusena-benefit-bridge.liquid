{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-brand lusena-benefit-bridge lusena-spacing--standard"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container">
    {%- if section.settings.kicker != blank or section.settings.heading != blank -%}
      <div class="lusena-text-center lusena-gap-section-intro{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {%- if section.settings.kicker != blank -%}
          <p class="lusena-type-caption lusena-benefit-bridge__kicker">{{ section.settings.kicker | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="lusena-type-h1">
            {{ section.settings.heading | escape }}
          </h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div
        class="lusena-benefit-bridge__cards"
        {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}
      >
        {%- for block in section.blocks -%}
          {%- liquid
            assign is_featured = false
            if forloop.first
              assign is_featured = true
            endif
          -%}
          <div
            class="lusena-benefit-bridge__card{% if is_featured %} lusena-benefit-bridge__card--featured{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
          >
            <div class="lusena-benefit-bridge__accent-bar"></div>

            {%- if block.settings.icon != blank -%}
              <div class="lusena-icon-circle lusena-benefit-bridge__icon-circle">
                {% render 'lusena-icon', name: block.settings.icon, class: 'lusena-icon-lg', stroke_width: 1.5 %}
              </div>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="lusena-type-h2">
                {{ block.settings.title | escape }}
              </h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="lusena-type-body">
                {{ block.settings.text | escape }}
              </p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.transition_text != blank -%}
      <p class="lusena-type-body lusena-benefit-bridge__transition{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.transition_text | escape }}
      </p>
    {%- endif -%}
  </div>
</section>

{{ 'lusena-benefit-bridge.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "LUSENA Benefit Bridge",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (above heading)",
      "default": "Jedwab morwowy 22 momme"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Co zobaczysz rano?"
    },
    {
      "type": "text",
      "id": "transition_text",
      "label": "Transition sentence (italic, below cards)",
      "default": "Wszystkie trzy - bez żadnej zmiany w rutynie."
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Benefit card",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon name",
          "default": "sparkles",
          "info": "Available: sparkles, wind, droplets, heart, moon, feather, palette, clock, star, layers, shield-check"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title (max 28 chars)",
          "default": "Benefit title"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description (1-2 sentences)",
          "default": "Benefit description."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LUSENA Benefit Bridge",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "icon": "sparkles",
            "title": "Skóra bez śladów nocy",
            "text": "Rano widzisz w lustrze twarz wypoczętą - nie twarz, która dopiero musi się obudzić. Jedwab jest gładki - nie zagniata skóry tak jak bawełna."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "wind",
            "title": "Włosy bez porannego chaosu",
            "text": "Gładki jedwab nie czepia się włosów podczas snu - mniej puszenia, plątania i łamania delikatnych pasm."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "droplets",
            "title": "Krem pracuje całą noc",
            "text": "Kosmetyki kupujesz dla skóry, nie dla pościeli. Jedwab wchłania je wolniej niż bawełna - krem zostaje tam, gdzie powinien."
          }
        }
      ]
    }
  ]
}
{% endschema %}
