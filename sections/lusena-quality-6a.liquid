{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-surface-1 lusena-quality-6a lusena-spacing--standard"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container lusena-split">
    <div class="lusena-quality-6a__image-wrap{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}>
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            class: 'lusena-quality-6a__image',
            loading: 'lazy',
            widths: '600, 900, 1200, 1400',
            sizes: '(min-width: 768px) 45vw, 90vw'
        }}
      {%- else -%}
        <span class="lusena-quality-6a__placeholder">
          {{ section.settings.image_placeholder | escape }}
        </span>
      {%- endif -%}
    </div>

    <div class="lusena-content-flow{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}>
      <div class="lusena-content-flow--tight">
        {%- if section.settings.kicker != blank -%}
          <span class="lusena-type-caption lusena-kicker lusena-quality-6a__kicker">
            {{ section.settings.kicker | escape }}
          </span>
        {%- endif -%}
        <h2 class="lusena-type-h1">
          {{ section.settings.heading | escape }}
        </h2>
      </div>

      <div class="lusena-content-flow--tight lusena-type-body">
        {{ section.settings.body }}
      </div>

      {%- if section.blocks.size > 0 -%}
        <ul class="lusena-content-flow--tight">
          {%- for block in section.blocks -%}
            {%- if block.type == 'benefit' -%}
              <li class="lusena-quality-6a__bullet" {{ block.shopify_attributes }}>
                <span class="lusena-quality-6a__bullet-dot" aria-hidden="true"></span>
                <span class="lusena-quality-6a__bullet-text">{{ block.settings.text | escape }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  /* Kicker color */
  .lusena-quality-6a .lusena-quality-6a__kicker {
    color: var(--lusena-accent-2);
  }

  /* Image wrap */
  .lusena-quality-6a__image-wrap {
    aspect-ratio: 1;
    background-color: var(--lusena-color-n100);
    border-radius: 0.2rem;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lusena-quality-6a__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lusena-quality-6a__placeholder {
    color: var(--lusena-color-n400);
    font-weight: 300;
    font-style: italic;
    text-align: center;
    padding-inline: var(--lusena-space-3);
  }

  /* Gold bullet list */
  .lusena-quality-6a__bullet {
    display: flex;
    flex-wrap: nowrap;
    align-items: flex-start;
    gap: 0.8rem;
    list-style: none;
  }

  .lusena-quality-6a__bullet-dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background-color: var(--lusena-accent-2);
    flex-shrink: 0;
    margin-top: calc((1.625em - 0.6rem) / 2);
  }

  .lusena-quality-6a__bullet-text {
    min-width: 0;
    flex: 1;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Quality: 6A",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Klasa jedwabiu"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Klasa 6A"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Klasa 6A to najwyższa klasyfikacja jedwabiu morwowego. Oznacza dłuższe, bardziej jednorodne włókna oraz stabilną jakość partii.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Infographic / image"
    },
    {
      "type": "text",
      "id": "image_placeholder",
      "label": "Image placeholder",
      "default": "Infografika: skala klas jedwabiu (3A → 6A)"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Wyższa selekcja włókien i powtarzalna jakość."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LUSENA Quality: 6A",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "text": "Dłuższe, bardziej jednorodne włókna."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "text": "Stabilna jakość partii i wykończenia."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "text": "Delikatny połysk i gładkość w dotyku."
          }
        }
      ]
    }
  ]
}
{% endschema %}
