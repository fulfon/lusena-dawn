{%- liquid
  assign shipping_info = 'Wysyłamy z naszego magazynu w Polsce. Zamówienia złożone do godziny 14:00 wysyłamy jeszcze tego samego dnia. Dostawa InPost/kurier zajmuje zazwyczaj 1–2 dni robocze. Darmowa dostawa od 199 zł.'
  assign returns_info = '60 dni na zwrot — nawet używanego produktu. Prosty formularz online, darmowy zwrot InPost.'
  assign guarantee_info = 'Przetestuj przez 60 nocy. Jeśli nie poczujesz różnicy, zwróć i otrzymaj pełny zwrot. Bez pytań.'

  if product != blank
    assign mf_shipping_info = product.metafields.lusena.pdp_shipping_info
    if mf_shipping_info != blank and mf_shipping_info.value != blank
      assign shipping_info = mf_shipping_info.value
    endif

    assign mf_returns_info = product.metafields.lusena.pdp_returns_info
    if mf_returns_info != blank and mf_returns_info.value != blank
      assign returns_info = mf_returns_info.value
    endif

    assign mf_guarantee_info = product.metafields.lusena.pdp_guarantee_info
    if mf_guarantee_info != blank and mf_guarantee_info.value != blank
      assign guarantee_info = mf_guarantee_info.value
    endif
  endif
-%}

{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  id="details"
  class="lusena-pdp-details border-t border-brand-bg lusena-spacing--compact"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="container">
    <h2 class="lusena-pdp-details__heading text-primary text-center lusena-gap-section-intro{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      Szczegóły i pytania
    </h2>

    <div class="max-w-3xl mx-auto">
      <div
        class="w-full lusena-pdp-accordion"
        data-lusena-accordion-root
        data-lusena-accordion-single
        data-lusena-accordion-collapsible
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        <div
          class="lusena-pdp-accordion__item border-b border-secondary/20{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          data-lusena-accordion-item
          data-lusena-accordion-value="shipping"
        >
          <div class="flex">
            <button
              type="button"
              class="lusena-pdp-accordion__trigger flex flex-1 items-center justify-between min-h-[44px] font-medium transition-all hover:text-accent-cta text-left"
              data-lusena-accordion-trigger
              data-state="closed"
              aria-expanded="false"
            >
              Wysyłka i dostawa
              {% render 'lusena-icon',
                name: 'chevron-down',
                class: 'lusena-pdp-accordion__chevron h-4 w-4 shrink-0 transition-transform duration-200',
                stroke_width: 2
              %}
            </button>
          </div>
          <div
            class="lusena-pdp-accordion__content overflow-hidden text-sm"
            data-lusena-accordion-content
            data-state="closed"
          >
            <div class="lusena-pdp-accordion__body text-secondary">
              <p>{{ shipping_info | escape }}</p>
            </div>
          </div>
        </div>

        <div
          class="lusena-pdp-accordion__item border-b border-secondary/20{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          data-lusena-accordion-item
          data-lusena-accordion-value="returns"
          data-lusena-accordion-returns
        >
          <div class="flex">
            <button
              type="button"
              class="lusena-pdp-accordion__trigger flex flex-1 items-center justify-between min-h-[44px] font-medium transition-all hover:text-accent-cta text-left"
              data-lusena-accordion-trigger
              data-state="closed"
              aria-expanded="false"
            >
              Zwroty i gwarancja 60 dni
              {% render 'lusena-icon',
                name: 'chevron-down',
                class: 'lusena-pdp-accordion__chevron h-4 w-4 shrink-0 transition-transform duration-200',
                stroke_width: 2
              %}
            </button>
          </div>
          <div
            class="lusena-pdp-accordion__content overflow-hidden text-sm"
            data-lusena-accordion-content
            data-state="closed"
          >
            <div class="lusena-pdp-accordion__body text-secondary">
              <p>{{ returns_info | escape }}</p>
              <p>{{ guarantee_info | escape }}</p>
              <a href="/pages/zwroty" class="lusena-pdp-details__returns-link">
                Szczegóły zwrotów i gwarancji →
              </a>
            </div>
          </div>
        </div>

        <div
          class="lusena-pdp-accordion__item border-b border-secondary/20{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          data-lusena-accordion-item
          data-lusena-accordion-value="authenticity"
        >
          <div class="flex">
            <button
              type="button"
              class="lusena-pdp-accordion__trigger flex flex-1 items-center justify-between min-h-[44px] font-medium transition-all hover:text-accent-cta text-left"
              data-lusena-accordion-trigger
              data-state="closed"
              aria-expanded="false"
            >
              Czy to prawdziwy jedwab?
              {% render 'lusena-icon',
                name: 'chevron-down',
                class: 'lusena-pdp-accordion__chevron h-4 w-4 shrink-0 transition-transform duration-200',
                stroke_width: 2
              %}
            </button>
          </div>
          <div
            class="lusena-pdp-accordion__content overflow-hidden text-sm"
            data-lusena-accordion-content
            data-state="closed"
          >
            <div class="lusena-pdp-accordion__body text-secondary">
              <p>
                Tak, używamy wyłącznie w 100% naturalnego jedwabiu morwowego, <strong class="font-medium text-primary">bez żadnych domieszek poliestru czy elastanu</strong>. Autentyczność potwierdzają niezależne badania oraz certyfikat OEKO-TEX Standard 100. Różnicę w jakości poczujesz od pierwszego dotyku.
              </p>
            </div>
          </div>
        </div>

        <div
          class="lusena-pdp-accordion__item border-b border-secondary/20{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          data-lusena-accordion-item
          data-lusena-accordion-value="allergy"
        >
          <div class="flex">
            <button
              type="button"
              class="lusena-pdp-accordion__trigger flex flex-1 items-center justify-between min-h-[44px] font-medium transition-all hover:text-accent-cta text-left"
              data-lusena-accordion-trigger
              data-state="closed"
              aria-expanded="false"
            >
              Czy jedwab LUSENA jest odpowiedni dla alergików i cery trądzikowej?
              {% render 'lusena-icon',
                name: 'chevron-down',
                class: 'lusena-pdp-accordion__chevron h-4 w-4 shrink-0 transition-transform duration-200',
                stroke_width: 2
              %}
            </button>
          </div>
          <div
            class="lusena-pdp-accordion__content overflow-hidden text-sm"
            data-lusena-accordion-content
            data-state="closed"
          >
            <div class="lusena-pdp-accordion__body text-secondary">
              <p>
                Zdecydowanie tak. Jedwab morwowy jest naturalnie hipoalergiczny i nie gromadzi roztoczy ani kurzu. W przeciwieństwie do bawełny, <strong class="font-medium text-primary">nie wchłania wilgoci ani kosmetyków z Twojej twarzy</strong>, co zapobiega zapychaniu porów i aktywnie wspiera nocną pielęgnację oraz leczenie trądziku.
              </p>
            </div>
          </div>
        </div>

        <div
          class="lusena-pdp-accordion__item border-b border-secondary/20{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          data-lusena-accordion-item
          data-lusena-accordion-value="oeko"
        >
          <div class="flex">
            <button
              type="button"
              class="lusena-pdp-accordion__trigger flex flex-1 items-center justify-between min-h-[44px] font-medium transition-all hover:text-accent-cta text-left"
              data-lusena-accordion-trigger
              data-state="closed"
              aria-expanded="false"
            >
              Jak zweryfikować certyfikat OEKO-TEX?
              {% render 'lusena-icon',
                name: 'chevron-down',
                class: 'lusena-pdp-accordion__chevron h-4 w-4 shrink-0 transition-transform duration-200',
                stroke_width: 2
              %}
            </button>
          </div>
          <div
            class="lusena-pdp-accordion__content overflow-hidden text-sm"
            data-lusena-accordion-content
            data-state="closed"
          >
            <div class="lusena-pdp-accordion__body text-secondary">
              <p>
                Numer certyfikatu znajdziesz na materiałach produktu. Możesz go sprawdzić w oficjalnej bazie OEKO-TEX.
              </p>
            </div>
          </div>
        </div>

        <div
          class="lusena-pdp-accordion__item border-b border-secondary/20{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          data-lusena-accordion-item
          data-lusena-accordion-value="care-faq"
        >
          <div class="flex">
            <button
              type="button"
              class="lusena-pdp-accordion__trigger flex flex-1 items-center justify-between min-h-[44px] font-medium transition-all hover:text-accent-cta text-left"
              data-lusena-accordion-trigger
              data-state="closed"
              aria-expanded="false"
            >
              Jak prać i pielęgnować jedwab?
              {% render 'lusena-icon',
                name: 'chevron-down',
                class: 'lusena-pdp-accordion__chevron h-4 w-4 shrink-0 transition-transform duration-200',
                stroke_width: 2
              %}
            </button>
          </div>
          <div
            class="lusena-pdp-accordion__content overflow-hidden text-sm"
            data-lusena-accordion-content
            data-state="closed"
          >
            <div class="lusena-pdp-accordion__body text-secondary">
              <ul class="list-disc pl-4 space-y-1 text-secondary/80">
                <li>Prać w pralce: program delikatny, maks. 30°C</li>
                <li>Używać detergentu do jedwabiu lub delikatnych tkanin</li>
                <li>Suszyć na płasko — nie używać suszarki bębnowej</li>
                <li>Nie wybielać, nie prać z chlorem</li>
                <li>Prasować na najniższej temperaturze z lewej strony</li>
              </ul>
            </div>
          </div>
        </div>

        <div
          class="lusena-pdp-accordion__item border-b border-secondary/20{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          data-lusena-accordion-item
          data-lusena-accordion-value="origin"
        >
          <div class="flex">
            <button
              type="button"
              class="lusena-pdp-accordion__trigger flex flex-1 items-center justify-between min-h-[44px] font-medium transition-all hover:text-accent-cta text-left"
              data-lusena-accordion-trigger
              data-state="closed"
              aria-expanded="false"
            >
              Dlaczego jedwab z Suzhou?
              {% render 'lusena-icon',
                name: 'chevron-down',
                class: 'lusena-pdp-accordion__chevron h-4 w-4 shrink-0 transition-transform duration-200',
                stroke_width: 2
              %}
            </button>
          </div>
          <div
            class="lusena-pdp-accordion__content overflow-hidden text-sm"
            data-lusena-accordion-content
            data-state="closed"
          >
            <div class="lusena-pdp-accordion__body text-secondary">
              <p>
                Suzhou to historyczna stolica jedwabiu, której tradycje tkackie sięgają dynastii Ming. To stamtąd pochodzi najwyższej klasy jedwab morwowy, charakteryzujący się najdłuższymi i najbardziej wytrzymałymi włóknami na świecie.
              </p>
            </div>
          </div>
        </div>
        <div
          class="lusena-pdp-accordion__item border-b border-secondary/20{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          data-lusena-accordion-item
          data-lusena-accordion-value="price"
        >
          <div class="flex">
            <button
              type="button"
              class="lusena-pdp-accordion__trigger flex flex-1 items-center justify-between min-h-[44px] font-medium transition-all hover:text-accent-cta text-left"
              data-lusena-accordion-trigger
              data-state="closed"
              aria-expanded="false"
            >
              Dlaczego prawdziwy jedwab tyle kosztuje?
              {% render 'lusena-icon',
                name: 'chevron-down',
                class: 'lusena-pdp-accordion__chevron h-4 w-4 shrink-0 transition-transform duration-200',
                stroke_width: 2
              %}
            </button>
          </div>
          <div
            class="lusena-pdp-accordion__content overflow-hidden text-sm"
            data-lusena-accordion-content
            data-state="closed"
          >
            <div class="lusena-pdp-accordion__body text-secondary space-y-3">
              <p>
                Produkcja jedwabiu to proces wymagający ogromnej precyzji i czasu. Do stworzenia jednej poszewki LUSENA potrzeba tysięcy kokonów jedwabnika morwowego.
              </p>
              <p>
                Używamy wyłącznie jedwabiu o gęstości <strong class="font-medium text-primary">22 momme</strong> (idealny balans między miękkością a trwałością) oraz najwyższej <strong class="font-medium text-primary">klasy 6A</strong> (najdłuższe, nieskazitelne włókna). To inwestycja w produkt, który przy odpowiedniej pielęgnacji posłuży Ci przez lata.
              </p>
            </div>
          </div>
        </div>

        <div
          class="lusena-pdp-accordion__item border-b border-secondary/20{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          data-lusena-accordion-item
          data-lusena-accordion-value="silk-vs-satin"
        >
          <div class="flex">
            <button
              type="button"
              class="lusena-pdp-accordion__trigger flex flex-1 items-center justify-between min-h-[44px] font-medium transition-all hover:text-accent-cta text-left"
              data-lusena-accordion-trigger
              data-state="closed"
              aria-expanded="false"
            >
              Czym różni się jedwab od satyny?
              {% render 'lusena-icon',
                name: 'chevron-down',
                class: 'lusena-pdp-accordion__chevron h-4 w-4 shrink-0 transition-transform duration-200',
                stroke_width: 2
              %}
            </button>
          </div>
          <div
            class="lusena-pdp-accordion__content overflow-hidden text-sm"
            data-lusena-accordion-content
            data-state="closed"
          >
            <div class="lusena-pdp-accordion__body text-secondary space-y-3">
              <p>
                <strong class="font-medium text-primary">Jedwab</strong> to naturalne włókno białkowe, które oddycha, termoreguluje i nie wchłania wilgoci z Twojej skóry ani kremów.
              </p>
              <p>
                <strong class="font-medium text-primary">Satyna</strong> to jedynie rodzaj splotu, najczęściej wykonywany z taniego poliestru (plastiku). Poliester nie oddycha, powoduje pocenie się skóry i elektryzowanie włosów.
              </p>
            </div>
          </div>
        </div>

        <div
          class="lusena-pdp-accordion__item border-b border-secondary/20{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          data-lusena-accordion-item
          data-lusena-accordion-value="effects"
        >
          <div class="flex">
            <button
              type="button"
              class="lusena-pdp-accordion__trigger flex flex-1 items-center justify-between min-h-[44px] font-medium transition-all hover:text-accent-cta text-left"
              data-lusena-accordion-trigger
              data-state="closed"
              aria-expanded="false"
            >
              Kiedy zauważę pierwsze efekty?
              {% render 'lusena-icon',
                name: 'chevron-down',
                class: 'lusena-pdp-accordion__chevron h-4 w-4 shrink-0 transition-transform duration-200',
                stroke_width: 2
              %}
            </button>
          </div>
          <div
            class="lusena-pdp-accordion__content overflow-hidden text-sm"
            data-lusena-accordion-content
            data-state="closed"
          >
            <div class="lusena-pdp-accordion__body text-secondary space-y-3">
              <p>
                Różnicę poczujesz już po pierwszej nocy. Włosy będą mniej splątane i pozbawione puszenia, a na twarzy nie pojawią się odgniecenia od poduszki (tzw. sleep wrinkles).
              </p>
              <p>
                Długoterminowe efekty, takie jak lepsze nawilżenie skóry i poprawa kondycji włosów, zauważysz po około 2-4 tygodniach regularnego spania na jedwabiu.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  /* Use standard accordion spacing (defined in lusena-pdp-styles) */

  .lusena-pdp-details .lusena-pdp-details__returns-link {
    display: inline-block;
    margin-top: 0.8rem;
    color: rgb(14 94 90 / 1);
    font-weight: 500;
    text-decoration: none;
  }

  .lusena-pdp-details .lusena-pdp-details__returns-link:hover {
    text-decoration: underline;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PDP Details",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "PDP Details"
    }
  ]
}
{% endschema %}
