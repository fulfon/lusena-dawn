{%- liquid
  assign has_evidence_blocks = false
  for block in section.blocks
    if block.type == 'evidence'
      assign has_evidence_blocks = true
      break
    endif
  endfor
-%}

{%- if has_evidence_blocks -%}
  {%- liquid
    assign override_style = ''
    if section.settings.padding_top > 0
      assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
    endif
    if section.settings.padding_bottom > 0
      assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
    endif
    if section.settings.padding_top_mobile > 0
      assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
    endif
    if section.settings.padding_bottom_mobile > 0
      assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
    endif
  -%}
  <section
    class="lusena-pdp-quality-evidence lusena-spacing--standard"
    data-lusena-quality-evidence
    {% if override_style != blank %}
      style="{{ override_style }}"
    {% endif %}
  >
    <div class="lusena-container">
      <h2 class="lusena-pdp-quality-evidence__heading lusena-gap-section-intro{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.heading | escape }}
      </h2>

      <div
        class="lusena-pdp-quality-evidence__stack"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        {%- for block in section.blocks -%}
          {%- if block.type == 'evidence' -%}
            {%- liquid
              assign cta_url = block.settings.cta_link
              assign cta_opens_new_tab = false

              if block.settings.use_certificate_link
                assign oeko_number = blank
                assign cta_opens_new_tab = true

                if shop.metafields.lusena.oeko_tex_certificate_number != blank
                  assign oeko_number_value = shop.metafields.lusena.oeko_tex_certificate_number.value
                  if oeko_number_value != blank
                    assign oeko_number = oeko_number_value | strip
                  endif
                endif

                if oeko_number != blank
                  assign oeko_number_encoded = oeko_number | url_encode
                  assign cta_url = 'https://www.oeko-tex.com/en/detail/?number=' | append: oeko_number_encoded
                else
                  assign cta_url = '/pages/nasza-jakosc'
                endif
              endif
            -%}

            <div
              class="lusena-pdp-quality-evidence__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              data-lusena-quality-evidence-item
              {{ block.shopify_attributes }}
            >
              <button
                type="button"
                class="lusena-pdp-quality-evidence__toggle"
                data-lusena-quality-evidence-toggle
                aria-expanded="false"
              >
                <span class="lusena-pdp-quality-evidence__toggle-icon-wrap">
                  {% render 'lusena-icon',
                    name: block.settings.icon,
                    class: 'lusena-pdp-quality-evidence__toggle-icon',
                    stroke_width: 1.5
                  %}
                </span>
                <span class="lusena-pdp-quality-evidence__toggle-copy">
                  <span class="lusena-pdp-quality-evidence__title">{{ block.settings.title | escape }}</span>
                  <span class="lusena-pdp-quality-evidence__summary">
                    {{- block.settings.summary | escape | newline_to_br -}}
                  </span>
                </span>
                {% render 'lusena-icon',
                  name: 'chevron-down',
                  class: 'lusena-pdp-quality-evidence__chevron',
                  stroke_width: 1.5
                %}
              </button>

              <div class="lusena-pdp-quality-evidence__panel" data-lusena-quality-evidence-panel>
                <div class="lusena-pdp-quality-evidence__panel-inner">
                  {%- if block.settings.detail != blank -%}
                    <p class="lusena-pdp-quality-evidence__detail">
                      {{ block.settings.detail | escape | newline_to_br }}
                    </p>
                  {%- endif -%}

                  {%- if block.settings.cta_label != blank -%}
                    {%- if cta_url != blank -%}
                      <a
                        href="{{ cta_url }}"
                        class="lusena-pdp-quality-evidence__cta lusena-link-arrow"
                        {% if cta_opens_new_tab %}
                          target="_blank" rel="noopener"
                        {% endif %}
                      >
                        {{ block.settings.cta_label | escape }}
                      </a>
                    {%- else -%}
                      <span class="lusena-pdp-quality-evidence__cta lusena-link-arrow">
                        {{ block.settings.cta_label | escape }}
                      </span>
                    {%- endif -%}
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% stylesheet %}
  .lusena-pdp-quality-evidence {
    background-color: var(--lusena-brand-bg);
  }

  .lusena-pdp-quality-evidence__heading {
    margin: 0;
    font-family: var(--lusena-font-brand);
    font-size: 24px;
    line-height: 32px;
    color: var(--lusena-text-1);
    text-align: center;
  }

  .lusena-pdp-quality-evidence__stack {
    max-width: 768px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--lusena-space-2);
  }

  .lusena-pdp-quality-evidence__item {
    background-color: var(--lusena-surface-1);
    border-radius: var(--lusena-radius-sm);
    overflow: hidden;
    cursor: pointer;
    contain: layout style;
    -webkit-tap-highlight-color: transparent;
  }

  .lusena-pdp-quality-evidence__toggle {
    width: 100%;
    padding: 20px;
    display: flex;
    align-items: flex-start;
    gap: var(--lusena-space-2);
    text-align: left;
    background-color: var(--lusena-surface-1);
    border: 0;
    transition: none;
    color: inherit;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .lusena-pdp-quality-evidence__toggle:hover .lusena-pdp-quality-evidence__title {
    color: var(--lusena-accent-cta);
  }

  .lusena-pdp-quality-evidence__toggle:hover .lusena-pdp-quality-evidence__chevron {
    color: var(--lusena-accent-cta);
  }

  .lusena-pdp-quality-evidence__toggle:focus-visible {
    outline: 2px solid var(--lusena-accent-cta);
    outline-offset: 2px;
  }

  .lusena-pdp-quality-evidence__toggle-icon-wrap {
    width: 40px;
    height: 40px;
    border-radius: 9999px;
    background-color: var(--lusena-surface-2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .lusena-pdp-quality-evidence__toggle-icon {
    width: 20px;
    height: 20px;
    color: var(--lusena-accent-2);
  }

  .lusena-pdp-quality-evidence__toggle-copy {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--lusena-space-05);
  }

  .lusena-pdp-quality-evidence__title {
    margin: 0;
    font-family: var(--lusena-font-brand);
    font-size: 20px;
    line-height: 28px;
    color: var(--lusena-text-1);
    transition: color var(--lusena-transition-fast);
  }

  .lusena-pdp-quality-evidence__summary {
    margin: 0;
    font-size: 14px;
    line-height: 1.625;
    color: var(--lusena-text-2);
  }

  .lusena-pdp-quality-evidence__chevron {
    width: 20px;
    height: 20px;
    color: color-mix(in srgb, var(--lusena-text-2) 50%, transparent);
    flex-shrink: 0;
    margin-top: 4px;
    transition: transform 0.2s ease, color var(--lusena-transition-fast);
  }

  .lusena-pdp-quality-evidence__panel {
    height: 0;
    overflow: hidden;
    transition: height 0.2s cubic-bezier(0.25, 0.1, 0.25, 1);
    will-change: height;
  }

  .lusena-pdp-quality-evidence__panel-inner {
    /* 20px padding + 40px icon + 16px gap = 76px */
    padding: 0 20px 20px 76px;
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  .lusena-pdp-quality-evidence__detail {
    margin: 0 0 12px;
    font-size: 14px;
    line-height: 1.625;
    color: var(--lusena-text-2);
  }

  .lusena-pdp-quality-evidence__cta {
    font-size: 12px;
    line-height: 16px;
    font-weight: 500;
    color: var(--lusena-accent-cta);
    text-decoration: none;
  }

  .lusena-pdp-quality-evidence__cta:hover {
    text-decoration: underline;
  }

  .lusena-pdp-quality-evidence__cta:focus-visible {
    outline: 2px solid var(--lusena-accent-cta);
    outline-offset: 2px;
  }

  .lusena-pdp-quality-evidence__item[data-state='open'] .lusena-pdp-quality-evidence__chevron {
    transform: rotate(180deg);
  }

  .lusena-pdp-quality-evidence__item[data-state='closed'] .lusena-pdp-quality-evidence__panel-inner,
  .lusena-pdp-quality-evidence__item[data-state='closing'] .lusena-pdp-quality-evidence__panel-inner {
    opacity: 0;
    transform: translateY(-6px);
  }

  @media (prefers-reduced-motion: reduce) {
    .lusena-pdp-quality-evidence__panel {
      transition: none;
      will-change: auto;
    }
    .lusena-pdp-quality-evidence__panel-inner {
      transition: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }

  @media (min-width: 768px) {
    .lusena-pdp-quality-evidence__heading {
      font-size: 28px;
      line-height: 36px;
    }

    .lusena-pdp-quality-evidence__toggle {
      padding: 24px;
    }

    .lusena-pdp-quality-evidence__panel-inner {
      /* 24px padding + 40px icon + 16px gap = 80px */
      padding: 0 24px 24px 80px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    var prefersReducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function getPanel(item) { return item.querySelector('[data-lusena-quality-evidence-panel]'); }
    function getInner(panel) { return panel.querySelector('.lusena-pdp-quality-evidence__panel-inner') || panel.firstElementChild; }
    function clearPendingEnd(panel) {
      if (typeof panel._lusenaQeOnEnd === 'function') {
        panel.removeEventListener('transitionend', panel._lusenaQeOnEnd);
        panel._lusenaQeOnEnd = null;
      }
    }
    function setExpanded(item, expanded) {
      var toggle = item.querySelector('[data-lusena-quality-evidence-toggle]');
      if (toggle) toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
    }

    var initRoot = function(root) {
      if (!root) return;
      if (root.hasAttribute('data-lusena-quality-evidence-init')) return;
      root.setAttribute('data-lusena-quality-evidence-init', 'true');

      var items = Array.from(root.querySelectorAll('[data-lusena-quality-evidence-item]'));

      function closeItem(item) {
        var panel = getPanel(item);
        if (!panel) return;
        clearPendingEnd(panel);

        if (prefersReducedMotion) {
          item.dataset.state = 'closed';
          panel.style.height = '0px';
          setExpanded(item, false);
          return;
        }

        var h = panel.offsetHeight;
        panel.style.height = h + 'px';
        item.dataset.state = 'closing';

        requestAnimationFrame(function() {
          panel.style.height = '0px';
        });

        var onEnd = function(e) {
          if (e.target !== panel || e.propertyName !== 'height') return;
          panel.removeEventListener('transitionend', onEnd);
          panel._lusenaQeOnEnd = null;
          item.dataset.state = 'closed';
          panel.style.height = '0px';
        };
        panel._lusenaQeOnEnd = onEnd;
        panel.addEventListener('transitionend', onEnd);
        setExpanded(item, false);
      }

      function openItem(item) {
        var panel = getPanel(item);
        if (!panel) return;
        clearPendingEnd(panel);

        // Accordion: close all others
        items.forEach(function(other) {
          if (other !== item && other.dataset.state !== 'closed') closeItem(other);
        });

        if (prefersReducedMotion) {
          item.dataset.state = 'open';
          panel.style.height = 'auto';
          setExpanded(item, true);
          return;
        }

        panel.style.height = '0px';
        item.dataset.state = 'open';

        var inner = getInner(panel);
        var targetH = inner ? inner.scrollHeight : panel.scrollHeight;

        requestAnimationFrame(function() {
          panel.style.height = targetH + 'px';
        });

        setExpanded(item, true);
      }

      // Init state
      items.forEach(function(item) {
        var panel = getPanel(item);
        if (!panel) return;
        item.dataset.state = 'closed';
        panel.style.height = '0px';
      });

      // Event handlers
      items.forEach(function(item) {
        item.addEventListener('click', function(e) {
          if (e.target.closest('.lusena-pdp-quality-evidence__cta')) return;
          if (item.dataset.state === 'open') closeItem(item);
          else openItem(item);
        });
      });
    };

    var initAll = function(scope) {
      var searchRoot = scope || document;
      var roots = searchRoot.querySelectorAll('[data-lusena-quality-evidence]');
      roots.forEach(function(root) { initRoot(root); });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() { initAll(document); });
    } else {
      initAll(document);
    }

    if (window.Shopify && window.Shopify.designMode) {
      document.addEventListener('shopify:section:load', function(event) {
        initAll(event.target);
      });

      document.addEventListener('shopify:block:select', function(event) {
        var selectedItem = event.target.closest('[data-lusena-quality-evidence-item]');
        if (!selectedItem) return;
        var root = selectedItem.closest('[data-lusena-quality-evidence]');
        if (!root) return;
        var items = Array.from(root.querySelectorAll('[data-lusena-quality-evidence-item]'));
        items.forEach(function(item) {
          var panel = getPanel(item);
          if (item === selectedItem) {
            item.dataset.state = 'open';
            if (panel) panel.style.height = 'auto';
            setExpanded(item, true);
          } else {
            item.dataset.state = 'closed';
            if (panel) panel.style.height = '0px';
            setExpanded(item, false);
          }
        });
      });
    }
  })();
{% endjavascript %}

{% schema %}
{
  "name": "LUSENA PDP Quality",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Dlaczego LUSENA?"
    }
  ],
  "blocks": [
    {
      "type": "evidence",
      "name": "Evidence item",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "shield-check",
          "options": [
            { "value": "shield-check", "label": "Shield Check" },
            { "value": "map-pin", "label": "Map Pin" },
            { "value": "layers", "label": "Layers" },
            { "value": "package", "label": "Package" },
            { "value": "sparkles", "label": "Sparkles" },
            { "value": "gift", "label": "Gift" },
            { "value": "rotate-ccw", "label": "Rotate (returns)" }
          ]
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "OEKO-TEX® Standard 100"
        },
        {
          "type": "textarea",
          "id": "summary",
          "label": "Summary",
          "default": "Niezależny certyfikat potwierdzający brak substancji szkodliwych. Bezpieczny dla skóry wrażliwej, alergików i dzieci."
        },
        {
          "type": "textarea",
          "id": "detail",
          "label": "Expanded detail",
          "default": "Każda partia jedwabiu jest testowana przez akredytowane laboratorium. Numer certyfikatu znajdziesz na karcie dołączonej do produktu. Możesz go zweryfikować na oeko-tex.com/check."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Sprawdź certyfikat"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "CTA link"
        },
        {
          "type": "checkbox",
          "id": "use_certificate_link",
          "label": "Use OEKO-TEX verification link (from shop metafield)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LUSENA PDP Quality",
      "settings": {
        "heading": "Dlaczego LUSENA?"
      },
      "blocks": [
        {
          "type": "evidence",
          "settings": {
            "icon": "shield-check",
            "title": "OEKO-TEX® Standard 100",
            "summary": "Niezależny certyfikat potwierdzający brak substancji szkodliwych. Bezpieczny dla skóry wrażliwej, alergików i dzieci.",
            "detail": "Każda partia jedwabiu jest testowana przez akredytowane laboratorium. Numer certyfikatu znajdziesz na karcie dołączonej do produktu. Możesz go zweryfikować na oeko-tex.com/check.",
            "cta_label": "Sprawdź certyfikat",
            "cta_link": "/pages/nasza-jakosc",
            "use_certificate_link": true
          }
        },
        {
          "type": "evidence",
          "settings": {
            "icon": "map-pin",
            "title": "Jedwab z Suzhou - 600 lat tradycji",
            "summary": "Nasz jedwab pochodzi z regionu Shengze w Suzhou - światowej stolicy jedwabiu od ponad 600 lat.",
            "detail": "Lokalni producenci specjalizują się w jedwabiu Grade 6A o najdłuższych włóknach. To gładszy, trwalszy i bardziej lśniący materiał niż jedwab z innych regionów. Współpracujemy bezpośrednio z certyfikowanymi manufakturami.",
            "cta_label": "Więcej o pochodzeniu",
            "cta_link": "/pages/o-nas"
          }
        },
        {
          "type": "evidence",
          "settings": {
            "icon": "layers",
            "title": "22 momme - optymalny standard",
            "summary": "Momme to jednostka gęstości jedwabiu. 22 momme to gęstszy i trwalszy splot niż typowe 16-19 momme na rynku.",
            "detail": "Wyższe momme oznacza grubszy, bardziej trwały jedwab, który lepiej oddycha i zachowuje właściwości termoregulacyjne. 22 momme to optymalny balans między luksusowym dotykiem a wytrzymałością - bez nadmiernej wagi.",
            "cta_label": "Porównaj momme",
            "cta_link": "/pages/nasza-jakosc"
          }
        },
        {
          "type": "evidence",
          "settings": {
            "icon": "package",
            "title": "Kontrola jakości w Polsce + wysyłka 24h",
            "summary": "Każdy produkt przechodzi kontrolę jakości w naszym magazynie w Polsce. Wysyłamy w ciągu 24 godzin roboczych.",
            "detail": "Sprawdzamy szwy, zamek, kolor i gramaturę. Produkty niespełniające standardów nie trafiają do sprzedaży. Dzięki lokalnej logistyce dostarczamy w 1-2 dni robocze via InPost lub kurier."
          }
        }
      ]
    }
  ]
}
{% endschema %}
