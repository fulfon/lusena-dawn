{%- comment -%}
  LUSENA Cart Items - flex-based layout matching cart drawer.
  All JS-required IDs and classes preserved for cart.js compatibility.
  Upsell uses custom JS (not product-form.js) to avoid opening the drawer.
{%- endcomment -%}

{%- unless settings.cart_type == 'drawer' -%}
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'lusena-bundle-swap.js' | asset_url }}" defer="defer"></script>

{%- liquid
  comment
    Upsell product selection - mirrors cart-drawer.liquid waterfall:
    1. Check global enable toggle + distinct-product suppression
    2. Find trigger product (hero role or first item)
    3. Resolve candidate: primary metafield → secondary → global fallback
  endcomment

  assign upsell_enabled = settings.lusena_enable_cart_upsell
  if upsell_enabled == nil
    assign upsell_enabled = true
  endif

  assign suppress_distinct_threshold = settings.lusena_cart_upsell_suppress_distinct_count | default: 2
  assign cart_product_ids = cart.items | map: 'product_id' | uniq
  assign distinct_count = cart_product_ids | size

  assign suppress_upsell = false

  for item in cart.items
    if item.product.metafields.lusena.upsell_suppress == true or item.product.metafields.lusena.upsell_role == 'bundle'
      assign suppress_upsell = true
      break
    endif
  endfor

  assign trigger_product = nil
  assign trigger_item = nil
  if cart != empty and suppress_upsell == false and upsell_enabled
    for item in cart.items
      if item.product.metafields.lusena.upsell_role == 'hero' and item.product.metafields.lusena.upsell_suppress != true
        assign trigger_product = item.product
        assign trigger_item = item
        break
      endif
    endfor
    if trigger_product == nil
      assign trigger_item = cart.items.first
      assign trigger_product = trigger_item.product
    endif
  endif

  assign trigger_color = ''
  if trigger_item != nil
    for option in trigger_product.options_with_values
      assign opt_name_down = option.name | downcase
      assign is_color_opt = false
      if opt_name_down contains 'color'
        assign is_color_opt = true
      else
        if opt_name_down contains 'colour'
          assign is_color_opt = true
        else
          if opt_name_down contains 'kolor'
            assign is_color_opt = true
          endif
        endif
      endif
      if is_color_opt
        assign trigger_color_pos = forloop.index
        if trigger_color_pos == 1
          assign trigger_color = trigger_item.variant.option1
        elsif trigger_color_pos == 2
          assign trigger_color = trigger_item.variant.option2
        elsif trigger_color_pos == 3
          assign trigger_color = trigger_item.variant.option3
        endif
        break
      endif
    endfor
  endif

  assign candidate_primary = blank
  assign candidate_secondary = blank
  assign candidate_fallback = settings.lusena_cart_upsell_global_fallback

  if trigger_product != nil
    assign primary_metafield = trigger_product.metafields.lusena.upsell_primary
    assign secondary_metafield = trigger_product.metafields.lusena.upsell_secondary
    assign candidate_primary = primary_metafield.value
    assign candidate_secondary = secondary_metafield.value
  endif

  assign upsell_product = blank

  assign in_cart_primary = false
  if candidate_primary != blank and cart_product_ids contains candidate_primary.id
    assign in_cart_primary = true
  endif

  assign in_cart_secondary = false
  if candidate_secondary != blank and cart_product_ids contains candidate_secondary.id
    assign in_cart_secondary = true
  endif

  assign in_cart_fallback = false
  if candidate_fallback != blank and cart_product_ids contains candidate_fallback.id
    assign in_cart_fallback = true
  endif

  if suppress_upsell == false and upsell_enabled and cart != empty
    if candidate_primary != blank and candidate_primary.available and in_cart_primary == false
      assign upsell_product = candidate_primary
    elsif candidate_secondary != blank and candidate_secondary.available and in_cart_secondary == false
      assign upsell_product = candidate_secondary
    elsif candidate_fallback != blank and candidate_fallback.available and in_cart_fallback == false
      assign upsell_product = candidate_fallback
    endif

    comment
      If no upsell product found via metafield waterfall, the upsell zone stays hidden.
    endcomment
  endif

  if suppress_upsell == false and distinct_count >= suppress_distinct_threshold
    if upsell_product == blank or upsell_product.metafields.lusena.bundle_original_price == blank
      assign upsell_product = blank
    endif
  endif
-%}

<cart-items
  class="lusena-spacing--compact{% if cart == empty %} is-empty{% endif %}"
  data-section-type="lusena-cart-items"
>
  <div class="lusena-container">
    {%- comment -%} Page header {%- endcomment -%}
    <div class="lusena-cart-header">
      <h1 class="lusena-cart-header__title">Twój koszyk</h1>
    </div>

    {%- comment -%} Empty state {%- endcomment -%}
    <div class="cart__warnings lusena-cart-empty">
      <div class="lusena-empty">
        <h1 class="lusena-type-h2">Twój koszyk jest pusty</h1>
        <a href="{{ routes.all_products_collection_url }}" class="lusena-btn lusena-btn--primary lusena-btn--size-default">
          Kontynuuj zakupy
        </a>

        {%- if shop.customer_accounts_enabled and customer == null -%}
          <div class="lusena-cart-empty__login lusena-content-flow--tight">
            <h2 class="lusena-type-body" style="font-weight: 500;">Masz już konto?</h2>
            <p class="lusena-type-caption">
              <a href="{{ routes.account_login_url }}" class="link underlined-link">Zaloguj się</a>, aby szybciej realizować zakupy.
            </p>
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Cart form {%- endcomment -%}
    <form action="{{ routes.cart_url }}" class="lusena-cart-form critical-hidden" method="post" id="cart">
      <div class="cart__items" id="main-cart-items" data-id="{{ section.id }}">
        <div class="js-contents">
          {%- if cart != empty -%}
            <div class="lusena-cart-list">
              {%- for item in cart.items -%}
                <div
                  class="cart-item lusena-cart-item"
                  id="CartItem-{{ item.index | plus: 1 }}"
                  {% if item.parent_relationship.parent != null %}
                    aria-label="{{ item.product.title | escape }} (część {{ item.parent_relationship.parent.title | escape }})"
                  {% endif %}
                >
                  {%- comment -%} Image (always render wrapper for placeholder) {%- endcomment -%}
                  <a href="{{ item.url }}" class="lusena-cart-item__media" aria-hidden="true" tabindex="-1">
                    {% if item.image %}
                      <img
                        src="{{ item.image | image_url: width: 300 }}"
                        alt="{{ item.image.alt | escape }}"
                        class="lusena-cart-item__img"
                        loading="lazy"
                        width="80"
                        height="{{ 96 | divided_by: item.image.aspect_ratio | ceil }}"
                      >
                    {% endif %}
                  </a>

                  {%- comment -%} Info column {%- endcomment -%}
                  <div class="lusena-cart-item__info">
                    <div>
                      {%- comment -%} Top row: name + line price {%- endcomment -%}
                      <div class="lusena-cart-item__top">
                        <div class="lusena-cart-item__name-wrap">
                          {%- if settings.show_vendor -%}
                            <p class="lusena-cart-item__vendor">{{ item.product.vendor }}</p>
                          {%- endif -%}
                          <a href="{{ item.url }}" class="cart-item__name lusena-cart-item__title">
                            {{ item.product.title | escape }}
                          </a>
                        </div>
                        <div class="lusena-cart-item__prices">
                          {%- render 'loading-spinner' -%}
                          <span class="lusena-cart-item__price">{{ item.final_line_price | money }}</span>
                          {%- if item.original_line_price != item.final_line_price -%}
                            <span class="lusena-cart-item__compare-price">{{ item.original_line_price | money }}</span>
                          {%- endif -%}
                        </div>
                      </div>

                      {%- comment -%} Options - value-only, slash-separated (matching drawer) {%- endcomment -%}
                      {%- if item.product.has_only_default_variant == false -%}
                        <p class="lusena-cart-item__options">
                          {%- for option in item.options_with_values -%}
                            {{ option.value }}{%- unless forloop.last %} / {% endunless -%}
                          {%- endfor -%}
                        </p>
                      {%- endif -%}

                      {%- comment -%} Properties (bundle color selections, custom uploads, etc.) {%- endcomment -%}
                      {%- unless item.properties == empty -%}
                        {%- for property in item.properties -%}
                          {%- assign property_first_char = property.first | slice: 0 -%}
                          {%- if property.last != blank and property_first_char != '_' -%}
                            <p class="lusena-cart-item__property">
                              {{ property.first }}:
                              {%- if property.last contains '/uploads/' %}
                                <a href="{{ property.last }}" class="lusena-cart-item__upload-link" target="_blank">
                                  {{ property.last | split: '/' | last }}
                                </a>
                              {%- else %}
                                {{ property.last }}
                              {%- endif -%}
                            </p>
                          {%- endif -%}
                        {%- endfor -%}
                      {%- endunless -%}

                      {%- if item.selling_plan_allocation != null -%}
                        <p class="lusena-cart-item__options">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                      {%- endif -%}

                      {%- comment -%} Line-level discounts {%- endcomment -%}
                      {%- if item.line_level_discount_allocations.size > 0 -%}
                        <ul class="lusena-cart-item__discounts" role="list" aria-label="Rabat">
                          {%- for discount in item.line_level_discount_allocations -%}
                            <li class="lusena-cart-item__discount">
                              <span class="lusena-cart-item__discount-icon">{{- 'icon-discount.svg' | inline_asset_content -}}</span>
                              {{ discount.discount_application.title | escape }}
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}
                    </div>

                    {%- comment -%} Bottom row: quantity stepper + remove {%- endcomment -%}
                    <div class="lusena-cart-item__bottom">
                      {%- render 'lusena-cart-quantity', item: item -%}
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            </div>

            {%- comment -%} Upsell card - below items, inside items area {%- endcomment -%}
            {%- if upsell_product != blank -%}
              {%- assign upsell_is_bundle = false -%}
              {%- if upsell_product.metafields.lusena.bundle_original_price != blank -%}
                {%- assign upsell_is_bundle = true -%}
              {%- endif -%}
                {%- liquid
                comment
                  Color-matched variant selection:
                  1. Find upsell product's color option position
                  2. Match trigger product's color — pick that variant
                  3. Fallback: highest-inventory available variant
                  4. Last resort: first available variant
                endcomment
                assign upsell_variant = nil
                assign upsell_color_option_pos = 0
                assign upsell_color_label = ''

                if upsell_product.options_with_values != blank
                  for option in upsell_product.options_with_values
                    assign opt_name_down = option.name | downcase
                    assign is_color_opt = false
                    if opt_name_down contains 'color'
                      assign is_color_opt = true
                    else
                      if opt_name_down contains 'colour'
                        assign is_color_opt = true
                      else
                        if opt_name_down contains 'kolor'
                          assign is_color_opt = true
                        endif
                      endif
                    endif
                    if is_color_opt
                      assign upsell_color_option_pos = forloop.index
                      break
                    endif
                  endfor
                endif

                if trigger_color != blank and upsell_color_option_pos > 0
                  for variant in upsell_product.variants
                    if variant.available
                      assign variant_color = ''
                      if upsell_color_option_pos == 1
                        assign variant_color = variant.option1
                      elsif upsell_color_option_pos == 2
                        assign variant_color = variant.option2
                      elsif upsell_color_option_pos == 3
                        assign variant_color = variant.option3
                      endif
                      if variant_color == trigger_color
                        assign upsell_variant = variant
                        break
                      endif
                    endif
                  endfor
                endif

                if upsell_variant == nil
                  assign best_inv_qty = -1
                  for variant in upsell_product.variants
                    if variant.available
                      if variant.inventory_quantity > best_inv_qty
                        assign best_inv_qty = variant.inventory_quantity
                        assign upsell_variant = variant
                      endif
                    endif
                  endfor
                endif

                if upsell_variant == nil
                  assign upsell_variant = upsell_product.selected_or_first_available_variant
                endif

                if upsell_color_option_pos > 0
                  if upsell_color_option_pos == 1
                    assign upsell_color_label = upsell_variant.option1
                  elsif upsell_color_option_pos == 2
                    assign upsell_color_label = upsell_variant.option2
                  elsif upsell_color_option_pos == 3
                    assign upsell_color_label = upsell_variant.option3
                  endif
                endif

                assign upsell_message_metafield = upsell_product.metafields.lusena.upsell_message
                assign upsell_message = upsell_message_metafield.value | default: settings.lusena_cart_upsell_message_fallback
                assign upsell_display_title = upsell_product.title
                assign upsell_display_price = upsell_variant.price | money_without_trailing_zeros
              -%}

              {%- if upsell_is_bundle -%}
                {%- comment -%} Bundle two-tile card {%- endcomment -%}
                {%- assign nudge_map = upsell_product.metafields.lusena.bundle_nudge_map.value -%}
                {%- assign nudge_entry = nudge_map[trigger_product.handle] -%}
                {%- assign added_label = nudge_entry.label | default: nudge_entry -%}
                {%- assign added_component = all_products[nudge_entry.handle] -%}
                {%- assign bundle_price_cents = upsell_variant.price -%}
                {%- assign original_total_cents = upsell_product.metafields.lusena.bundle_original_price.value | times: 100 -%}
                {%- assign savings_cents = original_total_cents | minus: bundle_price_cents -%}
                {%- assign incremental_cents = bundle_price_cents | minus: trigger_item.variant.price -%}

                {%- liquid
                  assign sb_options = upsell_variant.metafields.simple_bundles.variant_options.value
                  assign nudge_prop_map = ''
                  if sb_options != blank
                    for opt in sb_options
                      assign opt_product = opt.optionName | split: ' - Color' | first | split: ' - ' | first
                      assign opt_clean = opt_product
                      assign dim_parts = opt_product | split: '×'
                      if dim_parts.size > 1
                        assign opt_words = opt_product | split: ' '
                        assign opt_clean = ''
                        for w in opt_words
                          assign w_dim = w | split: '×' | size
                          if w_dim > 1
                            break
                          endif
                          if opt_clean == ''
                            assign opt_clean = w
                          else
                            assign opt_clean = opt_clean | append: ' ' | append: w
                          endif
                        endfor
                      endif

                      assign outer_idx = forloop.index
                      assign same_total = 0
                      assign same_so_far = 0
                      for check in sb_options
                        assign check_name = check.optionName | split: ' - Color' | first | split: ' - ' | first
                        if check_name == opt_product
                          assign same_total = same_total | plus: 1
                          if forloop.index <= outer_idx
                            assign same_so_far = same_so_far | plus: 1
                          endif
                        endif
                      endfor
                      if same_total > 1
                        assign opt_clean = opt_clean | append: ' ' | append: same_so_far
                      endif

                      assign opt_vals_raw = opt.optionValues | split: ', '
                      assign opt_vals_json = ''
                      for v in opt_vals_raw
                        if opt_vals_json == ''
                          assign opt_vals_json = '"' | append: v | append: '"'
                        else
                          assign opt_vals_json = opt_vals_json | append: ',"' | append: v | append: '"'
                        endif
                      endfor
                      assign entry = '{"key":"' | append: opt_clean | append: '","values":[' | append: opt_vals_json | append: ']}'
                      if nudge_prop_map == ''
                        assign nudge_prop_map = entry
                      else
                        assign nudge_prop_map = nudge_prop_map | append: ',' | append: entry
                      endif
                    endfor
                    assign nudge_prop_map = '[' | append: nudge_prop_map | append: ']'
                  endif
                -%}

                <div class="lusena-cart-upsell" aria-live="polite">
                  <p class="lusena-cart-upsell__label">Korzystniej w zestawie</p>
                  <div class="lusena-upsell-card"
                       data-bundle-nudge
                       data-bundle-variant-id="{{ upsell_variant.id }}"
                       data-replace-key="{{ trigger_item.key | escape }}"
                       {%- if trigger_color != blank %} data-trigger-color="{{ trigger_color | escape }}"{% endif -%}
                       {%- if nudge_prop_map != blank %} data-property-map="{{ nudge_prop_map | escape }}"{% endif -%}
                       aria-label="Propozycja zestawu">
                    <p class="lusena-upsell-card__bn-headline">
                      Dodaj {{ added_label }} i zaoszczedz {{ savings_cents | money_without_trailing_zeros }}
                    </p>
                    <div class="lusena-upsell-card__bn-tiles">
                      <div class="lusena-upsell-card__bn-have">
                        <div class="lusena-upsell-card__bn-have-img">
                          {%- if trigger_product.featured_image -%}
                            <img
                              src="{{ trigger_product.featured_image | image_url: width: 120 }}"
                              alt="{{ trigger_product.featured_image.alt | escape }}"
                              loading="lazy" width="38"
                              height="{{ 38 | divided_by: trigger_product.featured_image.aspect_ratio | ceil }}"
                            >
                          {%- endif -%}
                          <span class="lusena-upsell-card__bn-check" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                          </span>
                        </div>
                        <p class="lusena-upsell-card__bn-have-name">{{ trigger_product.title | escape }}</p>
                        <p class="lusena-upsell-card__bn-have-status">W koszyku</p>
                      </div>
                      <span class="lusena-upsell-card__bn-plus" aria-hidden="true">+</span>
                      <div class="lusena-upsell-card__bn-add">
                        <div class="lusena-upsell-card__bn-add-img">
                          {%- assign add_tile_image = added_component.featured_image | default: upsell_product.featured_image -%}
                          {%- if add_tile_image -%}
                            <img
                              src="{{ add_tile_image | image_url: width: 240 }}"
                              alt="{{ add_tile_image.alt | escape }}"
                              loading="lazy" width="56"
                              height="{{ 56 | divided_by: add_tile_image.aspect_ratio | ceil }}"
                            >
                          {%- endif -%}
                        </div>
                        {%- assign tile_label = nudge_entry.tile_label | default: added_component.title | default: added_label -%}
                        <p class="lusena-upsell-card__bn-add-name">{{ tile_label | escape }}</p>
                      </div>
                    </div>
                    <div class="lusena-upsell-card__bn-bottom">
                      <div class="lusena-upsell-card__bn-pricing">
                        <span class="lusena-upsell-card__bn-price">{{ bundle_price_cents | money_without_trailing_zeros }}</span>
                        <span class="lusena-upsell-card__bn-was">{{ original_total_cents | money_without_trailing_zeros }}</span>
                      </div>
                      <button type="button"
                              class="lusena-btn lusena-btn--outline lusena-btn--size-xs"
                              data-bundle-nudge-action>
                        <span class="lusena-btn__content">Dodaj do zestawu</span>
                        <span class="loading__spinner hidden">
                          <span class="lusena-btn__loading-dots" aria-hidden="true">
                            <span></span><span></span><span></span>
                          </span>
                        </span>
                      </button>
                    </div>
                  </div>
                </div>

              {%- else -%}
                {%- comment -%} Cross-sell card (horizontal) - cart page version {%- endcomment -%}
                <div class="lusena-cart-upsell" data-cart-page-upsell aria-live="polite">
                  <p class="lusena-cart-upsell__label">Pasuje do</p>
                  <div class="lusena-upsell-card">
                    <div class="lusena-upsell-card__xs-row">
                      <div class="lusena-upsell-card__xs-img">
                        {%- if upsell_product.featured_image -%}
                          <img
                            src="{{ upsell_product.featured_image | image_url: width: 240 }}"
                            alt="{{ upsell_product.featured_image.alt | escape }}"
                            loading="lazy" width="56"
                            height="{{ 56 | divided_by: upsell_product.featured_image.aspect_ratio | ceil }}"
                          >
                        {%- endif -%}
                      </div>
                      <div class="lusena-upsell-card__xs-info">
                        <p class="lusena-upsell-card__xs-title">{{ upsell_product.title | escape }}</p>
                        {%- if upsell_message != blank -%}
                          <p class="lusena-upsell-card__xs-msg">{{ upsell_message | escape }}</p>
                        {%- endif -%}
                        {%- if upsell_color_label != blank -%}
                          <p class="lusena-upsell-card__xs-color">
                            Kolor: <span>{{ upsell_color_label | escape }}</span>
                          </p>
                        {%- endif -%}
                      </div>
                    </div>
                    <div class="lusena-upsell-card__xs-bottom">
                      <p class="lusena-upsell-card__xs-price">{{ upsell_display_price | escape }}</p>
                      <button
                        type="button"
                        class="lusena-btn lusena-btn--outline lusena-btn--size-xs"
                        data-cart-page-upsell-add
                        data-variant-id="{{ upsell_variant.id }}"
                      >
                        <span class="lusena-btn__content" data-upsell-btn-text>Dodaj</span>
                        <span class="lusena-upsell-card__dots hidden" data-upsell-loading aria-hidden="true">
                          <span></span><span></span><span></span>
                        </span>
                      </button>
                    </div>
                  </div>
                </div>
              {%- endif -%}
            {%- endif -%}

          {%- endif -%}
        </div>
      </div>

      <p class="lusena-visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
      <p class="lusena-visually-hidden" id="shopping-cart-line-item-status" aria-live="polite" aria-hidden="true" role="status">
        Ładowanie...
      </p>
    </form>
  </div>
</cart-items>

{%- comment -%}
  Upsell add-to-cart - event delegation so it survives cart.js section re-renders.
  Bypasses product-form.js to avoid opening the drawer.
{%- endcomment -%}
<script>
  (function() {
    var container = document.getElementById('main-cart-items');
    if (!container) return;

    // Bundle nudge: click handler using shared LusenaBundle.swap()
    container.addEventListener('click', async function(e) {
      var btn = e.target.closest('[data-bundle-nudge-action]');
      if (!btn) return;

      var nudge = btn.closest('[data-bundle-nudge]');
      if (!nudge) return;

      btn.disabled = true;
      btn.classList.add('loading');
      var spinnerEl = btn.querySelector('.loading__spinner');
      if (spinnerEl) spinnerEl.classList.remove('hidden');

      var swapOpts = {};
      var triggerColor = nudge.dataset.triggerColor;
      var propertyMapRaw = nudge.dataset.propertyMap;
      if (triggerColor && propertyMapRaw) {
        try {
          var components = JSON.parse(propertyMapRaw);
          var props = {};
          var selectionParts = [];

          // Detect multi-pack: all components have identical value lists
          var isMultiPack = components.length > 1 && components.every(function(c) {
            return c.values.join(',') === components[0].values.join(',');
          });

          if (isMultiPack) {
            // Distribute unique colors: trigger first, then remaining unused
            var usedColors = [];
            components.forEach(function(comp, idx) {
              var color;
              if (idx === 0) {
                color = comp.values.indexOf(triggerColor) !== -1 ? triggerColor : comp.values[0];
              } else {
                color = comp.values.find(function(v) { return usedColors.indexOf(v) === -1; });
                if (!color) color = comp.values[0];
              }
              usedColors.push(color);
              props[comp.key] = color;
              selectionParts.push(color);
            });
          } else {
            // Complementary: match trigger color per component (fallback to first available)
            components.forEach(function(comp) {
              var color = comp.values.indexOf(triggerColor) !== -1 ? triggerColor : comp.values[0];
              props[comp.key] = color;
              selectionParts.push(color);
            });
          }

          props['_bundle_selection'] = selectionParts.join(' <> ');
          swapOpts.properties = props;
        } catch (e) { /* ignore parse errors */ }
      }

      try {
        await LusenaBundle.swap(nudge.dataset.bundleVariantId, [nudge.dataset.replaceKey], swapOpts);
        window.location.reload();
      } catch (err) {
        console.error('Bundle swap failed:', err);
        btn.disabled = false;
        btn.classList.remove('loading');
        if (spinnerEl) spinnerEl.classList.add('hidden');
      }
    });

    container.addEventListener('click', async function(e) {
      var btn = e.target.closest('[data-cart-page-upsell-add]');
      if (!btn || btn.disabled) return;

      btn.disabled = true;
      var btnText = btn.querySelector('[data-upsell-btn-text]');
      var dots = btn.querySelector('[data-upsell-loading]');
      if (btnText) btnText.classList.add('hidden');
      if (dots) dots.classList.remove('hidden');

      try {
        var addRes = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: [{ id: parseInt(btn.dataset.variantId), quantity: 1 }] })
        });
        if (!addRes.ok) throw new Error('Add failed');

        window.location.reload();
      } catch (err) {
        btn.disabled = false;
        if (btnText) btnText.classList.remove('hidden');
        if (dots) dots.classList.add('hidden');
      }
    });
  })();
</script>

{% stylesheet %}
  /* --- Section spacing - kill compact-tier bottom pad so footer bg creates the break --- */
  cart-items.lusena-spacing--compact {
    padding-top: 0;
    padding-bottom: 0;
  }
  /* Make <main> a flex column so cart content fills viewport and pushes
     the site footer below the fold on every screen size. */
  main:has(cart-items) {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
  }
  /* Mobile: grow the cart-items section so upsell sticks to footer bottom.
     Desktop: cart stays compact at top; remaining space is empty background. */
  @media (max-width: 767px) {
    main:has(cart-items) > .shopify-section:has(cart-items) {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    cart-items.lusena-spacing--compact {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    cart-items.lusena-spacing--compact > .lusena-container {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    cart-items.lusena-spacing--compact .lusena-cart-form {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    cart-items.lusena-spacing--compact #main-cart-items {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    cart-items.lusena-spacing--compact .js-contents {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .lusena-cart-upsell {
      margin-top: auto;
    }
  }

  /* --- Kill Dawn .cart__items border + padding (component-cart.css) --- */
  #main-cart-items.cart__items {
    border-bottom: none;
    padding-bottom: 0;
  }

  /* --- Cart header --- */
  .lusena-cart-header {
    padding-top: var(--lusena-space-2);
    padding-bottom: var(--lusena-space-2);
  }
  /* Mobile: tinted header zone matching drawer's header background */
  @media (max-width: 767px) {
    .lusena-cart-header {
      background-color: color-mix(in srgb, var(--lusena-surface-1) 50%, transparent);
      border-bottom: 1px solid color-mix(in srgb, var(--lusena-text-2) 10%, transparent);
      margin-left: calc(-1 * var(--lusena-space-2));
      margin-right: calc(-1 * var(--lusena-space-2));
      padding-left: var(--lusena-space-2);
      padding-right: var(--lusena-space-2);
    }
  }
  @media (min-width: 768px) {
    .lusena-cart-header { padding-top: var(--lusena-space-4); }
  }
  .lusena-cart-header__title {
    font-family: var(--lusena-font-brand);
    font-size: 2rem;
    line-height: 1.2;
    color: var(--lusena-text-1);
    margin: 0;
  }

  /* --- Empty state --- */
  cart-items:not(.is-empty) .lusena-cart-empty { display: none; }
  cart-items.is-empty .lusena-cart-form { display: none; }
  .lusena-cart-empty__login { margin-top: var(--lusena-space-4); }

  /* --- Item list --- */
  .lusena-cart-list {
    border-top: 1px solid color-mix(in srgb, var(--lusena-text-2) 10%, transparent);
  }
  /* Mobile: header border-bottom already provides the separator */
  @media (max-width: 767px) {
    .lusena-cart-list { border-top: none; }
  }

  /* --- Item row (flex, matches drawer) --- */
  /* Double-class to override Dawn's component-cart-items.css (.cart-item { display: table-row/grid }) */
  .lusena-cart-item.cart-item {
    display: flex;
    align-items: center;
    gap: var(--lusena-space-2);
    padding: var(--lusena-space-3) 0;
    border-bottom: 1px solid color-mix(in srgb, var(--lusena-text-2) 10%, transparent);
  }
  .lusena-cart-item.cart-item:last-child { border-bottom: 0; }

  /* --- Item image --- */
  .lusena-cart-item__media {
    display: block;
    width: 8rem;
    height: 9.6rem;
    background-color: var(--lusena-surface-2);
    border-radius: var(--lusena-radius-sm);
    overflow: hidden;
    flex-shrink: 0;
  }
  .lusena-cart-item__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* --- Item info column --- */
  .lusena-cart-item__info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-width: 0;
  }

  /* --- Top: name + price --- */
  .lusena-cart-item__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--lusena-space-1);
  }
  .lusena-cart-item__name-wrap { min-width: 0; }
  .lusena-cart-item__vendor {
    font-size: 1.2rem;
    color: var(--lusena-text-2);
    margin: 0 0 var(--lusena-space-05);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .lusena-cart-item__title {
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--lusena-text-1);
    line-height: 1.25;
    text-decoration: none;
    display: block;
  }
  .lusena-cart-item__title:hover { color: var(--lusena-accent-cta); }

  /* --- Prices (right side of top row) --- */
  .lusena-cart-item__prices {
    text-align: right;
    flex-shrink: 0;
  }
  .lusena-cart-item__price {
    display: block;
    font-size: 1.4rem;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
    color: var(--lusena-text-1);
  }
  .lusena-cart-item__compare-price {
    display: block;
    font-size: 1.2rem;
    color: var(--lusena-text-2);
    text-decoration: line-through;
  }

  /* --- Options (value-only, slash-separated) --- */
  .lusena-cart-item__options {
    font-size: 1.3rem;
    color: var(--lusena-text-2);
    margin: var(--lusena-space-05) 0 0;
  }

  /* --- Properties --- */
  .lusena-cart-item__property {
    font-size: 1.2rem;
    color: var(--lusena-text-2);
    margin: var(--lusena-space-05) 0 0;
  }
  .lusena-cart-item__upload-link {
    color: var(--lusena-accent-cta);
    text-decoration: underline;
  }

  /* --- Discounts --- */
  .lusena-cart-item__discounts {
    list-style: none;
    padding: 0;
    margin: var(--lusena-space-1) 0 0;
  }
  .lusena-cart-item__discount {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 1.2rem;
    color: var(--lusena-accent-cta);
    font-weight: 500;
  }
  .lusena-cart-item__discount-icon { display: flex; width: 1.4rem; height: 1.4rem; }
  .lusena-cart-item__discount-icon svg { width: 100%; height: 100%; }

  /* --- Bottom row (qty + remove) - handled by lusena-cart-quantity snippet --- */
  .lusena-cart-item__bottom {
    margin-top: var(--lusena-space-1);
  }

  /* --- Loading state --- */
  .cart__items--disabled { pointer-events: none; opacity: 0.5; }
  .loading__spinner { display: flex; align-items: center; justify-content: center; }
  .loading__spinner.hidden { display: none; }
  .loading__spinner svg { width: 2rem; height: 2rem; animation: lusena-spin 600ms linear infinite; }
  @keyframes lusena-spin { to { transform: rotate(360deg); } }

  /* === UPSELL ZONE (cart page) === */
  .lusena-cart-upsell :where(p) { margin: 0; }
  .lusena-cart-upsell .lusena-btn--size-xs { min-height: auto; }

  .lusena-cart-upsell {
    padding: var(--lusena-space-2);
    border-top: 1px solid color-mix(in srgb, var(--lusena-text-2) 10%, transparent);
    background-color: color-mix(in srgb, var(--lusena-surface-2) 50%, transparent);
    margin-left: calc(-1 * var(--lusena-space-2));
    margin-right: calc(-1 * var(--lusena-space-2));
  }
  @media (min-width: 768px) {
    .lusena-cart-upsell {
      margin-left: calc(-1 * var(--lusena-space-4));
      margin-right: calc(-1 * var(--lusena-space-4));
      padding-left: var(--lusena-space-4);
      padding-right: var(--lusena-space-4);
    }
  }

  .lusena-cart-upsell__label {
    font-family: var(--lusena-font-brand);
    font-size: 1.2rem;
    line-height: 1.4;
    color: var(--lusena-text-2);
    margin: 0 0 1rem;
  }

  /* --- Unified card container (same as drawer) --- */
  .lusena-upsell-card {
    padding: var(--lusena-space-2);
    background: var(--lusena-color-n0);
    border-radius: var(--lusena-btn-radius);
    border: 1px solid color-mix(in srgb, var(--lusena-text-2) 5%, transparent);
    box-shadow: 0 1px 2px rgba(0,0,0,0.03);
    border-left: 0.25rem solid color-mix(in srgb, var(--lusena-accent-cta) 40%, transparent);
  }

  /* --- Cross-sell card (horizontal) --- */
  .lusena-upsell-card__xs-row { display: flex; gap: 1.2rem; align-items: center; }
  .lusena-upsell-card__xs-img { width: 5.6rem; height: 5.6rem; background: var(--lusena-surface-2); border: 1px dashed color-mix(in srgb, var(--lusena-text-2) 20%, transparent); border-radius: var(--lusena-radius-sm); overflow: hidden; flex-shrink: 0; }
  .lusena-upsell-card__xs-img:empty { display: block; } /* override Dawn base.css div:empty { display:none } */
  .lusena-upsell-card__xs-img img { width: 100%; height: 100%; object-fit: cover; }
  .lusena-upsell-card__xs-info { flex: 1; min-width: 0; }
  .lusena-upsell-card__xs-title { font-size: 1.3rem; font-weight: 500; color: var(--lusena-text-1); line-height: 1.25; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .lusena-upsell-card__xs-msg { font-size: 1.15rem; color: var(--lusena-text-2); margin-top: var(--lusena-space-05); line-height: 1.375; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .lusena-upsell-card__xs-color { font-size: 1.05rem; line-height: 1.5; color: color-mix(in srgb, var(--lusena-text-2) 70%, transparent); margin-top: var(--lusena-space-05); }
  .lusena-upsell-card__xs-color span { color: var(--lusena-text-1); font-weight: 500; }
  .lusena-upsell-card__xs-bottom { display: flex; align-items: center; justify-content: space-between; gap: var(--lusena-space-1); margin-top: var(--lusena-space-1); padding-top: var(--lusena-space-1); border-top: 1px solid color-mix(in srgb, var(--lusena-text-2) 5%, transparent); }
  .lusena-upsell-card__xs-price { font-size: 1.4rem; font-weight: 500; color: var(--lusena-text-1); font-variant-numeric: tabular-nums; }

  /* --- Bundle card (two-tile) --- */
  .lusena-upsell-card__bn-headline { font-size: 1.35rem; font-weight: 500; color: var(--lusena-text-1); line-height: 1.35; margin-bottom: var(--lusena-space-1); }
  .lusena-upsell-card__bn-tiles { display: flex; gap: var(--lusena-space-1); align-items: stretch; }
  .lusena-upsell-card__bn-have { flex: 0 0 30%; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: var(--lusena-space-1) var(--lusena-space-05); border-radius: var(--lusena-radius-sm); background: color-mix(in srgb, var(--lusena-surface-2) 40%, transparent); }
  .lusena-upsell-card__bn-have-img { width: 3.8rem; height: 3.8rem; border-radius: 0.4rem; overflow: visible; margin-top: 0.7rem; margin-bottom: 0.5rem; position: relative; background: var(--lusena-surface-2); border: 1px dashed color-mix(in srgb, var(--lusena-text-2) 20%, transparent); }
  .lusena-upsell-card__bn-have-img img { width: 100%; height: 100%; object-fit: cover; opacity: 0.75; border-radius: 0.4rem; }
  .lusena-upsell-card__bn-check { position: absolute; top: -0.7rem; right: -0.7rem; width: 1.4rem; height: 1.4rem; background: var(--lusena-accent-cta); border-radius: 50%; display: flex; align-items: center; justify-content: center; opacity: 1; }
  .lusena-upsell-card__bn-check svg { width: 0.8rem; height: 0.8rem; color: #fff; }
  .lusena-upsell-card__bn-have-name { font-size: 1rem; font-weight: 500; color: #888; line-height: 1.2; }
  .lusena-upsell-card__bn-have-status { font-size: 0.9rem; color: var(--lusena-accent-cta); margin-top: 0.2rem; font-weight: 500; }
  .lusena-upsell-card__bn-plus { font-size: 1.6rem; color: var(--lusena-text-2); font-weight: 400; flex-shrink: 0; align-self: center; }
  .lusena-upsell-card__bn-add { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: var(--lusena-space-1); border-radius: var(--lusena-radius-sm); background: color-mix(in srgb, var(--lusena-surface-2) 50%, transparent); border: 1px solid color-mix(in srgb, var(--lusena-text-2) 6%, transparent); }
  .lusena-upsell-card__bn-add-img { width: 5.6rem; height: 5.6rem; border-radius: var(--lusena-radius-sm); overflow: hidden; margin-bottom: 0.6rem; background: var(--lusena-surface-2); border: 1px dashed color-mix(in srgb, var(--lusena-text-2) 20%, transparent); }
  .lusena-upsell-card__bn-add-img:empty { display: block; } /* override Dawn base.css div:empty { display:none } */
  .lusena-upsell-card__bn-add-img img { width: 100%; height: 100%; object-fit: cover; }
  .lusena-upsell-card__bn-add-name { font-size: 1.2rem; font-weight: 500; color: var(--lusena-text-1); line-height: 1.25; }
  .lusena-upsell-card__bn-bottom { display: flex; align-items: center; justify-content: space-between; gap: var(--lusena-space-1); margin-top: var(--lusena-space-1); padding-top: var(--lusena-space-1); border-top: 1px solid color-mix(in srgb, var(--lusena-text-2) 5%, transparent); }
  .lusena-upsell-card__bn-pricing { display: flex; align-items: baseline; gap: 0.6rem; flex-wrap: wrap; }
  .lusena-upsell-card__bn-price { font-size: 1.4rem; font-weight: 500; color: var(--lusena-text-1); font-variant-numeric: tabular-nums; }
  .lusena-upsell-card__bn-was { font-size: 1.4rem; color: var(--lusena-text-2); text-decoration: line-through; }

  /* --- Cross-sell loading dots (cart page specific) --- */
  .lusena-upsell-card__dots { display: inline-flex; gap: 0.3rem; align-items: center; justify-content: center; }
  .lusena-upsell-card__dots.hidden { display: none; }
  .lusena-upsell-card__dots span { width: 0.4rem; height: 0.4rem; border-radius: 50%; background: currentColor; animation: lusena-dot-pulse 1.2s infinite ease-in-out; }
  .lusena-upsell-card__dots span:nth-child(2) { animation-delay: 0.2s; }
  .lusena-upsell-card__dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes lusena-dot-pulse {
    0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
    40% { opacity: 1; transform: scale(1); }
  }

  /* --- Responsive - desktop image larger for page proportions --- */
  @media (min-width: 768px) {
    .lusena-cart-header__title { font-size: 3.2rem; }
    .lusena-cart-item__media { width: 10rem; height: 12rem; }
    /* Constrain card + label width, right-align, remove accent border */
    .lusena-cart-upsell .lusena-cart-upsell__label { max-width: 42rem; margin-left: auto; }
    .lusena-cart-upsell .lusena-upsell-card { max-width: 42rem; margin-left: auto; border-left: none; }
  }
{% endstylesheet %}

