{%- comment -%}
  Upsell add-to-cart - event delegation so it survives cart.js section re-renders.
  Bypasses product-form.js to avoid opening the drawer.
{%- endcomment -%}
<script>
  (function() {
    var container = document.getElementById('main-cart-items');
    if (!container) return;

    // Section re-render config (mirrors cart.js getSectionsToRender).
    // Footer is looked up lazily because it renders AFTER this section.
    var cartItemsSection = container.dataset.id;

    function getFooterSection() {
      var el = document.getElementById('main-cart-footer');
      return el ? el.dataset.id : null;
    }

    function getSectionNames() {
      return [cartItemsSection, 'cart-icon-bubble', 'cart-live-region-text', getFooterSection()].filter(Boolean);
    }

    function getSectionConfigs() {
      var configs = [
        { id: 'main-cart-items', section: cartItemsSection, selector: '.js-contents' },
        { id: 'cart-icon-bubble', section: 'cart-icon-bubble', selector: '.shopify-section' },
        { id: 'cart-live-region-text', section: 'cart-live-region-text', selector: '.shopify-section' }
      ];
      var footerSection = getFooterSection();
      if (footerSection) {
        configs.push({ id: 'main-cart-footer', section: footerSection, selector: '.js-contents' });
      }
      return configs;
    }

    function reRenderSections(state) {
      if (!state || !state.sections) return;
      if (typeof state.item_count === 'number') {
        var cartItemsEl = document.querySelector('cart-items');
        var footerEl = document.getElementById('main-cart-footer');
        if (cartItemsEl) cartItemsEl.classList.toggle('is-empty', state.item_count === 0);
        if (footerEl) footerEl.classList.toggle('is-empty', state.item_count === 0);
      }
      getSectionConfigs().forEach(function(cfg) {
        var html = state.sections[cfg.section];
        if (!html) return;
        var el = document.getElementById(cfg.id);
        if (!el) return;
        var target = el.querySelector(cfg.selector) || el;
        var doc = new DOMParser().parseFromString(html, 'text/html');
        var source = doc.querySelector(cfg.selector);
        if (source) target.innerHTML = source.innerHTML;
      });
      if (typeof publish === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
        publish(PUB_SUB_EVENTS.cartUpdate, { source: 'cart-items', cartData: state });
      }
    }

    // Bundle nudge: click handler using shared LusenaBundle.swap()
    container.addEventListener('click', async function(e) {
      var btn = e.target.closest('[data-bundle-nudge-action]');
      if (!btn) return;

      var nudge = btn.closest('[data-bundle-nudge]');
      if (!nudge) return;

      btn.disabled = true;
      btn.classList.add('loading');
      var spinnerEl = btn.querySelector('.loading__spinner');
      if (spinnerEl) spinnerEl.classList.remove('hidden');

      var swapOpts = {
        sections: getSectionNames(),
        sectionsUrl: window.location.pathname
      };
      // Merge path: pre-filled properties + multiple replace keys
      var removeKeys;
      if (nudge.dataset.replaceKeys) {
        removeKeys = JSON.parse(nudge.dataset.replaceKeys);
        if (nudge.dataset.properties) {
          try { swapOpts.properties = JSON.parse(nudge.dataset.properties); } catch(e) {}
        }
      } else {
        // Existing nudge path: single replace key + color matching
        removeKeys = [nudge.dataset.replaceKey];
        var triggerColor = nudge.dataset.triggerColor;
        var propertyMapRaw = nudge.dataset.propertyMap;
        if (triggerColor && propertyMapRaw) {
          try {
            var components = JSON.parse(propertyMapRaw);
            var props = {};
            var selectionParts = [];

            // Detect multi-pack: all components have identical value lists
            var isMultiPack = components.length > 1 && components.every(function(c) {
              return c.values.join(',') === components[0].values.join(',');
            });

            if (isMultiPack) {
              // Distribute unique colors: trigger first, then remaining unused
              var usedColors = [];
              components.forEach(function(comp, idx) {
                var color;
                if (idx === 0) {
                  color = comp.values.indexOf(triggerColor) !== -1 ? triggerColor : comp.values[0];
                } else {
                  color = comp.values.find(function(v) { return usedColors.indexOf(v) === -1; });
                  if (!color) color = comp.values[0];
                }
                usedColors.push(color);
                props[comp.key] = color;
                selectionParts.push(color);
              });
            } else {
              // Complementary: match trigger color per component (fallback to first available)
              components.forEach(function(comp) {
                var color = comp.values.indexOf(triggerColor) !== -1 ? triggerColor : comp.values[0];
                props[comp.key] = color;
                selectionParts.push(color);
              });
            }

            props['_bundle_selection'] = selectionParts.join(' <> ');
            swapOpts.properties = props;
          } catch (e) { /* ignore parse errors */ }
        }
      }

      try {
        var state = await LusenaBundle.swap(nudge.dataset.bundleVariantId, removeKeys, swapOpts);
        reRenderSections(state);
        // Direct drawer sync (belt-and-suspenders — don't rely solely on pubsub)
        fetch(routes.cart_url + '?section_id=cart-drawer')
          .then(function(r) { return r.text(); })
          .then(function(html) {
            var doc = new DOMParser().parseFromString(html, 'text/html');
            var fresh = doc.querySelector('#CartDrawer');
            var current = document.getElementById('CartDrawer');
            if (fresh && current) current.innerHTML = fresh.innerHTML;
            var drawerEl = document.querySelector('cart-drawer');
            if (drawerEl) drawerEl.classList.toggle('is-empty', !doc.querySelector('[data-cart-item]'));
          })
          .catch(function() {});
      } catch (err) {
        console.error('Bundle swap failed:', err);
        btn.disabled = false;
        btn.classList.remove('loading');
        if (spinnerEl) spinnerEl.classList.add('hidden');
      }
    });

    container.addEventListener('click', async function(e) {
      var btn = e.target.closest('[data-cart-page-upsell-add]');
      if (!btn || btn.disabled) return;

      btn.disabled = true;
      var btnText = btn.querySelector('[data-upsell-btn-text]');
      var dots = btn.querySelector('[data-upsell-loading]');
      if (btnText) btnText.classList.add('hidden');
      if (dots) dots.classList.remove('hidden');

      try {
        var addRes = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            items: [{ id: parseInt(btn.dataset.variantId), quantity: 1 }],
            sections: getSectionNames(),
            sections_url: window.location.pathname
          })
        });
        if (!addRes.ok) throw new Error('Add failed');
        var state = await addRes.json();
        reRenderSections(state);
      } catch (err) {
        btn.disabled = false;
        if (btnText) btnText.classList.remove('hidden');
        if (dots) dots.classList.add('hidden');
      }
    });

    // Override cart-items.onCartUpdate() to do a full re-render (items + footer + empty state).
    // The default in cart.js only replaces <cart-items> innerHTML — misses footer and is-empty toggle.
    var cartItemsEl = document.querySelector('cart-items');
    if (cartItemsEl) {
      cartItemsEl.onCartUpdate = function() {
        var self = this;
        return fetch(routes.cart_url + '?sections=' + getSectionNames().join(','))
          .then(function(r) { return r.json(); })
          .then(function(sections) {
            var itemsHtml = sections[cartItemsSection];
            if (itemsHtml) {
              var doc = new DOMParser().parseFromString(itemsHtml, 'text/html');
              var freshEl = doc.querySelector('cart-items');
              var isEmpty = freshEl ? freshEl.classList.contains('is-empty') : false;
              self.classList.toggle('is-empty', isEmpty);
              var footerEl = document.getElementById('main-cart-footer');
              if (footerEl) footerEl.classList.toggle('is-empty', isEmpty);
            }
            getSectionConfigs().forEach(function(cfg) {
              var html = sections[cfg.section];
              if (!html) return;
              var el = document.getElementById(cfg.id);
              if (!el) return;
              var target = el.querySelector(cfg.selector) || el;
              var doc = new DOMParser().parseFromString(html, 'text/html');
              var source = doc.querySelector(cfg.selector);
              if (source) target.innerHTML = source.innerHTML;
            });
          })
          .catch(function(e) { console.error(e); });
      };

    }
  })();
</script>

