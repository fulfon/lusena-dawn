{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-brand lusena-quality-fire-test lusena-spacing--standard"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container lusena-text-center">
    <h2 class="lusena-type-h1 lusena-gap-section-intro{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {{ section.settings.fire_heading | escape }}
    </h2>

    <div class="lusena-quality-fire-test__video-wrap lusena-gap-body{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- if section.settings.fire_video != blank -%}
        {{
          section.settings.fire_video
          | video_tag:
            controls: true,
            preload: 'metadata',
            class: 'lusena-quality-fire-test__video'
        }}
      {%- else -%}
        <span class="lusena-quality-fire-test__placeholder">
          {{ section.settings.fire_video_placeholder | escape }}
        </span>
      {%- endif -%}
    </div>

    <p class="lusena-type-body lusena-quality-fire-test__body{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {{ section.settings.fire_body | escape }}
    </p>
  </div>
</section>

{% stylesheet %}
  /* Video wrap */
  .lusena-quality-fire-test__video-wrap {
    max-width: 76.8rem;
    margin-inline: auto;
    background-color: rgba(0, 0, 0, 0.05);
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.2rem;
    border: 1px solid rgba(0, 0, 0, 0.1);
    overflow: hidden;
  }

  .lusena-quality-fire-test__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lusena-quality-fire-test__placeholder {
    color: var(--lusena-text-2);
    font-weight: 300;
    text-align: center;
    padding-inline: var(--lusena-space-3);
  }

  /* Body max-width centering + contrast on cream — 0-2-0 to beat foundations */
  .lusena-quality-fire-test .lusena-quality-fire-test__body {
    max-width: 64rem;
    margin-inline: auto;
    color: var(--lusena-text-1);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Quality: Fire test",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "fire_heading",
      "label": "Fire heading",
      "default": "Test Ognia (The Fire Test)"
    },
    {
      "type": "video",
      "id": "fire_video",
      "label": "Fire video"
    },
    {
      "type": "text",
      "id": "fire_video_placeholder",
      "label": "Fire video placeholder",
      "default": "Video Placeholder: Test spalania nitki jedwabiu"
    },
    {
      "type": "text",
      "id": "fire_body",
      "label": "Fire body",
      "default": "Prawdziwy jedwab po spaleniu pachnie jak pieczone włosy i zamienia się w sypki popiół. Poliester topi się w twardą kulkę. Nie mamy nic do ukrycia."
    }
  ],
  "presets": [
    {
      "name": "LUSENA Quality: Fire test"
    }
  ]
}
{% endschema %}
