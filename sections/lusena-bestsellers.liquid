{%- liquid
  assign collection = section.settings.collection
  assign limit = section.settings.products_to_show | default: 3

  assign view_all_url = routes.all_products_collection_url
  if collection != blank
    assign view_all_url = collection.url
  endif
-%}

{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}
<section
  class="lusena-bg-surface-1 lusena-bestsellers lusena-spacing--spacious"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container">
    <div class="lusena-bestsellers__header lusena-gap-section-intro{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div class="lusena-content-flow--tight">
        <h2 class="lusena-type-h1">
          {{ section.settings.heading | escape }}
        </h2>
        {%- if section.settings.subheading != blank -%}
          <p class="lusena-type-body">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.view_all_label != blank -%}
        <a href="{{ view_all_url }}" class="lusena-bestsellers__view-all lusena-hide-mobile">
          {{ section.settings.view_all_label | escape }}
        </a>
      {%- endif -%}
    </div>

    <div class="lusena-bestsellers__grid">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: limit -%}
          {%- liquid
            assign badge = ''
            assign tags_downcase = product.tags | join: ',' | downcase

            if tags_downcase contains 'bestseller'
              assign badge = 'Bestseller'
            elsif tags_downcase contains 'new'
              assign badge = 'New'
            endif
          -%}
          <div
            {% if settings.animations_reveal_on_scroll %}
              class="scroll-trigger animate--slide-in"
              data-cascade
            {% endif %}
          >
            {% render 'lusena-product-card', product: product, badge: badge, show_secondary_image: true %}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <div
            class="lusena-bestsellers__placeholder{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
            {% endif %}
          >
            <div class="lusena-bestsellers__placeholder-image"></div>
            <div class="lusena-bestsellers__placeholder-text">
              <div class="lusena-bestsellers__placeholder-line lusena-bestsellers__placeholder-line--long"></div>
              <div class="lusena-bestsellers__placeholder-line lusena-bestsellers__placeholder-line--short"></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.view_all_mobile_label != blank -%}
      <div class="lusena-text-center lusena-hide-desktop lusena-gap-cta-top{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <a href="{{ view_all_url }}" class="lusena-bestsellers__mobile-cta">
          {{ section.settings.view_all_mobile_label | escape }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  /* Foundations handles: .lusena-type-h1, .lusena-type-body for heading/subheading. */

  .lusena-bestsellers {
    border-top: 1px solid var(--lusena-color-n200);
  }

  /* Header: heading left, view-all right */
  .lusena-bestsellers__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  /* View-all link (kicker-style: uppercase, small, weighted) */
  .lusena-bestsellers__view-all {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    font-size: 1.4rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--lusena-text-1);
    text-decoration: none;
    text-underline-offset: 4px;
    transition: color var(--lusena-transition-fast);
  }

  .lusena-bestsellers__view-all:hover {
    text-decoration: underline;
  }

  /* Product grid: 2-col mobile → 3-col desktop */
  .lusena-bestsellers__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--lusena-space-8) var(--lusena-space-4);
  }

  @media (min-width: 1024px) {
    .lusena-bestsellers__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Mobile CTA ghost button (editorial: no border-radius) */
  .lusena-bestsellers__mobile-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    font-size: 1.4rem;
    font-weight: 500;
    height: var(--lusena-space-6);
    padding: 0 var(--lusena-space-4);
    width: 100%;
    border: 1px solid var(--lusena-accent-cta);
    border-radius: var(--lusena-btn-radius);
    background: transparent;
    color: var(--lusena-accent-cta);
    text-decoration: none;
    transition: background-color var(--lusena-transition-fast);
  }

  .lusena-bestsellers__mobile-cta:hover {
    background-color: rgba(14, 94, 90, 0.05);
  }

  .lusena-bestsellers__mobile-cta:focus-visible {
    outline: 2px solid var(--lusena-accent-cta);
    outline-offset: 2px;
  }

  /* Placeholders */
  .lusena-bestsellers__placeholder {
    cursor: pointer;
  }

  .lusena-bestsellers__placeholder-image {
    aspect-ratio: 4 / 5;
    background-color: var(--lusena-surface-2);
    overflow: hidden;
    margin-bottom: var(--lusena-space-4);
  }

  .lusena-bestsellers__placeholder-text {
    display: flex;
    flex-direction: column;
    gap: var(--lusena-space-05);
  }

  .lusena-bestsellers__placeholder-line {
    height: 16px;
    background-color: var(--lusena-surface-2);
  }

  .lusena-bestsellers__placeholder-line--long {
    width: 75%;
  }

  .lusena-bestsellers__placeholder-line--short {
    width: 50%;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Bestsellers",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Bestsellers"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Loved by over 12,000 sleepers."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label (desktop)",
      "default": "View all products"
    },
    {
      "type": "text",
      "id": "view_all_mobile_label",
      "label": "View all label (mobile)",
      "default": "View all products"
    }
  ],
  "presets": [
    {
      "name": "LUSENA Bestsellers",
      "settings": {
        "collection": "all"
      }
    }
  ]
}
{% endschema %}
