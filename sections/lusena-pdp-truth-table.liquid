{%- liquid
  assign has_rows = false
  for block in section.blocks
    if block.type == 'row'
      assign has_rows = true
      break
    endif
  endfor
-%}

{%- if has_rows -%}
  {%- liquid
    assign override_style = ''
    if section.settings.padding_top > 0
      assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
    endif
    if section.settings.padding_bottom > 0
      assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
    endif
    if section.settings.padding_top_mobile > 0
      assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
    endif
    if section.settings.padding_bottom_mobile > 0
      assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
    endif
  -%}

  <section
    class="lusena-bg-brand lusena-spacing--standard"
    {% if override_style != blank %}
      style="{{ override_style }}"
    {% endif %}
  >
    <div class="lusena-container--narrow lusena-text-center lusena-content-flow--tight lusena-gap-section-intro{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <h2 class="lusena-type-h1">
        {{ section.settings.heading | escape }}
      </h2>
      {%- if section.settings.subheading != blank -%}
        <p class="lusena-type-body">
          {{ section.settings.subheading | escape }}
        </p>
      {%- endif -%}
    </div>

    <div class="lusena-container--narrow">
      {%- comment -%} Desktop table (visible ≥1024px) {%- endcomment -%}
      <div class="lusena-truth-table__table-wrap{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <table class="lusena-truth-table__table" aria-label="{{ section.settings.heading | escape }}">
          <thead>
            <tr>
              <th scope="col">{{ section.settings.metric_label | escape }}</th>
              <th scope="col">{{ section.settings.lusena_label | escape }}</th>
              <th scope="col">{{ section.settings.others_label | escape }}</th>
            </tr>
          </thead>
          <tbody{% if settings.animations_reveal_on_scroll %} data-cascade{% endif %}>
            {%- for block in section.blocks -%}
              {%- if block.type == 'row' -%}
                <tr class="{% if settings.animations_reveal_on_scroll %}scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }}>
                  <th scope="row">{{ block.settings.metric | escape }}</th>
                  <td>
                    <span class="lusena-truth-table__value lusena-truth-table__value--lusena">
                      <svg class="lusena-truth-table__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="m9 12 2 2 4-4"/>
                      </svg>
                      <span>{{ block.settings.lusena_value | escape }}</span>
                    </span>
                  </td>
                  <td>
                    <span class="lusena-truth-table__value lusena-truth-table__value--others">
                      <svg class="lusena-truth-table__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="m15 9-6 6"/>
                        <path d="m9 9 6 6"/>
                      </svg>
                      <span>{{ block.settings.others_value | escape }}</span>
                    </span>
                  </td>
                </tr>
              {%- endif -%}
            {%- endfor -%}
          </tbody>
        </table>
      </div>

      {%- comment -%} Mobile cards (visible <1024px) {%- endcomment -%}
      <div class="lusena-truth-table__cards"{% if settings.animations_reveal_on_scroll %} data-cascade{% endif %}>
        {%- for block in section.blocks -%}
          {%- if block.type == 'row' -%}
            <article class="lusena-truth-table__card{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" {{ block.shopify_attributes }}>
              <h3 class="lusena-truth-table__card-metric">{{ block.settings.metric | escape }}</h3>
              <div class="lusena-truth-table__card-line lusena-truth-table__card-line--lusena">
                <span class="lusena-truth-table__card-label lusena-truth-table__card-label--lusena">{{ section.settings.lusena_label | escape }}</span>
                <span class="lusena-truth-table__value lusena-truth-table__value--lusena">
                  <svg class="lusena-truth-table__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="m9 12 2 2 4-4"/>
                  </svg>
                  <span>{{ block.settings.lusena_value | escape }}</span>
                </span>
              </div>
              <div class="lusena-truth-table__card-line">
                <span class="lusena-truth-table__card-label">{{ section.settings.others_label | escape }}</span>
                <span class="lusena-truth-table__value lusena-truth-table__value--others">
                  <svg class="lusena-truth-table__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="m15 9-6 6"/>
                    <path d="m9 9 6 6"/>
                  </svg>
                  <span>{{ block.settings.others_value | escape }}</span>
                </span>
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.footer_note != blank -%}
        <p class="lusena-truth-table__note{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{ section.settings.footer_note | escape }}
        </p>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "LUSENA PDP Truth Table",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Jedwab vs satyna"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Satyna to marketingowa nazwa poliestru. Porównaj fakty."
    },
    {
      "type": "text",
      "id": "metric_label",
      "label": "Table heading: metric",
      "default": "Porównanie"
    },
    {
      "type": "text",
      "id": "lusena_label",
      "label": "Table heading: LUSENA",
      "default": "LUSENA"
    },
    {
      "type": "text",
      "id": "others_label",
      "label": "Table heading: others",
      "default": "Inne opcje"
    },
    {
      "type": "textarea",
      "id": "footer_note",
      "label": "Footer note"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison row",
      "settings": [
        {
          "type": "text",
          "id": "metric",
          "label": "Metric",
          "default": "Materiał"
        },
        {
          "type": "textarea",
          "id": "lusena_value",
          "label": "LUSENA value",
          "default": "100% jedwab morwowy 22 momme (klasa 6A), certyfikowany OEKO-TEX Standard 100."
        },
        {
          "type": "textarea",
          "id": "others_value",
          "label": "Other value",
          "default": "Najczęściej satyna poliestrowa lub mieszanki bez transparentnej specyfikacji."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LUSENA PDP Truth Table",
      "settings": {
        "heading": "Jedwab vs satyna",
        "subheading": "Satyna to marketingowa nazwa poliestru. Porównaj fakty.",
        "metric_label": "Cecha",
        "lusena_label": "Jedwab LUSENA",
        "others_label": "Satyna (Poliester)"
      },
      "blocks": [
        {
          "type": "row",
          "settings": {
            "metric": "Materiał",
            "lusena_value": "100% naturalny jedwab morwowy (włókno białkowe).",
            "others_value": "Syntetyczny poliester (włókno sztuczne)."
          }
        },
        {
          "type": "row",
          "settings": {
            "metric": "Oddychalność",
            "lusena_value": "Termoregulacyjny i przewiewny. Skóra oddycha przez całą noc.",
            "others_value": "Zatrzymuje ciepło i wilgoć, co sprzyja poceniu się."
          }
        },
        {
          "type": "row",
          "settings": {
            "metric": "Wpływ na skórę i włosy",
            "lusena_value": "Redukuje tarcie, chroni przed zagnieceniami i puszeniem.",
            "others_value": "Może elektryzować włosy i podrażniać wrażliwą cerę."
          }
        }
      ]
    }
  ]
}
{% endschema %}
