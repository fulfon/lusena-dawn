{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif

  assign certificate_url = blank
  assign certificate_label = section.settings.hero_button_label
  if certificate_label == blank
    assign certificate_label = 'Pobierz certyfikat OEKO-TEX (PDF)'
  endif

  if shop.metafields.lusena.oeko_tex_certificate != blank
    assign certificate_file = shop.metafields.lusena.oeko_tex_certificate.value
    if certificate_file != blank
      if certificate_file.url != blank
        assign certificate_url = certificate_file.url
      endif
    endif
  endif

  if certificate_url == blank
    if section.settings.hero_button_link != blank
      assign certificate_url = section.settings.hero_button_link
    endif
  endif
-%}
<section
  class="lusena-bg-brand lusena-quality-hero lusena-spacing--hero lusena-spacing--snug-top"
  {% if override_style != blank %}
    style="{{ override_style }}"
  {% endif %}
>
  <div class="lusena-container--narrow lusena-text-center lusena-content-flow{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    <div class="lusena-content-flow--tight">
      <span class="lusena-kicker lusena-quality-hero__kicker">
        {{ section.settings.hero_kicker | escape }}
      </span>
      <h1 class="lusena-type-hero">
        {{ section.settings.hero_heading | newline_to_br }}
      </h1>
    </div>
    <p class="lusena-type-body lusena-quality-hero__body">
      {{ section.settings.hero_body | escape }}
    </p>

    <div class="lusena-gap-cta-top lusena-quality-hero__actions">
      {%- if section.settings.hero_cta_link != blank -%}
        <a
          href="{{ section.settings.hero_cta_link }}"
          {% if section.settings.hero_cta_link contains 'http' %}
            target="_blank"
            rel="noopener"
          {% endif %}
          class="lusena-btn lusena-btn--primary lusena-btn--size-default"
        >
          <span class="lusena-link-arrow">{{ section.settings.hero_cta_label | escape }}</span>
        </a>
      {%- endif -%}

      {%- if certificate_url != blank -%}
        <a
          href="{{ certificate_url }}"
          {% if certificate_url contains 'http' %}
            target="_blank"
            rel="noopener"
          {% endif %}
          class="lusena-quality-hero__cert-link"
        >
          {{ certificate_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .lusena-quality-hero .lusena-quality-hero__kicker {
    color: var(--lusena-accent-2);
  }

  .lusena-quality-hero .lusena-quality-hero__body {
    max-width: 64rem;
    margin-inline: auto;
    color: var(--lusena-text-1);
  }

  .lusena-quality-hero__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--lusena-space-3);
  }

  .lusena-quality-hero__cert-link {
    font-size: 1.4rem;
    color: var(--lusena-accent-cta);
    text-decoration: underline;
    text-underline-offset: 0.3rem;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
  }

  @media (hover: hover) {
    .lusena-quality-hero__cert-link:hover {
      color: var(--lusena-accent-cta-hover);
      text-decoration: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Quality: Hero",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "text",
      "id": "hero_kicker",
      "label": "Hero kicker",
      "default": "Nasza jakość"
    },
    {
      "type": "textarea",
      "id": "hero_heading",
      "label": "Hero heading",
      "default": "Nie wierz nam na słowo.\nSprawdź."
    },
    {
      "type": "text",
      "id": "hero_body",
      "label": "Hero body",
      "default": "Jedwab LUSENA to 22 momme czystej perfekcji. Stworzony w Suzhou, kontrolowany w Polsce. Poczuj różnicę, której nie da się podrobić."
    },
    {
      "type": "text",
      "id": "hero_cta_label",
      "label": "Primary CTA label",
      "default": "Zobacz kolekcję"
    },
    {
      "type": "url",
      "id": "hero_cta_link",
      "label": "Primary CTA link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "hero_button_label",
      "label": "Certificate link label",
      "default": "Pobierz certyfikat OEKO-TEX (PDF)"
    },
    {
      "type": "url",
      "id": "hero_button_link",
      "label": "Certificate link (fallback)",
      "info": "Preferowane: metafield sklepu `lusena.oeko_tex_certificate` (file_reference). Jeżeli metafield jest pusty, użyty zostanie ten link (np. `#certificates`)."
    }
  ],
  "presets": [
    {
      "name": "LUSENA Quality: Hero"
    }
  ]
}
{% endschema %}
