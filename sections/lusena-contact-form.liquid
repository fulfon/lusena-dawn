{%- liquid
  assign override_style = ''
  if section.settings.padding_top > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-desktop:' | append: section.settings.padding_top | append: 'px;'
  endif
  if section.settings.padding_bottom > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-desktop:' | append: section.settings.padding_bottom | append: 'px;'
  endif
  if section.settings.padding_top_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-top-mobile:' | append: section.settings.padding_top_mobile | append: 'px;'
  endif
  if section.settings.padding_bottom_mobile > 0
    assign override_style = override_style | append: '--lusena-section-padding-bottom-mobile:' | append: section.settings.padding_bottom_mobile | append: 'px;'
  endif
-%}

<section
  class="lusena-contact-form lusena-bg-surface-1 lusena-spacing--compact"
  {% if override_style != blank %}style="{{ override_style }}"{% endif %}
>
  <div class="lusena-container--narrow">
    {%- if section.settings.show_breadcrumbs -%}
      {% render 'lusena-breadcrumbs', page_type: 'page', page: page, breadcrumb_label: 'Kontakt' %}
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="lusena-page-header__title lusena-contact-form__heading{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.heading | escape }}
      </h1>
    {%- endif -%}

    {%- if section.settings.contact_info != blank -%}
      <p class="lusena-type-body lusena-contact-form__info{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.contact_info | escape }}
      </p>
    {%- endif -%}

    {%- liquid
      assign form_class = 'lusena-form'
      if settings.animations_reveal_on_scroll
        assign form_class = form_class | append: ' scroll-trigger animate--slide-in'
      endif
    -%}
    {%- form 'contact', id: 'ContactForm', class: form_class -%}

      {%- if form.posted_successfully? -%}
        <div class="lusena-form-msg lusena-form-msg--success" role="status" tabindex="-1" autofocus>
          {%- render 'lusena-icon', name: 'check', class: 'lusena-contact-form__msg-icon' -%}
          {{ 'templates.contact.form.post_success' | t }}
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="lusena-form-msg lusena-form-msg--error" role="alert" tabindex="-1" autofocus>
          {{ 'templates.contact.form.error_heading' | t }}
        </div>
      {%- endif -%}

      {%- unless form.posted_successfully? -%}
        {%- comment -%} Name + Email row (side by side on desktop) {%- endcomment -%}
        <div class="lusena-form__row">
          <div class="lusena-form__field">
            <label class="lusena-form__label" for="ContactForm-name">
              {{ 'templates.contact.form.name' | t }}
            </label>
            <input
              class="lusena-input"
              autocomplete="name"
              type="text"
              id="ContactForm-name"
              name="contact[{{ 'templates.contact.form.name' | t }}]"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              placeholder="{{ 'templates.contact.form.name' | t }}"
            >
          </div>

          <div class="lusena-form__field">
            <label class="lusena-form__label lusena-form__label--required" for="ContactForm-email">
              {{ 'templates.contact.form.email' | t }}
            </label>
            <input
              class="lusena-input{% if form.errors contains 'email' %} lusena-input--error{% endif %}"
              autocomplete="email"
              type="email"
              id="ContactForm-email"
              name="contact[email]"
              spellcheck="false"
              autocapitalize="off"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              aria-required="true"
              {% if form.errors contains 'email' %}
                aria-invalid="true"
                aria-describedby="ContactForm-email-error"
              {% endif %}
              placeholder="{{ 'templates.contact.form.email' | t }}"
            >
            {%- if form.errors contains 'email' -%}
              <div class="lusena-form-msg lusena-form-msg--error" id="ContactForm-email-error">
                {{ form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email }}
              </div>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} Phone (full width) {%- endcomment -%}
        <div class="lusena-form__field">
          <label class="lusena-form__label" for="ContactForm-phone">
            {{ 'templates.contact.form.phone' | t }}
          </label>
          <input
            class="lusena-input"
            type="tel"
            id="ContactForm-phone"
            autocomplete="tel"
            name="contact[{{ 'templates.contact.form.phone' | t }}]"
            value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
            placeholder="{{ 'templates.contact.form.phone' | t }}"
          >
        </div>

        {%- comment -%} Message (textarea) {%- endcomment -%}
        <div class="lusena-form__field">
          <label class="lusena-form__label" for="ContactForm-body">
            {{ 'templates.contact.form.comment' | t }}
          </label>
          <textarea
            class="lusena-input"
            rows="6"
            id="ContactForm-body"
            name="contact[{{ 'templates.contact.form.comment' | t }}]"
            placeholder="{{ 'templates.contact.form.comment' | t }}"
          >
            {{- form.body -}}
          </textarea>
        </div>

        {%- comment -%} Submit {%- endcomment -%}
        <div class="lusena-form__actions">
          <button
            type="submit"
            class="lusena-btn lusena-btn--primary lusena-btn--size-default"
          >
            {{ 'templates.contact.form.send' | t }}
          </button>
        </div>
      {%- endunless -%}

    {%- endform -%}
  </div>
</section>

{% stylesheet %}
  /* Push footer below fold on tall screens.
     The newsletter section (surface-2) grows to fill extra space,
     so the extra padding shares the same gray background — no color break. */
  main:has(.lusena-contact-form) {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
  }
  main:has(.lusena-contact-form) > .shopify-section:has(.lusena-contact-form) {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  main:has(.lusena-contact-form) > .shopify-section:has(.lusena-contact-form) > .lusena-contact-form {
    flex: 1;
  }

  /* Tighter top padding on mobile */
  @media (max-width: 767px) {
    .lusena-contact-form.lusena-spacing--compact { padding-top: var(--lusena-space-2); }
  }

  /* Heading spacing */
  .lusena-contact-form .lusena-contact-form__heading {
    margin-bottom: var(--lusena-space-2);
  }
  /* Info text spacing */
  .lusena-contact-form .lusena-contact-form__info {
    margin-bottom: var(--lusena-space-4);
  }
  /* Full-width submit button on mobile */
  @media (max-width: 767px) {
    .lusena-contact-form .lusena-form__actions .lusena-btn { width: 100%; }
  }
  /* Message icon */
  .lusena-contact-form .lusena-contact-form__msg-icon {
    width: 1.8rem;
    height: 1.8rem;
    flex-shrink: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LUSENA Kontakt",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Napisz do nas"
    },
    {
      "type": "textarea",
      "id": "contact_info",
      "label": "Contact info text",
      "default": "Odpowiadamy w ciągu 24 godzin w dni robocze."
    },
    {
      "type": "header",
      "content": "Spacing overrides (0 = use global default)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "LUSENA Kontakt"
    }
  ]
}
{% endschema %}
