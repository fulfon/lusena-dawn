{% doc %}
  Bundle PDP summary: emotional headline, title, tagline, price with savings, delivery row.

  @param {product} product
  @param {variant} current_variant
  @param {section} section

  Per-product metafield overrides (fallback to section settings):
  - product.metafields.lusena.pdp_emotional_headline
  - product.metafields.lusena.pdp_tagline
  - product.metafields.lusena.bundle_original_price (integer, zł — e.g. 508)
{% enddoc %}

{%- liquid
  assign resolved_headline = section.settings.emotional_headline
  if product != blank
    assign mf_headline = product.metafields.lusena.pdp_emotional_headline
    if mf_headline != blank
      if mf_headline.value != blank
        assign resolved_headline = mf_headline.value
      endif
    endif
  endif

  assign resolved_tagline = section.settings.tagline
  if product != blank
    assign mf_tagline = product.metafields.lusena.pdp_tagline
    if mf_tagline != blank
      if mf_tagline.value != blank
        assign resolved_tagline = mf_tagline.value
      endif
    endif
  endif

  assign original_price_cents = 0
  assign savings_cents = 0
  assign has_savings = false
  if product != blank
    assign mf_original = product.metafields.lusena.bundle_original_price
    if mf_original != blank
      if mf_original.value != blank
        assign original_price_cents = mf_original.value | times: 100
        assign savings_cents = original_price_cents | minus: current_variant.price
        if savings_cents > 0
          assign has_savings = true
        endif
      endif
    endif
  endif
-%}

<div class="lusena-pdp-summary{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  {%- if resolved_headline != blank -%}
    <span class="lusena-pdp-summary__eyebrow">
      {{ resolved_headline | escape }}
    </span>
  {%- endif -%}

  <h1 class="lusena-pdp-summary__title">
    {{ product.title | escape }}
  </h1>

  {%- if resolved_tagline != blank -%}
    <p class="lusena-pdp-summary__tagline">
      {{ resolved_tagline | escape }}
    </p>
  {%- endif -%}

  <div data-lusena-price-wrap>
    <div class="lusena-pdp-summary__price-row">
      <span class="lusena-pdp-summary__price">
        {{ current_variant.price | money_without_trailing_zeros }}
      </span>
      {%- if has_savings -%}
        <span class="lusena-pdp-summary__compare-at">
          {{ original_price_cents | money_without_trailing_zeros }}
        </span>
      {%- endif -%}
    </div>
    {%- if has_savings -%}
      <span class="lusena-bundle-savings">
        {{ section.settings.savings_label | escape }} {{ savings_cents | money_without_trailing_zeros }}
      </span>
    {%- endif -%}
  </div>

  {%- liquid
    assign has_delivery_micro = false
    if section.settings.delivery_eta_label != blank
      assign has_delivery_micro = true
    else
      if section.settings.delivery_returns_link_label != blank
        assign has_delivery_micro = true
      endif
    endif
  -%}

  {%- if has_delivery_micro -%}
    <div class="lusena-pdp-summary__delivery">
      <p class="lusena-pdp-summary__delivery-row">
        {% render 'lusena-icon',
          name: 'truck',
          class: 'lusena-pdp-summary__delivery-icon',
          stroke_width: 1.5
        %}
        <span class="lusena-pdp-summary__delivery-copy">
          {%- if section.settings.delivery_eta_label != blank -%}
            <span class="lusena-pdp-summary__delivery-eta">{{ section.settings.delivery_eta_label | escape }}</span>
          {%- endif -%}
          {%- if section.settings.delivery_returns_link_label != blank -%}
            {%- if section.settings.delivery_eta_label != blank -%}
              <span aria-hidden="true"> &middot; </span>
            {%- endif -%}
            <a
              href="#details"
              class="lusena-pdp-summary__delivery-link"
            >
              {{ section.settings.delivery_returns_link_label | escape }}
            </a>
          {%- endif -%}
        </span>
      </p>
    </div>
  {%- endif -%}
</div>
