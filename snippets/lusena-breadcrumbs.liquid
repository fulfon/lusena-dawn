{% doc %}
  Renders LUSENA breadcrumbs in the draft-shop visual style.

  @param {string} page_type - Supported values: "product", "collection", "blog", "article", "page"
  @param {product} [product] - Product object for product page breadcrumbs
  @param {collection} [collection] - Current collection context
  @param {blog} [blog] - Blog object for blog/article breadcrumbs
  @param {article} [article] - Article object for article breadcrumbs
  @param {page} [page] - Page object for generic page breadcrumbs
  @param {string} [breadcrumb_label] - Override label for the current page breadcrumb (e.g. "Kontakt" instead of page.title)
{% enddoc %}

{%- liquid
  assign home_label = 'Strona g&#322;&#243;wna'
  assign home_url = routes.root_url
-%}

<nav aria-label="Breadcrumb" class="lusena-breadcrumb-nav{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  <ol class="lusena-breadcrumb">
    <li class="lusena-breadcrumb__item">
      <a href="{{ home_url }}" class="lusena-breadcrumb__link">{{ home_label }}</a>
      {% render 'lusena-icon', name: 'chevron-right', class: 'lusena-breadcrumb__separator' %}
    </li>

    {%- if page_type == 'product' -%}
      {%- liquid
        assign product_category_url = ''

        if collection != blank
          if collection.url != blank
            assign product_category_url = collection.url
          endif
        endif

        if product_category_url == blank
          assign jedwab_collection = collections['jedwab']

          if jedwab_collection != blank
            assign product_category_url = jedwab_collection.url
          else
            assign product_category_url = '/collections/all'
          endif
        endif
      -%}

      <li class="lusena-breadcrumb__item">
        <a href="{{ product_category_url }}" class="lusena-breadcrumb__link">Jedwab</a>
        {% render 'lusena-icon', name: 'chevron-right', class: 'lusena-breadcrumb__separator' %}
      </li>

      <li class="lusena-breadcrumb__item">
        <span class="lusena-breadcrumb__link" aria-current="page">{{ product.title | escape }}</span>
      </li>
    {%- elsif page_type == 'collection' -%}
      <li class="lusena-breadcrumb__item">
        <span class="lusena-breadcrumb__link" aria-current="page">Jedwab</span>
      </li>

    {%- elsif page_type == 'blog' -%}
      <li class="lusena-breadcrumb__item">
        <span class="lusena-breadcrumb__link" aria-current="page">{{ blog.title | escape }}</span>
      </li>

    {%- elsif page_type == 'article' -%}
      <li class="lusena-breadcrumb__item">
        <a href="{{ blog.url }}" class="lusena-breadcrumb__link">{{ blog.title | escape }}</a>
        {% render 'lusena-icon', name: 'chevron-right', class: 'lusena-breadcrumb__separator' %}
      </li>
      <li class="lusena-breadcrumb__item">
        <span class="lusena-breadcrumb__link" aria-current="page">{{ article.title | escape }}</span>
      </li>

    {%- elsif page_type == 'page' -%}
      <li class="lusena-breadcrumb__item">
        <span class="lusena-breadcrumb__link" aria-current="page">{{ breadcrumb_label | default: page.title | escape }}</span>
      </li>
    {%- endif -%}
  </ol>
</nav>

{% stylesheet %}
  .lusena-breadcrumb-nav {
    padding-block: var(--lusena-space-05);
  }
  .lusena-breadcrumb__item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    white-space: nowrap;
    flex-shrink: 0;
  }
  /* Truncate the last item (current page) */
  .lusena-breadcrumb__item:last-child {
    flex-shrink: 1;
    min-width: 0;
  }
  .lusena-breadcrumb__item:last-child .lusena-breadcrumb__link {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    min-height: 0;
  }
{% endstylesheet %}
