{%- comment -%}
  Scrunchie PDP education — live cart sync for price education.
  Server-side rendering (in lusena-pdp-summary) handles initial state.
  This script only manages live updates when cart changes while on page.
  Parameters: product (product object), education_price (integer, cents)
{%- endcomment -%}

{%- if product.handle == 'silk-scrunchie' and education_price != blank -%}
<script>
(function lusenaScrunchieEducation() {
  var root = document.querySelector('[data-lusena-product-section]');
  if (!root) return;
  if (root.dataset.lusenaEducationInit) return;
  root.dataset.lusenaEducationInit = '1';

  /* ---- Handle-to-label map (Polish instrumental case) ---- */
  var LABELS = {
    'poszewka-jedwabna': 'Taniej z poszewk\u0105 jedwabn\u0105 w koszyku',
    'silk-bonnet': 'Taniej z czepkiem jedwabnym w koszyku',
    'jedwabna-maska-3d': 'Taniej z mask\u0105 do spania w koszyku',
    'heatless-curlers': 'Taniej z wa\u0142kiem do lok\u00f3w w koszyku',
    'nocna-rutyna': 'Taniej z zestawem Nocna Rutyna w koszyku',
    'piekny-sen': 'Taniej z zestawem Pi\u0119kny Sen w koszyku'
  };
  var FALLBACK_LABEL = 'Taniej w komplecie';

  /* ---- DOM refs (elements rendered server-side by lusena-pdp-summary) ---- */
  var priceRow = root.querySelector('.lusena-pdp-summary__price-row');
  var eduRow = root.querySelector('[data-lusena-education-row]');
  var hintEl = root.querySelector('[data-lusena-education-hint]');
  var perNightEl = root.querySelector('[data-lusena-price-per-night]');
  var stickyPrices = document.querySelectorAll('[data-lusena-sticky-price]');
  var stickyCompares = document.querySelectorAll('[data-lusena-sticky-compare]');
  var stickyPerNights = document.querySelectorAll('[data-lusena-sticky-price-per-night]');

  if (!priceRow || !eduRow || !hintEl) return;

  /* ---- Read initial state from server-rendered DOM ---- */
  var isActive = priceRow.style.display === 'none';
  var eduPriceText = eduRow.querySelector('.lusena-pdp-summary__education-current').textContent.trim();
  var eduCompareText = eduRow.querySelector('.lusena-pdp-summary__education-compare').textContent.trim();

  /* ---- Sticky guard ---- */
  var stickyGuard = false;

  /* ---- Sticky MutationObserver ---- */
  var stickyObs = null;
  if (stickyPrices.length > 0) {
    stickyObs = new MutationObserver(function() {
      if (stickyGuard || !isActive) return;
      applyStickyEducation();
    });
    stickyPrices.forEach(function(el) {
      stickyObs.observe(el, { childList: true, characterData: true, subtree: true });
    });
  }

  function applyStickyEducation() {
    stickyGuard = true;
    stickyPrices.forEach(function(el) { el.textContent = eduPriceText; });
    stickyCompares.forEach(function(el) { el.textContent = eduCompareText; el.hidden = false; });
    stickyPerNights.forEach(function(el) { el.hidden = true; });
    setTimeout(function() { stickyGuard = false; }, 0);
  }

  function revertStickyEducation() {
    stickyGuard = true;
    var priceEl = root.querySelector('[data-lusena-price]');
    stickyPrices.forEach(function(el) { el.textContent = priceEl ? priceEl.textContent : ''; });
    stickyCompares.forEach(function(el) { el.hidden = true; });
    stickyPerNights.forEach(function(el) { el.hidden = false; });
    setTimeout(function() { stickyGuard = false; }, 0);
  }

  /* ---- Activate / Deactivate ---- */
  function activate(label) {
    isActive = true;
    priceRow.style.display = 'none';
    eduRow.style.display = '';
    hintEl.textContent = label;
    hintEl.style.display = '';
    if (perNightEl) perNightEl.style.display = 'none';
    applyStickyEducation();
  }

  function deactivate() {
    isActive = false;
    priceRow.style.display = '';
    eduRow.style.display = 'none';
    hintEl.style.display = 'none';
    if (perNightEl) perNightEl.style.display = '';
    revertStickyEducation();
  }

  /* ---- Cart check (live sync only) ---- */
  function checkCart() {
    fetch('/cart.js', { credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        var label = null;
        for (var i = 0; i < cart.items.length; i++) {
          var handle = cart.items[i].handle;
          if (handle.indexOf('scrunchie') === -1) {
            label = LABELS[handle] || FALLBACK_LABEL;
            break;
          }
        }
        if (label) {
          activate(label);
        } else if (isActive) {
          deactivate();
        }
      })
      .catch(function() { /* network error — silently ignore */ });
  }

  /* ---- Apply sticky education on init if server rendered active state ---- */
  if (isActive) {
    applyStickyEducation();
  }

  /* ---- PubSub subscriber (live cart sync) ----
     Inline scripts run before Dawn's deferred pubsub.js loads,
     so subscribe may not exist yet. Try now, retry on window load. */
  function trySubscribe() {
    if (typeof subscribe === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
      subscribe(PUB_SUB_EVENTS.cartUpdate, function() {
        checkCart();
      });
      return true;
    }
    return false;
  }
  if (!trySubscribe()) {
    window.addEventListener('load', trySubscribe);
  }
})();
</script>
{%- endif -%}
