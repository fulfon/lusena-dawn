{% doc %}
  Renders a Polish-formatted date (e.g. "5 marca 2026").
  Shopify's time_tag uses the store locale which may output English.

  @param {string} date - The date to format
{% enddoc %}

{%- liquid
  assign d = date | date: '%-d'
  assign m = date | date: '%-m' | plus: 0
  assign y = date | date: '%Y'

  case m
    when 1
      assign month_name = 'stycznia'
    when 2
      assign month_name = 'lutego'
    when 3
      assign month_name = 'marca'
    when 4
      assign month_name = 'kwietnia'
    when 5
      assign month_name = 'maja'
    when 6
      assign month_name = 'czerwca'
    when 7
      assign month_name = 'lipca'
    when 8
      assign month_name = 'sierpnia'
    when 9
      assign month_name = 'września'
    when 10
      assign month_name = 'października'
    when 11
      assign month_name = 'listopada'
    when 12
      assign month_name = 'grudnia'
  endcase
-%}
{{- d }} {{ month_name }} {{ y -}}
