{% doc %}
  Renders quantity stepper + remove button for a cart line item.
  Styled to match the cart drawer's stepper (bordered group, icon-button--sm).
  Preserves all JS-required IDs/classes for cart.js + quantity-popover.js compatibility.

  @param {line_item} item - The cart line item object
{% enddoc %}

{%- liquid
  assign has_qty_rules = false
  if item.variant.quantity_rule.increment > 1 or item.variant.quantity_rule.min > 1 or item.variant.quantity_rule.max != null
    assign has_qty_rules = true
  endif

  assign has_vol_pricing = false
  if item.variant.quantity_price_breaks.size > 0
    assign has_vol_pricing = true
  endif

  assign can_update_quantity = item.instructions.can_update_quantity | default: true
  assign can_remove = item.instructions.can_remove | default: true
-%}

<quantity-popover>
  <div class="lusena-cart-qty">
    <label class="lusena-visually-hidden" for="Quantity-{{ item.index | plus: 1 }}">
      Ilość
    </label>
    <div class="lusena-cart-qty__stepper{% if has_qty_rules or has_vol_pricing %} quantity-popover-container--hover{% endif %}">
      {%- if has_qty_rules or has_vol_pricing -%}
        <button
          type="button"
          aria-expanded="false"
          class="quantity-popover__info-button quantity-popover__info-button--icon-only lusena-cart-qty__info lusena-hide-mobile"
        >
          {{- 'icon-info.svg' | inline_asset_content -}}
        </button>
      {%- endif -%}
      <quantity-input class="quantity lusena-cart-qty__group">
        <button
          class="quantity__button lusena-icon-button lusena-icon-button--subtle lusena-icon-button--sm"
          name="minus"
          type="button"
          {% if can_update_quantity == false %}disabled{% endif %}
        >
          <span class="lusena-visually-hidden">
            Zmniejsz ilość dla {{ item.product.title | escape }}
          </span>
          {% render 'lusena-icon', name: 'minus', class: 'lusena-icon-sm', stroke_width: 2 %}
        </button>
        <input
          class="quantity__input lusena-cart-qty__display"
          data-quantity-variant-id="{{ item.variant.id }}"
          type="number"
          name="updates[]"
          value="{{ item.quantity }}"
          {% comment %}theme-check-disable{% endcomment %}
          data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
          min="0"
          data-min="{{ item.variant.quantity_rule.min }}"
          {% if item.variant.quantity_rule.max != null %}
            max="{{ item.variant.quantity_rule.max }}"
          {% endif %}
          step="{{ item.variant.quantity_rule.increment }}"
          {% comment %}theme-check-enable{% endcomment %}
          aria-label="Ilość dla {{ item.product.title | escape }}"
          id="Quantity-{{ item.index | plus: 1 }}"
          data-index="{{ item.index | plus: 1 }}"
          {% if can_update_quantity == false %}disabled{% endif %}
        >
        <button
          class="quantity__button lusena-icon-button lusena-icon-button--subtle lusena-icon-button--sm"
          name="plus"
          type="button"
          {% if can_update_quantity == false %}disabled{% endif %}
        >
          <span class="lusena-visually-hidden">
            Zwiększ ilość dla {{ item.product.title | escape }}
          </span>
          {% render 'lusena-icon', name: 'plus', class: 'lusena-icon-sm', stroke_width: 2 %}
        </button>
      </quantity-input>
    </div>
    <cart-remove-button
      id="Remove-{{ item.index | plus: 1 }}"
      data-index="{{ item.index | plus: 1 }}"
      {% unless can_remove %}class="hidden"{% endunless %}
    >
      <a
        href="{{ item.url_to_remove }}"
        class="lusena-cart-qty__remove"
        aria-label="Usuń {{ item.title | escape }}"
      >
        Usuń
      </a>
    </cart-remove-button>
  </div>

  {%- if has_qty_rules or has_vol_pricing -%}
    <button
      type="button"
      class="quantity-popover__info-button quantity-popover__info-button--icon-with-label lusena-cart-qty__info-mobile lusena-hide-desktop"
      aria-expanded="false"
    >
      {{- 'icon-info.svg' | inline_asset_content -}}
      <span>
        {%- if has_vol_pricing -%}
          Ceny zależne od wolumenu są dostępne
        {%- elsif has_qty_rules -%}
          Wyświetl reguły ilości
        {%- endif -%}
      </span>
    </button>
  {%- endif -%}

  {%- if has_vol_pricing or has_qty_rules -%}
    <div class="cart-items__info global-settings-popup quantity-popover__info" tabindex="-1" hidden>
      {%- if has_qty_rules == false -%}
        <span class="lusena-type-caption lusena-kicker">
          Ceny zależne od wolumenu
        </span>
      {%- endif -%}
      <div class="lusena-type-caption">
        {%- if item.variant.quantity_rule.increment > 1 -%}
          <span>Przyrost o {{ item.variant.quantity_rule.increment }}</span>
        {%- endif -%}
        {%- if item.variant.quantity_rule.min > 1 -%}
          <span>Min. {{ item.variant.quantity_rule.min }}</span>
        {%- endif -%}
        {%- if item.variant.quantity_rule.max != null -%}
          <span>Maks. {{ item.variant.quantity_rule.max }}</span>
        {%- endif -%}
      </div>
      <button class="lusena-cart-qty__close lusena-hide-desktop" type="button" aria-label="Zamknij">
        <span class="svg-wrapper">{{- 'icon-close.svg' | inline_asset_content -}}</span>
      </button>
      {%- if item.variant.quantity_price_breaks.size > 0 -%}
        <volume-pricing class="parent-display">
          <ul class="lusena-cart-qty__vol-list">
            <li>
              <span>{{ item.variant.quantity_rule.min }}+</span>
              {%- assign price = item.variant.price | money_with_currency -%}
              <span>{{ price }}/szt.</span>
            </li>
            {%- for price_break in item.variant.quantity_price_breaks -%}
              <li>
                <span>{{ price_break.minimum_quantity }}<span aria-hidden="true">+</span></span>
                {%- assign price = price_break.price | money_with_currency -%}
                <span>{{ price }}/szt.</span>
              </li>
            {%- endfor -%}
          </ul>
        </volume-pricing>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="cart-item__error" id="Line-item-error-{{ item.index | plus: 1 }}" role="alert">
    <small class="cart-item__error-text"></small>
    <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
  </div>
</quantity-popover>

{% stylesheet %}
  /* CSS extracted to assets/lusena-cart-page.css */
{% endstylesheet %}
