{% doc %}
  PDP variant picker (swatches and pills).

  @param {product} product
  @param {variant} current_variant
  @param {section} section
{% enddoc %}

<div
  class="lusena-content-flow{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
  data-lusena-variant-selectors
>
  {%- unless product.has_only_default_variant -%}
    {%- for option in product.options_with_values -%}
      {%- liquid
        assign option_index = forloop.index0
        assign selected_value = current_variant.options[option_index]
        assign option_name_downcase = option.name | downcase
        assign swatch_count = option.values | map: 'swatch' | compact | size
        assign is_color = false
        if swatch_count > 0
          assign is_color = true
        elsif option_name_downcase contains 'color' or option_name_downcase contains 'colour' or option_name_downcase contains 'kolor'
          assign is_color = true
        endif
      -%}

      <fieldset
        class="lusena-content-flow--tight"
        data-lusena-option
        data-option-index="{{ option_index }}"
        {% if is_color %}
          data-lusena-option-type="color"
        {% endif %}
      >
        <legend class="lusena-pdp-variant-picker__legend">
          {%- if is_color and section.settings.select_color_label != blank -%}
            {{ section.settings.select_color_label | escape }}:
          {%- else -%}
            {{ option.name | escape }}:
          {%- endif -%}
          <span class="lusena-pdp-variant-picker__selected" data-lusena-selected>
            {{- selected_value | escape -}}
          </span>
        </legend>

        <div class="lusena-pdp-variant-picker__options">
          {%- for value in option.values -%}
            {%- liquid
              assign is_selected = value.selected
              assign option_disabled = true
              if value.available
                assign option_disabled = false
              endif
            -%}

            {%- if is_color -%}
              {%- liquid
                assign swatch_value = null
                assign swatch_focal_point = null

                if value.swatch.image
                  assign image_url = value.swatch.image | image_url: width: 100
                  assign swatch_value = 'url(' | append: image_url | append: ')'
                  assign swatch_focal_point = value.swatch.image.presentation.focal_point
                elsif value.swatch.color
                  assign swatch_value = 'rgb(' | append: value.swatch.color.rgb | append: ')'
                endif

                assign swatch_style = ''
                if swatch_value == null
                  assign value_downcase = value | downcase
                  case value_downcase
                    when 'beige'
                      assign swatch_style = 'background:#E8E0D5'
                    when 'midnight blue'
                      assign swatch_style = 'background:#1B243B'
                    when 'pearl white'
                      assign swatch_style = 'background:#FDFCF8'
                    when 'pink'
                      assign swatch_style = 'background:#F3E5DC'
                    when 'silver'
                      assign swatch_style = 'background:#D6D6D6'
                    else
                      assign swatch_style = 'background:#E5E5E5'
                  endcase
                endif
              -%}

              <label class="lusena-pdp-variant-picker__label{% if option_disabled %} lusena-pdp-variant-picker__label--disabled{% endif %}">
                <input
                  class="lusena-option__input visually-hidden"
                  type="radio"
                  name="option-{{ section.id }}-{{ option_index }}"
                  value="{{ value | escape }}"
                  {% if is_selected %}
                    checked
                  {% endif %}
                  {% if option_disabled %}
                    disabled
                  {% endif %}
                >
                <span
                  class="lusena-option__swatch"
                  data-lusena-value
                  data-lusena-option-value="{{ value | escape }}"
                  title="{{ value | escape }}"
                  {% if swatch_value %}
                    style="
                      background: {{ swatch_value }};
                      background-size: cover;
                      {% if swatch_focal_point %}background-position: {{ swatch_focal_point }};{% endif %}
                    "
                  {% elsif swatch_style != blank %}
                    style="{{ swatch_style }}"
                  {% endif %}
                ></span>
                <span class="visually-hidden">{{ value | escape }}</span>
              </label>
            {%- else -%}
              <label class="lusena-pdp-variant-picker__label{% if option_disabled %} lusena-pdp-variant-picker__label--disabled{% endif %}">
                <input
                  class="lusena-option__input visually-hidden"
                  type="radio"
                  name="option-{{ section.id }}-{{ option_index }}"
                  value="{{ value | escape }}"
                  {% if is_selected %}
                    checked
                  {% endif %}
                  {% if option_disabled %}
                    disabled
                  {% endif %}
                >
                <span
                  class="lusena-option__pill"
                  data-lusena-value
                  data-lusena-option-value="{{ value | escape }}"
                >
                  {{ value | escape }}
                </span>
              </label>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </fieldset>
    {%- endfor -%}
  {%- endunless -%}
</div>
