{%- comment -%}
  Cross-sell checkbox for PDP buy-box.
  Offers a discounted cross-sell product (e.g., scrunchie at 39 zl).
  Color-matches to the main product's selected variant.

  Required variables:
    cross_sell_product  - product object (from section setting)
    cross_sell_price    - discounted price in cents (e.g., 3900)
    current_variant     - selected variant of the main product
    product             - the main product
    section             - section object
{%- endcomment -%}

{%- comment -%} ── Find color option index on cross-sell product ── {%- endcomment -%}
{%- assign cs_color_index = 0 -%}
{%- for option in cross_sell_product.options_with_values -%}
  {%- assign opt_down = option.name | downcase -%}
  {%- if opt_down contains 'color' or opt_down contains 'colour' or opt_down contains 'kolor' -%}
    {%- assign cs_color_index = forloop.index -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%} ── Find color option index on main product ── {%- endcomment -%}
{%- assign main_color_index = 0 -%}
{%- for option in product.options_with_values -%}
  {%- assign opt_down = option.name | downcase -%}
  {%- if opt_down contains 'color' or opt_down contains 'colour' or opt_down contains 'kolor' -%}
    {%- assign main_color_index = forloop.index -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%} ── Get trigger color from current variant ── {%- endcomment -%}
{%- assign trigger_color = '' -%}
{%- if main_color_index == 1 -%}
  {%- assign trigger_color = current_variant.option1 -%}
{%- elsif main_color_index == 2 -%}
  {%- assign trigger_color = current_variant.option2 -%}
{%- elsif main_color_index == 3 -%}
  {%- assign trigger_color = current_variant.option3 -%}
{%- endif -%}

{%- comment -%} ── Color-match: find best cross-sell variant ── {%- endcomment -%}
{%- assign cs_variant = nil -%}
{%- assign cs_fallback = nil -%}
{%- assign cs_highest_inv = -1 -%}

{%- for variant in cross_sell_product.variants -%}
  {%- unless variant.available -%}{%- continue -%}{%- endunless -%}

  {%- if cs_color_index == 1 -%}
    {%- assign cs_var_color = variant.option1 -%}
  {%- elsif cs_color_index == 2 -%}
    {%- assign cs_var_color = variant.option2 -%}
  {%- elsif cs_color_index == 3 -%}
    {%- assign cs_var_color = variant.option3 -%}
  {%- else -%}
    {%- assign cs_var_color = '' -%}
  {%- endif -%}

  {%- if cs_var_color == trigger_color and cs_variant == nil -%}
    {%- assign cs_variant = variant -%}
  {%- endif -%}

  {%- if variant.inventory_quantity > cs_highest_inv -%}
    {%- assign cs_highest_inv = variant.inventory_quantity -%}
    {%- assign cs_fallback = variant -%}
  {%- endif -%}
{%- endfor -%}

{%- unless cs_variant -%}
  {%- if cs_fallback -%}
    {%- assign cs_variant = cs_fallback -%}
  {%- else -%}
    {%- assign cs_variant = cross_sell_product.selected_or_first_available_variant -%}
  {%- endif -%}
{%- endunless -%}

{%- comment -%} ── Guard: only render if we found an available variant ── {%- endcomment -%}
{%- if cs_variant and cs_variant.available -%}

{%- comment -%} ── Resolved color label ── {%- endcomment -%}
{%- assign cs_color_label = '' -%}
{%- if cs_color_index == 1 -%}
  {%- assign cs_color_label = cs_variant.option1 -%}
{%- elsif cs_color_index == 2 -%}
  {%- assign cs_color_label = cs_variant.option2 -%}
{%- elsif cs_color_index == 3 -%}
  {%- assign cs_color_label = cs_variant.option3 -%}
{%- endif -%}

{%- comment -%} ── Image: prefer variant-specific, fall back to product ── {%- endcomment -%}
{%- if cs_variant.featured_image -%}
  {%- assign cs_image = cs_variant.featured_image -%}
{%- else -%}
  {%- assign cs_image = cross_sell_product.featured_image -%}
{%- endif -%}

{%- comment -%} ── Prices ── {%- endcomment -%}
{%- assign cs_original_price = cs_variant.price -%}
{%- assign cs_display_price = cross_sell_price | default: cs_original_price -%}

<div class="lusena-pdp-cross-sell-cb"
     data-lusena-cross-sell-row>
  <label class="lusena-pdp-cross-sell-cb__label">
    <input
      type="checkbox"
      class="lusena-pdp-cross-sell-cb__input visually-hidden"
      data-lusena-cross-sell-checkbox
      data-variant-id="{{ cs_variant.id }}"
      autocomplete="off"
    >
    <span class="lusena-pdp-cross-sell-cb__check" aria-hidden="true"></span>

    <span class="lusena-pdp-cross-sell-cb__image">
      {%- if cs_image -%}
        <img
          src="{{ cs_image | image_url: width: 80 }}"
          alt="{{ cross_sell_product.title | escape }}"
          width="40"
          height="40"
          loading="lazy"
          data-lusena-cross-sell-image
        >
      {%- endif -%}
      <span class="lusena-pdp-cross-sell-cb__color-indicator" data-lusena-cross-sell-color-indicator>
        {{- cs_color_label -}}
      </span>
    </span>

    <span class="lusena-pdp-cross-sell-cb__info">
      <span class="lusena-pdp-cross-sell-cb__title">
        Dodaj {{ cross_sell_product.title | downcase }}
      </span>
      <span class="lusena-pdp-cross-sell-cb__hint">Taniej w komplecie</span>
    </span>

    <span class="lusena-pdp-cross-sell-cb__pricing">
      <span class="lusena-pdp-cross-sell-cb__price">
        {{- cs_display_price | money_without_trailing_zeros -}}
      </span>
      {%- if cs_original_price > cs_display_price -%}
        <span class="lusena-pdp-cross-sell-cb__was">
          {{- cs_original_price | money_without_trailing_zeros -}}
        </span>
      {%- endif -%}
    </span>
  </label>

  {%- comment -%} ── Variant data for JS color matching on variant change ── {%- endcomment -%}
  <script type="application/json" data-lusena-cross-sell-variants>
    [
      {%- for variant in cross_sell_product.variants -%}
        {%- if cs_color_index == 1 -%}
          {%- assign v_color = variant.option1 -%}
        {%- elsif cs_color_index == 2 -%}
          {%- assign v_color = variant.option2 -%}
        {%- elsif cs_color_index == 3 -%}
          {%- assign v_color = variant.option3 -%}
        {%- else -%}
          {%- assign v_color = '' -%}
        {%- endif -%}
        {
          "id": {{ variant.id }},
          "available": {{ variant.available }},
          "color": {{ v_color | json }},
          "inventory": {{ variant.inventory_quantity | default: 0 }},
          "image": {% if variant.featured_image %}{{ variant.featured_image | image_url: width: 80 | json }}{% else %}null{% endif %}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  </script>
</div>

{%- unless skip_js -%}
<script>
  function lusenaCrossSellInit() {
    var row = document.querySelector('[data-lusena-cross-sell-row]');
    if (!row) return;
    if (row.dataset.lusenaCrossSellInit) return;
    row.dataset.lusenaCrossSellInit = '1';
    var checkbox = row.querySelector('[data-lusena-cross-sell-checkbox]');
    if (!checkbox) return;

    var section = row.closest('[data-lusena-product-section]');
    if (!section) return;
    var form = section.querySelector('product-form form[data-type="add-to-cart-form"]');
    var variantInput = section.querySelector('[data-lusena-variant-id]');
    var productFormEl = form ? form.closest('product-form') : null;
    var atcBtn = form ? form.querySelector('[type="submit"]') : null;
    var stickyBtns = Array.from(document.querySelectorAll('[data-lusena-sticky-atc-button]'));

    /* ── Button loading state helper (mirrors product-form.js behavior) ── */
    function setBtnLoading(btn, isLoading) {
      if (!btn) return;
      var spinner = btn.querySelector('.loading__spinner');
      btn.classList.toggle('loading', isLoading);
      if (isLoading) {
        btn.setAttribute('aria-disabled', 'true');
        btn.setAttribute('aria-busy', 'true');
        if (spinner) spinner.classList.remove('hidden');
      } else {
        btn.removeAttribute('aria-disabled');
        btn.removeAttribute('aria-busy');
        if (spinner) spinner.classList.add('hidden');
      }
    }

    function showBtnError(btn) {
      if (!btn) return;
      var textEl = btn.querySelector('.lusena-btn__content');
      if (!textEl) return;
      var original = textEl.textContent;
      textEl.textContent = 'Coś poszło nie tak';
      btn.classList.add('lusena-btn--error');
      setTimeout(function() {
        textEl.textContent = original;
        btn.classList.remove('lusena-btn--error');
      }, 3000);
    }

    /* ── ATC intercept: add both items when checkbox is checked ── */
    if (productFormEl) {
      productFormEl.addEventListener('submit', function(event) {
        if (!checkbox.checked) return;
        if (atcBtn && atcBtn.getAttribute('aria-disabled') === 'true') return;

        event.preventDefault();
        event.stopPropagation();

        var mainId = parseInt(variantInput.value);
        var crossSellId = parseInt(checkbox.dataset.variantId);
        if (!mainId || !crossSellId) return;

        setBtnLoading(atcBtn, true);

        fetch(window.routes.cart_add_url + '.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({
            items: [
              { id: mainId, quantity: 1 },
              { id: crossSellId, quantity: 1 }
            ]
          })
        })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.status) {
            console.error('Cross-sell ATC error:', data.description || data.message);
            setBtnLoading(atcBtn, false);
            showBtnError(atcBtn);
            stickyBtns.forEach(function(b) { showBtnError(b); });
            return;
          }
          /* Re-render cart drawer with fresh section HTML, then open it */
          var drawer = document.querySelector('cart-drawer');
          if (drawer) {
            fetch('/cart?section_id=cart-drawer')
              .then(function(r) { return r.text(); })
              .then(function(html) {
                var doc = new DOMParser().parseFromString(html, 'text/html');
                var fresh = doc.querySelector('#CartDrawer');
                var current = document.getElementById('CartDrawer');
                if (fresh && current) current.innerHTML = fresh.innerHTML;
                drawer.classList.remove('is-empty');
                drawer.open();
              })
              .catch(function(err) { console.error('Drawer re-render failed:', err); });
            /* Update cart icon bubble count */
            fetch('/cart?section_id=cart-icon-bubble')
              .then(function(r) { return r.text(); })
              .then(function(html) {
                var doc = new DOMParser().parseFromString(html, 'text/html');
                var fresh = doc.querySelector('.shopify-section');
                var current = document.getElementById('cart-icon-bubble');
                if (fresh && current) current.innerHTML = fresh.innerHTML;
              })
              .catch(function(err) { console.error('Icon bubble re-render failed:', err); });
          }
          setTimeout(function() {
            setBtnLoading(atcBtn, false);
          }, 800);
        })
        .catch(function(err) {
          console.error('Cross-sell ATC fetch error:', err);
          setBtnLoading(atcBtn, false);
          showBtnError(atcBtn);
          stickyBtns.forEach(function(b) { showBtnError(b); });
        });
      }, { capture: true });
    }

    /* ── Buy Now intercept: add both items then redirect to checkout ── */
    var buyNowBtn = section.querySelector('[data-lusena-buy-now]');
    if (buyNowBtn) {
      var origHandler = null;
      buyNowBtn.addEventListener('click', function(event) {
        if (!checkbox.checked) return;
        if (buyNowBtn.getAttribute('aria-disabled') === 'true') return;

        event.preventDefault();
        event.stopImmediatePropagation();

        var mainId = parseInt(variantInput.value);
        var crossSellId = parseInt(checkbox.dataset.variantId);
        if (!mainId || !crossSellId) return;

        setBtnLoading(buyNowBtn, true);

        fetch(window.routes.cart_add_url + '.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({
            items: [
              { id: mainId, quantity: 1 },
              { id: crossSellId, quantity: 1 }
            ]
          })
        })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (!data.status) {
            window.location.href = window.routes.checkout_url || '/checkout';
          } else {
            console.error('Cross-sell buy-now error:', data.description || data.message);
            setBtnLoading(buyNowBtn, false);
            showBtnError(buyNowBtn);
          }
        })
        .catch(function(err) {
          console.error('Cross-sell buy-now fetch error:', err);
          setBtnLoading(buyNowBtn, false);
          showBtnError(buyNowBtn);
        });
      }, { capture: true });
    }

    /* ── Variant change: update cross-sell color match ── */
    var variantsJson = row.querySelector('[data-lusena-cross-sell-variants]');
    if (variantsJson && section) {
      var csVariants = JSON.parse(variantsJson.textContent);

      section.addEventListener('change', function(e) {
        if (!(e.target instanceof HTMLInputElement) || e.target.type !== 'radio') return;

        /* Read color directly from the checked radio — immune to handler order */
        var selectedColor = null;
        var colorFieldset = section.querySelector('[data-lusena-option-type="color"]');
        if (colorFieldset) {
          var checked = colorFieldset.querySelector('input[type="radio"]:checked');
          if (checked) selectedColor = checked.value;
        }

        var matched = null;
        var highestInv = null;
        for (var j = 0; j < csVariants.length; j++) {
          var v = csVariants[j];
          if (!v.available) continue;
          if (selectedColor && v.color === selectedColor && !matched) matched = v;
          if (!highestInv || v.inventory > highestInv.inventory) highestInv = v;
        }

        var chosen = matched || highestInv || csVariants[0];
        if (!chosen) return;

        checkbox.dataset.variantId = String(chosen.id);
        var img = row.querySelector('[data-lusena-cross-sell-image]');
        if (img && chosen.image) img.src = chosen.image;
        var indicator = row.querySelector('[data-lusena-cross-sell-color-indicator]');
        if (indicator && chosen.color) indicator.textContent = chosen.color;
      });
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', lusenaCrossSellInit);
  } else {
    lusenaCrossSellInit();
  }
</script>
{%- endunless -%}

{%- endif -%}
{%- comment -%} ── End guard: cs_variant available ── {%- endcomment -%}
