{% doc %}
  PDP right-column summary: emotional headline, title, short description, price, and delivery row.

  @param {product} product
  @param {variant} current_variant
  @param {section} section
  @param {number} price_per_night_cents

  Per-product metafield overrides (fallback to section settings):
  - product.metafields.lusena.pdp_emotional_headline
  - product.metafields.lusena.pdp_tagline
  - product.metafields.lusena.pdp_show_price_per_night (boolean, default true)
{% enddoc %}

{%- liquid
  assign resolved_headline = section.settings.emotional_headline
  if product != blank
    assign mf_headline = product.metafields.lusena.pdp_emotional_headline
    if mf_headline != blank and mf_headline.value != blank
      assign resolved_headline = mf_headline.value
    endif
  endif

  assign resolved_tagline = section.settings.tagline
  if product != blank
    assign mf_tagline = product.metafields.lusena.pdp_tagline
    if mf_tagline != blank and mf_tagline.value != blank
      assign resolved_tagline = mf_tagline.value
    endif
  endif

  assign show_per_night = true
  if product != blank
    assign mf_per_night = product.metafields.lusena.pdp_show_price_per_night
    if mf_per_night.value == false
      assign show_per_night = false
    endif
  endif
-%}

<div class="lusena-pdp-summary{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  {%- if resolved_headline != blank -%}
    <span class="lusena-pdp-summary__eyebrow">
      {{ resolved_headline | escape }}
    </span>
  {%- endif -%}

  <h1 class="lusena-pdp-summary__title">
    {{ product.title | escape }}
  </h1>

  {%- if resolved_tagline != blank -%}
    <p class="lusena-pdp-summary__tagline">
      {{ resolved_tagline | escape }}
    </p>
  {%- endif -%}

  <div data-lusena-price-wrap>
    <div class="lusena-pdp-summary__price-row"{% if education_active %} style="display:none"{% endif %}>
      <span class="lusena-pdp-summary__price" data-lusena-price>
        {{ current_variant.price | money_without_trailing_zeros }}
      </span>
      {%- if current_variant.compare_at_price and current_variant.compare_at_price > current_variant.price -%}
        <span class="lusena-pdp-summary__compare-at" data-lusena-compare-at>
          {{ current_variant.compare_at_price | money_without_trailing_zeros }}
        </span>
      {%- else -%}
        <span class="lusena-pdp-summary__compare-at hidden" data-lusena-compare-at></span>
      {%- endif -%}
    </div>
    {%- if education_price -%}
      <div class="lusena-pdp-summary__education-row" data-lusena-education-row{% unless education_active %} style="display:none"{% endunless %}>
        <span class="lusena-pdp-summary__education-current">{{ education_price | money_without_trailing_zeros }}</span>
        <span class="lusena-pdp-summary__education-compare">{{ current_variant.price | money_without_trailing_zeros }}</span>
      </div>
      <span class="lusena-pdp-summary__education-hint" data-lusena-education-hint{% unless education_active %} style="display:none"{% endunless %}>
        {{- education_label -}}
      </span>
    {%- endif -%}
    {%- if show_per_night -%}
      <span
        class="lusena-pdp-summary__per-night"
        data-lusena-price-per-night
        data-prefix="{{ section.settings.price_per_night_prefix | escape }}"
        data-suffix="{{ section.settings.price_per_night_suffix | escape }}"
        {% if education_active %}style="display:none"{% endif %}
      >
        {{ section.settings.price_per_night_prefix | escape }}&nbsp;{{ price_per_night_cents | money_without_trailing_zeros }}
        {{ section.settings.price_per_night_suffix | escape }}
      </span>
    {%- endif -%}
  </div>

  {%- liquid
    assign has_delivery_micro = false
    if section.settings.delivery_eta_label != blank
      assign has_delivery_micro = true
    else
      if section.settings.delivery_returns_link_label != blank
        assign has_delivery_micro = true
      endif
    endif
  -%}

  {%- if has_delivery_micro -%}
    <div class="lusena-pdp-summary__delivery">
      <p class="lusena-pdp-summary__delivery-row">
        {% render 'lusena-icon',
          name: 'truck',
          class: 'lusena-pdp-summary__delivery-icon',
          stroke_width: 1.5
        %}
        <span class="lusena-pdp-summary__delivery-copy">
          {%- if section.settings.delivery_eta_label != blank -%}
            <span class="lusena-pdp-summary__delivery-eta">{{ section.settings.delivery_eta_label | escape }}</span>
          {%- endif -%}
          {%- if section.settings.delivery_returns_link_label != blank -%}
            {%- if section.settings.delivery_eta_label != blank -%}
              <span aria-hidden="true"> &middot; </span>
            {%- endif -%}
            <a
              href="#details"
              data-lusena-open-returns
              class="lusena-pdp-summary__delivery-link"
            >
              {{ section.settings.delivery_returns_link_label | escape }}
            </a>
          {%- endif -%}
        </span>
      </p>
    </div>
  {%- endif -%}
</div>
