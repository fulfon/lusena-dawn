{% doc %}
  PDP guarantee box under CTA.

  @param {section} section
{% enddoc %}

        <div class="lusena-pdp-guarantee__box{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <span class="lusena-pdp-guarantee__icon">
            {% render 'lusena-icon', name: 'shield-check', stroke_width: 1.5 %}
          </span>
          <p class="lusena-pdp-guarantee__text">
            <span class="lusena-pdp-guarantee__heading">{{ section.settings.guarantee_heading | escape }}</span>
            &middot;
            <a
              href="#details"
              data-lusena-open-returns
              class="lusena-pdp-guarantee__link"
            >
              {{ section.settings.guarantee_link_label | escape }}
            </a>
          </p>
        </div>
