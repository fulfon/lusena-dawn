{% doc %}
  PDP guarantee box under CTA.

  @param {section} section
{% enddoc %}

        <p class="lusena-pdp-guarantee__box{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {% render 'lusena-icon',
            name: 'shield-check',
            class: 'lusena-pdp-guarantee__icon',
            stroke_width: 1.5
          %}
          <span class="lusena-pdp-guarantee__text">
            <span class="lusena-pdp-guarantee__heading">{{ section.settings.guarantee_heading | escape }}</span>
            &middot;
            <a
              href="#details"
              data-lusena-open-returns
              class="lusena-pdp-guarantee__link"
            >
              {{ section.settings.guarantee_link_label | escape }}
            </a>
          </span>
        </p>
