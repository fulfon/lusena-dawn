{% doc %}
  Renders the cart drawer matching the LUSENA draft-shop UI.

  Usage:
  {% render 'cart-drawer' %}
{% enddoc %}

<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'lusena-bundle-swap.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign upsell_enabled = settings.lusena_enable_cart_upsell
  if upsell_enabled == nil
    assign upsell_enabled = true
  endif

  assign suppress_distinct_threshold = settings.lusena_cart_upsell_suppress_distinct_count | default: 2

  assign cart_product_ids = cart.items | map: 'product_id' | uniq
  assign distinct_count = cart_product_ids | size

  assign suppress_upsell = false

  for item in cart.items
    if item.product.metafields.lusena.upsell_suppress == true or item.product.metafields.lusena.upsell_role == 'bundle'
      assign suppress_upsell = true
      break
    endif
  endfor

  comment
    Merge detection: flag which bundle components are in cart.
    Checked later (before regular nudge) to offer bundle merge.
  endcomment
  assign merge_has_poszewka = false
  assign merge_has_bonnet = false
  assign merge_has_maska = false
  assign merge_poszewka_item = blank
  assign merge_bonnet_item = blank
  assign merge_maska_item = blank

  for item in cart.items
    case item.product.handle
      when 'poszewka-jedwabna'
        assign merge_has_poszewka = true
        assign merge_poszewka_item = item
      when 'silk-bonnet'
        assign merge_has_bonnet = true
        assign merge_bonnet_item = item
      when 'jedwabna-maska-3d'
        assign merge_has_maska = true
        assign merge_maska_item = item
    endcase
  endfor

  comment
    Resolve merge candidate. Highest savings first:
    Nocna Rutyna (poszewka+bonnet, 109 zl) > Piekny Sen (poszewka+maska, 89 zl).
  endcomment
  assign show_merge = false
  assign merge_bundle_handle = ''
  assign merge_item_1 = blank
  assign merge_item_2 = blank

  if upsell_enabled
    if merge_has_poszewka and merge_has_bonnet
      assign show_merge = true
      assign merge_bundle_handle = 'nocna-rutyna'
      assign merge_item_1 = merge_poszewka_item
      assign merge_item_2 = merge_bonnet_item
    elsif merge_has_poszewka and merge_has_maska
      assign show_merge = true
      assign merge_bundle_handle = 'piekny-sen'
      assign merge_item_1 = merge_poszewka_item
      assign merge_item_2 = merge_maska_item
    endif
  endif

  assign trigger_product = nil
  assign trigger_item = nil
  if cart != empty and suppress_upsell == false and upsell_enabled
    for item in cart.items
      if item.product.metafields.lusena.upsell_role == 'hero' and item.product.metafields.lusena.upsell_suppress != true
        assign trigger_product = item.product
        assign trigger_item = item
        break
      endif
    endfor
    if trigger_product == nil
      assign trigger_item = cart.items.first
      assign trigger_product = trigger_item.product
    endif
  endif

  assign trigger_color = ''
  if trigger_item != nil
    for option in trigger_product.options_with_values
      assign opt_name_down = option.name | downcase
      assign is_color_opt = false
      if opt_name_down contains 'color'
        assign is_color_opt = true
      else
        if opt_name_down contains 'colour'
          assign is_color_opt = true
        else
          if opt_name_down contains 'kolor'
            assign is_color_opt = true
          endif
        endif
      endif
      if is_color_opt
        assign trigger_color_pos = forloop.index
        if trigger_color_pos == 1
          assign trigger_color = trigger_item.variant.option1
        elsif trigger_color_pos == 2
          assign trigger_color = trigger_item.variant.option2
        elsif trigger_color_pos == 3
          assign trigger_color = trigger_item.variant.option3
        endif
        break
      endif
    endfor
  endif

  assign candidate_primary = blank
  assign candidate_secondary = blank
  assign candidate_fallback = settings.lusena_cart_upsell_global_fallback

  if trigger_product != nil
    assign primary_metafield = trigger_product.metafields.lusena.upsell_primary
    assign secondary_metafield = trigger_product.metafields.lusena.upsell_secondary
    assign candidate_primary = primary_metafield.value
    assign candidate_secondary = secondary_metafield.value
  endif

  assign upsell_product_1 = blank

  assign in_cart_primary = false
  if candidate_primary != blank and cart_product_ids contains candidate_primary.id
    assign in_cart_primary = true
  endif

  assign in_cart_secondary = false
  if candidate_secondary != blank and cart_product_ids contains candidate_secondary.id
    assign in_cart_secondary = true
  endif

  assign in_cart_fallback = false
  if candidate_fallback != blank and cart_product_ids contains candidate_fallback.id
    assign in_cart_fallback = true
  endif

  if suppress_upsell == false and upsell_enabled and cart != empty
    if candidate_primary != blank and candidate_primary.available and in_cart_primary == false
      assign upsell_product_1 = candidate_primary
    elsif candidate_secondary != blank and candidate_secondary.available and in_cart_secondary == false
      assign upsell_product_1 = candidate_secondary
    elsif candidate_fallback != blank and candidate_fallback.available and in_cart_fallback == false
      assign upsell_product_1 = candidate_fallback
    endif

  endif

  if suppress_upsell == false and distinct_count >= suppress_distinct_threshold
    if upsell_product_1 == blank or upsell_product_1.metafields.lusena.bundle_original_price == blank
      assign upsell_product_1 = blank
    endif
  endif

  assign free_shipping_threshold_zl = settings.lusena_free_shipping_threshold | default: 0 | plus: 0
  assign free_shipping_threshold = free_shipping_threshold_zl | times: 100
  assign free_shipping_remaining = 0
  if free_shipping_threshold > 0
    assign free_shipping_remaining = free_shipping_threshold | minus: cart.total_price
    if free_shipping_remaining < 0
      assign free_shipping_remaining = 0
    endif
  endif

  assign free_shipping_progress = 0
  if free_shipping_threshold > 0
    assign free_shipping_progress = cart.total_price | times: 100.0 | divided_by: free_shipping_threshold
    if free_shipping_progress > 100
      assign free_shipping_progress = 100
    endif
  endif
  assign free_shipping_progress_for_style = free_shipping_progress | round: 2 | append: ''
  assign free_shipping_progress_for_style = free_shipping_progress_for_style | replace: ',', '.'
-%}

<style>
  /* === Dawn drawer infrastructure (keep unchanged) === */
  cart-drawer.drawer {
    z-index: 6000;
    opacity: 1;
    visibility: hidden;
    pointer-events: none;
    background-color: transparent;
    transition: visibility 0s linear var(--duration-default);
  }

  cart-drawer.drawer.active {
    visibility: visible;
    pointer-events: auto;
    transition: visibility 0s linear 0s;
  }

  cart-drawer.drawer #CartDrawer-Overlay {
    opacity: 0;
    background-color: rgba(0, 0, 0, 0.6);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    transition: opacity var(--duration-default) var(--ease-out-slow);
  }

  cart-drawer.drawer.active #CartDrawer-Overlay {
    opacity: 1;
  }

  cart-drawer.drawer .drawer__inner {
    transition: transform 280ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  cart-drawer.drawer #CartDrawer.drawer__inner {
    padding: 0;
    border: 0;
    height: 100dvh;
  }

  cart-drawer.drawer.is-empty #CartDrawer.drawer__inner {
    display: flex;
    grid-template-rows: none;
    align-items: stretch;
  }

  /* === Item loading state (remove / qty change) === */
  .lusena-cart-drawer__item--loading {
    opacity: 0.45;
    pointer-events: none;
    transition: opacity 150ms ease;
  }

  /* === Icon button touch fix === */
  .lusena-cart-drawer__icon-button {
    -webkit-tap-highlight-color: transparent;
  }

  @media (hover: none) and (pointer: coarse) {
    .lusena-cart-drawer__icon-button:hover {
      background-color: transparent !important;
    }
  }

  /* === DRAWER SHELL === */
  .lusena-cart-drawer {
    width: 100%;
    max-width: 44.8rem;
    background-color: var(--lusena-brand-bg);
    box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25);
    border-left: 1px solid var(--lusena-brand-bg);
  }

  .lusena-cart-drawer .lusena-cart-drawer__shell {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  /* === HEADER === */
  .lusena-cart-drawer .lusena-cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--lusena-space-3);
    border-bottom: 1px solid color-mix(in srgb, var(--lusena-text-2) 10%, transparent);
    background-color: color-mix(in srgb, var(--lusena-surface-1) 50%, transparent);
  }

  .lusena-cart-drawer .lusena-cart-drawer__title {
    font-family: var(--lusena-font-brand);
    font-size: 2rem;
    color: var(--lusena-text-1);
    margin: 0;
  }

  /* === SCROLLABLE BODY === */
  .lusena-cart-drawer .lusena-cart-drawer__body {
    flex: 1 1 0%;
    overflow-y: auto;
    padding: var(--lusena-space-3);
    min-height: 0;
    scrollbar-width: none;
  }
  .lusena-cart-drawer .lusena-cart-drawer__body::-webkit-scrollbar { display: none; }

  .lusena-cart-drawer .lusena-cart-drawer__body > * + * {
    margin-top: var(--lusena-space-3);
  }

  /* === CART ITEM === */
  .lusena-cart-drawer .lusena-cart-drawer__item {
    display: flex;
    gap: var(--lusena-space-2);
  }

  .lusena-cart-drawer .lusena-cart-drawer__item-media {
    display: block;
    width: 8rem;
    height: 9.6rem;
    background-color: var(--lusena-surface-2);
    border-radius: var(--lusena-radius-sm);
    overflow: hidden;
    flex-shrink: 0;
  }

  .lusena-cart-drawer .lusena-cart-drawer__item-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lusena-cart-drawer .lusena-cart-drawer__item-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .lusena-cart-drawer .lusena-cart-drawer__item-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--lusena-space-1);
  }

  .lusena-cart-drawer .lusena-cart-drawer__item-name {
    font-family: var(--lusena-font-ui);
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--lusena-text-1);
    line-height: 1.25;
    letter-spacing: normal;
    margin: 0;
  }

  .lusena-cart-drawer .lusena-cart-drawer__item-name a {
    color: inherit;
    text-decoration: none;
    transition: color var(--lusena-transition-fast);
  }
  @media (hover: hover) {
    .lusena-cart-drawer .lusena-cart-drawer__item-name a:hover {
      color: var(--lusena-accent-cta);
    }
  }

  .lusena-cart-drawer .lusena-cart-drawer__item-prices {
    text-align: right;
    flex-shrink: 0;
  }

  .lusena-cart-drawer .lusena-cart-drawer__item-price {
    display: block;
    font-size: 1.4rem;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
    color: var(--lusena-text-1);
    line-height: 1.25;
  }

  .lusena-cart-drawer .lusena-cart-drawer__item-compare {
    display: block;
    font-size: 1.2rem;
    color: var(--lusena-text-2);
    text-decoration: line-through;
    text-decoration-color: color-mix(in srgb, currentColor 50%, transparent);
    font-variant-numeric: tabular-nums;
  }

  .lusena-cart-drawer .lusena-cart-drawer__item-options {
    font-size: 1.3rem;
    color: var(--lusena-text-2);
    margin: var(--lusena-space-05) 0 0;
  }

  .lusena-cart-drawer .lusena-cart-drawer__item-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--lusena-space-1);
  }

  /* === QUANTITY CONTROL === */
  .lusena-cart-drawer .lusena-cart-drawer__qty {
    display: flex;
    align-items: center;
    border: 1px solid color-mix(in srgb, var(--lusena-text-2) 20%, transparent);
    border-radius: var(--lusena-btn-radius);
  }

  .lusena-cart-drawer .lusena-cart-drawer__qty-display {
    font-size: 1.2rem;
    font-weight: 500;
    width: 2.4rem;
    text-align: center;
    font-variant-numeric: tabular-nums;
    color: var(--lusena-text-1);
  }

  /* === REMOVE BUTTON === */
  .lusena-cart-drawer .lusena-cart-drawer__remove {
    font-size: 1.3rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--lusena-space-05) var(--lusena-space-1);
    color: var(--lusena-text-2);
    transition: color var(--lusena-transition-fast);
    min-height: auto;
  }
  @media (hover: hover) {
    .lusena-cart-drawer .lusena-cart-drawer__remove:hover {
      color: var(--lusena-status-error);
    }
  }

  /* === UPSELL ZONE === */
  .lusena-cart-drawer__upsell :where(p) { margin: 0; }
  .lusena-cart-drawer .lusena-cart-drawer__upsell .lusena-btn--size-xs { min-height: auto; }

  .lusena-cart-drawer .lusena-cart-drawer__upsell {
    border-top: 1px solid color-mix(in srgb, var(--lusena-text-2) 10%, transparent);
    padding: var(--lusena-space-2) var(--lusena-space-3);
    background-color: color-mix(in srgb, var(--lusena-surface-2) 50%, transparent);
  }

  .lusena-cart-drawer .lusena-cart-drawer__upsell-label {
    font-family: var(--lusena-font-brand);
    font-size: 1.2rem;
    line-height: 1.4;
    color: var(--lusena-text-2);
    margin-bottom: 1rem;
  }

  /* --- Unified upsell card container --- */
  .lusena-cart-drawer .lusena-upsell-card {
    padding: var(--lusena-space-2);
    background: var(--lusena-color-n0);
    border-radius: var(--lusena-btn-radius);
    border: 1px solid color-mix(in srgb, var(--lusena-text-2) 5%, transparent);
    box-shadow: 0 1px 2px rgba(0,0,0,0.03);
    border-left: 0.25rem solid color-mix(in srgb, var(--lusena-accent-cta) 40%, transparent);
  }

  /* --- Cross-sell card (horizontal layout, scoped to drawer upsell zone) --- */
  .lusena-cart-drawer__upsell .lusena-upsell-card__xs-row {
    display: flex;
    gap: 1.2rem;
    align-items: center;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__xs-img {
    width: 5.6rem;
    height: 5.6rem;
    background: var(--lusena-surface-2);
    border: 1px dashed color-mix(in srgb, var(--lusena-text-2) 20%, transparent);
    border-radius: var(--lusena-radius-sm);
    overflow: hidden;
    flex-shrink: 0;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__xs-img:empty { display: block; } /* override Dawn base.css div:empty { display:none } */

  .lusena-cart-drawer__upsell .lusena-upsell-card__xs-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__xs-info {
    flex: 1;
    min-width: 0;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__xs-title {
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--lusena-text-1);
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__xs-msg {
    font-size: 1.15rem;
    color: var(--lusena-text-2);
    margin-top: var(--lusena-space-05);
    line-height: 1.375;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__xs-color {
    font-size: 1.05rem;
    line-height: 1.5;
    color: color-mix(in srgb, var(--lusena-text-2) 70%, transparent);
    margin-top: var(--lusena-space-05);
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__xs-color span {
    color: var(--lusena-text-1);
    font-weight: 500;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__xs-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--lusena-space-1);
    margin-top: var(--lusena-space-1);
    padding-top: var(--lusena-space-1);
    border-top: 1px solid color-mix(in srgb, var(--lusena-text-2) 5%, transparent);
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__xs-price {
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--lusena-text-1);
    font-variant-numeric: tabular-nums;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__xs-compare {
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--lusena-text-2);
    text-decoration: line-through;
    text-decoration-color: color-mix(in srgb, currentColor 50%, transparent);
    margin-left: 0.4rem;
  }

  /* --- Bundle card (two-tile layout, scoped to drawer upsell zone) --- */
  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-headline {
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--lusena-text-1);
    line-height: 1.35;
    margin-bottom: var(--lusena-space-1);
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-tiles {
    display: flex;
    gap: var(--lusena-space-1);
    align-items: stretch;
    justify-content: center;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-have {
    flex: 0 0 30%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--lusena-space-1) var(--lusena-space-05);
    border-radius: var(--lusena-radius-sm);
    background: color-mix(in srgb, var(--lusena-surface-2) 40%, transparent);
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-have-img {
    width: 3.8rem;
    height: 3.8rem;
    border-radius: 0.4rem;
    overflow: visible;
    margin-top: 0.7rem; /* compensate for check badge overhang so justify-content:center aligns visually */
    margin-bottom: 0.5rem;
    position: relative;
    background: var(--lusena-surface-2);
    border: 1px dashed color-mix(in srgb, var(--lusena-text-2) 20%, transparent);
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-have-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.75;
    border-radius: 0.4rem;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-check {
    position: absolute;
    top: -0.7rem;
    right: -0.7rem;
    width: 1.4rem;
    height: 1.4rem;
    background: var(--lusena-accent-cta);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-check svg {
    width: 0.8rem;
    height: 0.8rem;
    color: #fff;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-have-name {
    font-size: 1rem;
    font-weight: 500;
    color: #888;
    line-height: 1.2;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-have-status {
    font-size: 0.9rem;
    color: var(--lusena-accent-cta);
    margin-top: 0.2rem;
    font-weight: 500;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-plus {
    font-size: 1.6rem;
    color: var(--lusena-text-2);
    font-weight: 400;
    flex-shrink: 0;
    align-self: center;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-add {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--lusena-space-1);
    border-radius: var(--lusena-radius-sm);
    background: color-mix(in srgb, var(--lusena-surface-2) 50%, transparent);
    border: 1px solid color-mix(in srgb, var(--lusena-text-2) 6%, transparent);
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-add-img {
    width: 5.6rem;
    height: 5.6rem;
    border-radius: var(--lusena-radius-sm);
    overflow: hidden;
    margin-bottom: 0.6rem;
    background: var(--lusena-surface-2);
    border: 1px dashed color-mix(in srgb, var(--lusena-text-2) 20%, transparent);
  }

  /* Override Dawn base.css "div:empty { display:none }" (specificity 0,1,1).
     A class alone (0,1,0) loses. Adding :empty bumps to (0,2,0) and wins. */
  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-add-img:empty {
    display: block;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-add-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-add-name {
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--lusena-text-1);
    line-height: 1.25;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--lusena-space-1);
    margin-top: var(--lusena-space-1);
    padding-top: var(--lusena-space-1);
    border-top: 1px solid color-mix(in srgb, var(--lusena-text-2) 5%, transparent);
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-pricing {
    display: flex;
    align-items: baseline;
    column-gap: 0.6rem;
    row-gap: 0.15rem;
    flex-wrap: wrap;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-price-label {
    flex-basis: 100%;
    font-size: 1rem;
    font-weight: 400;
    color: var(--lusena-text-2);
    line-height: 1;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-price {
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--lusena-text-1);
    font-variant-numeric: tabular-nums;
  }

  .lusena-cart-drawer__upsell .lusena-upsell-card__bn-was {
    font-size: 1.2rem;
    color: var(--lusena-text-2);
    text-decoration: line-through;
    text-decoration-color: color-mix(in srgb, currentColor 50%, transparent);
  }

  /* === UPSELL SUCCESS === */
  .lusena-cart-drawer .lusena-cart-drawer__upsell-success {
    border-top: 1px solid color-mix(in srgb, var(--lusena-text-2) 10%, transparent);
    padding: var(--lusena-space-2) var(--lusena-space-3);
    background-color: color-mix(in srgb, var(--lusena-surface-2) 50%, transparent);
    align-items: center;
    justify-content: center;
    gap: var(--lusena-space-1);
    color: var(--lusena-status-success);
  }

  .lusena-cart-drawer .lusena-cart-drawer__upsell-success-text {
    font-size: 1.2rem;
    color: var(--lusena-status-success);
    font-weight: 500;
  }

  /* === FOOTER === */
  .lusena-cart-drawer .lusena-cart-drawer__footer {
    border-top: 1px solid color-mix(in srgb, var(--lusena-text-2) 10%, transparent);
    background-color: var(--lusena-color-n0);
    padding: var(--lusena-space-3);
  }

  .lusena-cart-drawer .lusena-cart-drawer__footer > * + * {
    margin-top: var(--lusena-space-2);
  }

  .lusena-cart-drawer .lusena-cart-drawer__total {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .lusena-cart-drawer .lusena-cart-drawer__total-label {
    font-size: 1.4rem;
    color: var(--lusena-text-2);
  }

  .lusena-cart-drawer .lusena-cart-drawer__total-value {
    font-family: var(--lusena-font-brand);
    font-size: 1.8rem;
    font-weight: 500;
    color: var(--lusena-text-1);
    font-variant-numeric: tabular-nums;
  }

  /* === SHIPPING PROGRESS === */
  .lusena-cart-drawer .lusena-cart-drawer__shipping > * + * {
    margin-top: var(--lusena-space-1);
  }

  .lusena-cart-drawer .lusena-cart-drawer__shipping-msg {
    display: flex;
    align-items: center;
    gap: var(--lusena-space-1);
    justify-content: center;
  }

  .lusena-cart-drawer .lusena-cart-drawer__shipping-text {
    font-size: 1.3rem;
    color: var(--lusena-text-2);
    line-height: 1.375;
  }

  .lusena-cart-drawer .lusena-cart-drawer__shipping-text--qualified {
    color: var(--lusena-status-success);
    font-weight: 500;
  }

  .lusena-cart-drawer .lusena-cart-drawer__shipping-text--amount {
    font-weight: 500;
    color: var(--lusena-text-1);
    font-variant-numeric: tabular-nums;
  }

  .lusena-cart-drawer .lusena-cart-drawer__shipping-track {
    width: 100%;
    height: 0.6rem;
    border-radius: 9999px;
    overflow: hidden;
    background: var(--lusena-surface-2);
  }

  .lusena-cart-drawer .lusena-cart-drawer__shipping-fill {
    display: block;
    height: 100%;
    border-radius: 9999px;
    transition: width 500ms ease-in-out, background-color 250ms ease;
    background: var(--lusena-accent-cta);
  }

  .lusena-cart-drawer .lusena-cart-drawer__shipping-fill--qualified {
    background: var(--lusena-status-success);
  }

  /* === TRUST ROW === */
  .lusena-cart-drawer .lusena-cart-drawer__trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--lusena-space-1);
    padding-top: var(--lusena-space-05);
  }

  .lusena-cart-drawer .lusena-cart-drawer__trust-text {
    font-size: 1.3rem;
    color: var(--lusena-text-2);
  }

  /* === EMPTY STATE === */
  .drawer__inner-empty.lusena-cart-drawer__empty {
    height: 100%;
    padding: 0;
    overflow: hidden;
  }

  .lusena-cart-drawer .lusena-cart-drawer__empty {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--lusena-space-3);
  }

  .lusena-cart-drawer .lusena-cart-drawer__empty > * + * {
    margin-top: var(--lusena-space-3);
  }

  .lusena-cart-drawer .lusena-cart-drawer__empty-icon {
    padding: var(--lusena-space-3);
    background-color: var(--lusena-color-n0);
    border-radius: 50%;
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    color: rgb(74 74 74 / 0.3);
  }

  .lusena-cart-drawer .lusena-cart-drawer__empty-text > * + * {
    margin-top: var(--lusena-space-1);
  }

  .lusena-cart-drawer .lusena-cart-drawer__empty-title {
    font-family: var(--lusena-font-brand);
    font-size: 1.8rem;
    color: var(--lusena-text-1);
  }

  .lusena-cart-drawer .lusena-cart-drawer__empty-subtitle {
    font-size: 1.4rem;
    color: var(--lusena-text-2);
  }

  .lusena-cart-drawer .lusena-cart-drawer__empty-browse {
    max-width: 24rem;
  }

  .lusena-cart-drawer .lusena-cart-drawer__empty-close {
    font-size: 1.2rem;
  }

  /* === MOBILE COMPACT LAYOUT (≤767px width) === */
  @media (max-width: 767px) {
    /* Reduce zone padding on mobile */
    .lusena-cart-drawer .lusena-cart-drawer__upsell {
      padding: var(--lusena-space-1) var(--lusena-space-2);
    }

    /* Slightly smaller headline */
    .lusena-cart-drawer__upsell .lusena-upsell-card__bn-headline {
      font-size: 1.25rem;
      margin-bottom: var(--lusena-space-05);
    }

    /* Stack tiles vertically on mobile */
    .lusena-cart-drawer__upsell .lusena-upsell-card__bn-tiles {
      flex-direction: column;
      gap: 0;
    }

    /* Collapse "in cart" tile to inline row — no image */
    .lusena-cart-drawer__upsell .lusena-upsell-card__bn-have {
      flex: 0 0 auto;
      flex-direction: row;
      justify-content: flex-start;
      align-items: center;
      gap: 0.4rem;
      padding: 0 0 var(--lusena-space-05);
      background: none;
      border-radius: 0;
    }

    .lusena-cart-drawer__upsell .lusena-upsell-card__bn-have-img {
      display: none;
    }

    .lusena-cart-drawer__upsell .lusena-upsell-card__bn-have-name {
      font-size: 1.1rem;
    }

    .lusena-cart-drawer__upsell .lusena-upsell-card__bn-have-name::before {
      content: '';
      display: inline-block;
      width: 0.45em;
      height: 0.75em;
      border: solid var(--lusena-accent-cta);
      border-width: 0 0.15em 0.15em 0;
      transform: rotate(45deg);
      margin-right: 0.4rem;
      position: relative;
      top: -0.1em;
    }

    .lusena-cart-drawer__upsell .lusena-upsell-card__bn-have-status {
      font-size: 0.9rem;
    }

    .lusena-cart-drawer__upsell .lusena-upsell-card__bn-have-status {
      margin-top: 0.1rem;
    }

    /* Hide "+" separator on mobile (stacked layout) */
    .lusena-cart-drawer__upsell .lusena-upsell-card__bn-plus {
      display: none;
    }

    /* "Add" tile: horizontal with smaller image */
    .lusena-cart-drawer__upsell .lusena-upsell-card__bn-add {
      flex-direction: row;
      justify-content: flex-start;
      align-items: center;
      gap: var(--lusena-space-1);
      text-align: left;
      padding: var(--lusena-space-1);
    }

    .lusena-cart-drawer__upsell .lusena-upsell-card__bn-add-img {
      width: 4rem;
      height: 4rem;
      min-width: 4rem;
      min-height: 4rem;
      flex-shrink: 0;
      margin-bottom: 0;
    }

    .lusena-cart-drawer__upsell .lusena-upsell-card__bn-add-name {
      font-size: 1.15rem;
    }

    /* Tighter pricing row */
    .lusena-cart-drawer__upsell .lusena-upsell-card__bn-bottom {
      margin-top: var(--lusena-space-05);
      padding-top: var(--lusena-space-05);
    }

    /* Reduce card padding on mobile */
    .lusena-cart-drawer .lusena-upsell-card {
      padding: var(--lusena-space-1);
    }

    /* Cross-sell card image size */
    .lusena-cart-drawer__upsell .lusena-upsell-card__xs-img {
      width: 4.4rem;
      height: 4.4rem;
    }
  }

  /* === COMPACT LAYOUT FOR SHORT SCREENS (iPhone SE, small Androids) === */
  @media (max-height: 700px) {
    .lusena-cart-drawer .lusena-cart-drawer__header {
      padding: var(--lusena-space-2);
    }

    .lusena-cart-drawer .lusena-cart-drawer__title {
      font-size: 1.8rem;
    }

    .lusena-cart-drawer .lusena-cart-drawer__upsell {
      padding: var(--lusena-space-1) var(--lusena-space-2);
    }

    .lusena-cart-drawer .lusena-cart-drawer__upsell-label {
      margin-bottom: var(--lusena-space-1);
      font-size: 1.1rem;
    }

    .lusena-cart-drawer__upsell .lusena-upsell-card__bn-have-img { width: 3rem; height: 3rem; }
    .lusena-cart-drawer__upsell .lusena-upsell-card__bn-add-img { width: 4.4rem; height: 4.4rem; }
    .lusena-cart-drawer__upsell .lusena-upsell-card__xs-img { width: 4rem; height: 4rem; }

    .lusena-cart-drawer .lusena-upsell-card {
      padding: var(--lusena-space-1);
    }

    .lusena-cart-drawer .lusena-cart-drawer__footer {
      padding: var(--lusena-space-2);
    }

    .lusena-cart-drawer .lusena-cart-drawer__footer > * + * {
      margin-top: var(--lusena-space-1);
    }

    .lusena-cart-drawer .lusena-cart-drawer__trust {
      padding-top: 0;
    }
  }
</style>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div
    id="CartDrawer-Overlay"
    class="cart-drawer__overlay"
  ></div>

  <div
    id="CartDrawer"
    class="drawer__inner lusena-cart-drawer"
    role="dialog"
    aria-modal="true"
    aria-label="{{ 'sections.cart.title' | t }}"
    tabindex="-1"
  >
    <div class="lusena-cart-drawer__shell">
      <div class="lusena-cart-drawer__header">
        <h2 class="lusena-cart-drawer__title">Tw&oacute;j koszyk</h2>
        <button
          type="button"
          onclick="this.closest('cart-drawer').close()"
          class="lusena-cart-drawer__icon-button lusena-icon-button lusena-icon-button--subtle lusena-icon-button--md"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          {% render 'lusena-icon', name: 'x', class: 'lusena-icon-base', stroke_width: 1.5 %}
        </button>
      </div>

      {%- if cart == empty -%}
        <div class="drawer__inner-empty lusena-cart-drawer__empty">
          <div class="lusena-cart-drawer__empty-icon">
            {% render 'lusena-icon', name: 'shopping-bag', class: 'lusena-icon-xl', stroke_width: 1.5 %}
          </div>
          <div class="lusena-cart-drawer__empty-text">
            <p class="lusena-cart-drawer__empty-title">Tw&oacute;j koszyk jest pusty</p>
            <p class="lusena-cart-drawer__empty-subtitle">Odkryj nasze bestsellery</p>
          </div>
          <a
            href="{{ routes.all_products_collection_url }}"
            class="lusena-btn lusena-btn--primary lusena-btn--size-default lusena-btn--full-width lusena-cart-drawer__empty-browse"
          >
            Przegl&#261;daj produkty
          </a>
          <button
            type="button"
            onclick="this.closest('cart-drawer').close()"
            class="lusena-btn lusena-btn--text-secondary lusena-cart-drawer__empty-close"
          >
            Zamknij
          </button>
        </div>
      {%- else -%}
        <div class="lusena-cart-drawer__body">
          {%- for item in cart.items -%}
            <div class="lusena-cart-drawer__item" data-cart-item data-key="{{ item.key }}">
              {%- if item.url != blank -%}
                <a href="{{ item.url }}" data-cart-item-link class="lusena-cart-drawer__item-media">
                  {%- if item.image -%}
                    <img
                      src="{{ item.image | image_url: width: 240 }}"
                      alt="{{ item.image.alt | escape }}"
                      class="lusena-cart-drawer__item-img"
                      loading="lazy"
                      width="80"
                      height="{{ 96 | divided_by: item.image.aspect_ratio | ceil }}"
                    >
                  {%- endif -%}
                </a>
              {%- else -%}
                <div class="lusena-cart-drawer__item-media">
                  {%- if item.image -%}
                    <img
                      src="{{ item.image | image_url: width: 240 }}"
                      alt="{{ item.image.alt | escape }}"
                      class="lusena-cart-drawer__item-img"
                      loading="lazy"
                      width="80"
                      height="{{ 96 | divided_by: item.image.aspect_ratio | ceil }}"
                    >
                  {%- endif -%}
                </div>
              {%- endif -%}

              <div class="lusena-cart-drawer__item-info">
                <div>
                  <div class="lusena-cart-drawer__item-top">
                    <h3 class="lusena-cart-drawer__item-name">
                      {%- if item.url != blank -%}
                        <a href="{{ item.url }}" data-cart-item-link>
                          {{ item.product.title | escape }}
                        </a>
                      {%- else -%}
                        {{ item.product.title | escape }}
                      {%- endif -%}
                    </h3>
                    <div class="lusena-cart-drawer__item-prices">
                      <span class="lusena-cart-drawer__item-price">{{ item.final_line_price | money_without_trailing_zeros }}</span>
                      {%- if item.original_line_price > item.final_line_price -%}
                        <span class="lusena-cart-drawer__item-compare">{{ item.original_line_price | money_without_trailing_zeros }}</span>
                      {%- elsif item.variant.compare_at_price != blank and item.variant.compare_at_price > item.variant.price -%}
                        {%- assign item_compare_at_line = item.variant.compare_at_price | times: item.quantity -%}
                        <span class="lusena-cart-drawer__item-compare">{{ item_compare_at_line | money_without_trailing_zeros }}</span>
                      {%- endif -%}
                    </div>
                  </div>

                  {%- if item.product.has_only_default_variant == false -%}
                    <p class="lusena-cart-drawer__item-options">
                      {%- for option in item.options_with_values -%}
                        {{ option.value }}{%- unless forloop.last -%} / {%- endunless -%}
                      {%- endfor -%}
                    </p>
                  {%- endif -%}

                  {%- unless item.properties == empty -%}
                    {%- assign has_visible_properties = false -%}
                    {%- for property in item.properties -%}
                      {%- assign prop_first_char = property.first | slice: 0 -%}
                      {%- unless prop_first_char == '_' -%}
                        {%- assign has_visible_properties = true -%}
                      {%- endunless -%}
                    {%- endfor -%}
                    {%- if has_visible_properties -%}
                      <div class="lusena-cart-drawer__item-properties">
                        {%- for property in item.properties -%}
                          {%- assign prop_first_char = property.first | slice: 0 -%}
                          {%- unless prop_first_char == '_' -%}
                            <p class="lusena-cart-drawer__item-property">
                              <span class="lusena-cart-drawer__item-property-label">
                                {{- property.first | split: ' - ' | first | split: ' (' | first | escape -}}:
                              </span>
                              {{ property.last | escape }}
                            </p>
                          {%- endunless -%}
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                  {%- endunless -%}
                </div>

                <div class="lusena-cart-drawer__item-bottom">
                  <div class="lusena-cart-drawer__qty">
                    <button
                      type="button"
                      data-cart-delta="-1"
                      class="lusena-icon-button lusena-icon-button--subtle lusena-icon-button--sm"
                      {% if item.quantity <= 1 %}disabled{% endif %}
                      aria-label="Zmniejsz ilo&#347;&#263;"
                    >
                      {% render 'lusena-icon', name: 'minus', class: 'lusena-icon-sm', stroke_width: 2 %}
                    </button>
                    <span class="lusena-cart-drawer__qty-display" data-cart-qty>{{ item.quantity }}</span>
                    <button
                      type="button"
                      data-cart-delta="1"
                      class="lusena-icon-button lusena-icon-button--subtle lusena-icon-button--sm"
                      aria-label="Zwi&#281;ksz ilo&#347;&#263;"
                    >
                      {% render 'lusena-icon', name: 'plus', class: 'lusena-icon-sm', stroke_width: 2 %}
                    </button>
                  </div>

                  <button
                    type="button"
                    data-cart-remove
                    class="lusena-cart-drawer__remove"
                  >
                    Usu&#324;
                  </button>
                </div>
              </div>
            </div>
          {%- endfor -%}

        {%- if show_merge -%}
          {%- liquid
            assign merge_bundle = all_products[merge_bundle_handle]
            assign merge_variant = merge_bundle.selected_or_first_available_variant

            comment
              Extract color from merge_item_1
            endcomment
            assign merge_color_1 = ''
            for option in merge_item_1.product.options_with_values
              assign opt_down = option.name | downcase
              assign is_color = false
              if opt_down contains 'color'
                assign is_color = true
              else
                if opt_down contains 'colour'
                  assign is_color = true
                else
                  if opt_down contains 'kolor'
                    assign is_color = true
                  endif
                endif
              endif
              if is_color
                assign cpos = forloop.index
                if cpos == 1
                  assign merge_color_1 = merge_item_1.variant.option1
                elsif cpos == 2
                  assign merge_color_1 = merge_item_1.variant.option2
                elsif cpos == 3
                  assign merge_color_1 = merge_item_1.variant.option3
                endif
                break
              endif
            endfor

            comment
              Extract color from merge_item_2
            endcomment
            assign merge_color_2 = ''
            for option in merge_item_2.product.options_with_values
              assign opt_down = option.name | downcase
              assign is_color = false
              if opt_down contains 'color'
                assign is_color = true
              else
                if opt_down contains 'colour'
                  assign is_color = true
                else
                  if opt_down contains 'kolor'
                    assign is_color = true
                  endif
                endif
              endif
              if is_color
                assign cpos = forloop.index
                if cpos == 1
                  assign merge_color_2 = merge_item_2.variant.option1
                elsif cpos == 2
                  assign merge_color_2 = merge_item_2.variant.option2
                elsif cpos == 3
                  assign merge_color_2 = merge_item_2.variant.option3
                endif
                break
              endif
            endfor

            comment
              Build Simple Bundles properties JSON
            endcomment
            assign merge_props_json = ''
            assign merge_selection_parts = ''
            assign sb_options = merge_variant.metafields.simple_bundles.variant_options.value
            if sb_options != blank
              for opt in sb_options
                assign opt_product = opt.optionName | split: ' - Color' | first | split: ' - ' | first
                assign opt_clean = opt_product
                assign dim_parts = opt_product | split: '×'
                if dim_parts.size > 1
                  assign opt_words = opt_product | split: ' '
                  assign opt_clean = ''
                  for w in opt_words
                    assign w_dim = w | split: '×' | size
                    if w_dim > 1
                      break
                    endif
                    if opt_clean == ''
                      assign opt_clean = w
                    else
                      assign opt_clean = opt_clean | append: ' ' | append: w
                    endif
                  endfor
                endif

                assign outer_idx = forloop.index
                assign same_total = 0
                assign same_so_far = 0
                for check in sb_options
                  assign check_name = check.optionName | split: ' - Color' | first | split: ' - ' | first
                  if check_name == opt_product
                    assign same_total = same_total | plus: 1
                    if forloop.index <= outer_idx
                      assign same_so_far = same_so_far | plus: 1
                    endif
                  endif
                endfor
                if same_total > 1
                  assign opt_clean = opt_clean | append: ' ' | append: same_so_far
                endif

                comment
                  Match slot to cart item by title substring
                endcomment
                assign slot_lower = opt_clean | downcase
                assign title_1_lower = merge_item_1.product.title | downcase
                assign this_color = merge_color_2
                if title_1_lower contains slot_lower
                  assign this_color = merge_color_1
                endif

                assign prop_entry = '"' | append: opt_clean | append: '":"' | append: this_color | append: '"'
                if merge_props_json == ''
                  assign merge_props_json = prop_entry
                else
                  assign merge_props_json = merge_props_json | append: ',' | append: prop_entry
                endif

                if merge_selection_parts == ''
                  assign merge_selection_parts = this_color
                else
                  assign merge_selection_parts = merge_selection_parts | append: ' <> ' | append: this_color
                endif
              endfor

              assign merge_props_json = '{' | append: merge_props_json | append: ',"_bundle_selection":"' | append: merge_selection_parts | append: '"}'
            endif

            comment
              Calculate pricing
            endcomment
            assign merge_bundle_price = merge_variant.price
            assign merge_original_cents = merge_bundle.metafields.lusena.bundle_original_price.value | times: 100
            assign merge_savings = merge_original_cents | minus: merge_bundle_price

            comment
              Build replace keys JSON array
            endcomment
            assign merge_replace_keys = '["' | append: merge_item_1.key | append: '","' | append: merge_item_2.key | append: '"]'
          -%}
          <div class="lusena-cart-drawer__upsell" data-cart-upsell-zone aria-live="polite">
            <p class="lusena-cart-drawer__upsell-label">Korzystniej w zestawie</p>
            <div class="lusena-upsell-card"
                 data-bundle-nudge
                 data-bundle-variant-id="{{ merge_variant.id }}"
                 data-replace-keys="{{ merge_replace_keys | escape }}"
                 {%- if merge_props_json != '' %} data-properties="{{ merge_props_json | escape }}"{% endif -%}
                 aria-label="Propozycja zestawu">
              <p class="lusena-upsell-card__bn-headline">
                Zamień na zestaw i zaoszczędź {{ merge_savings | money_without_trailing_zeros }}
              </p>
              <div class="lusena-upsell-card__bn-tiles">
                <div class="lusena-upsell-card__bn-have">
                  <div class="lusena-upsell-card__bn-have-img">
                    {%- if merge_item_1.product.featured_image -%}
                      <img
                        src="{{ merge_item_1.product.featured_image | image_url: width: 120 }}"
                        alt="{{ merge_item_1.product.featured_image.alt | escape }}"
                        loading="lazy" width="38"
                        height="{{ 38 | divided_by: merge_item_1.product.featured_image.aspect_ratio | ceil }}"
                      >
                    {%- endif -%}
                    <span class="lusena-upsell-card__bn-check" aria-hidden="true">
                      {% render 'lusena-icon', name: 'check', stroke_width: 3 %}
                    </span>
                  </div>
                  <p class="lusena-upsell-card__bn-have-name">{{ merge_item_1.product.title | escape }}</p>
                  <p class="lusena-upsell-card__bn-have-status">W koszyku</p>
                </div>
                <span class="lusena-upsell-card__bn-plus" aria-hidden="true">+</span>
                <div class="lusena-upsell-card__bn-have">
                  <div class="lusena-upsell-card__bn-have-img">
                    {%- if merge_item_2.product.featured_image -%}
                      <img
                        src="{{ merge_item_2.product.featured_image | image_url: width: 120 }}"
                        alt="{{ merge_item_2.product.featured_image.alt | escape }}"
                        loading="lazy" width="38"
                        height="{{ 38 | divided_by: merge_item_2.product.featured_image.aspect_ratio | ceil }}"
                      >
                    {%- endif -%}
                    <span class="lusena-upsell-card__bn-check" aria-hidden="true">
                      {% render 'lusena-icon', name: 'check', stroke_width: 3 %}
                    </span>
                  </div>
                  <p class="lusena-upsell-card__bn-have-name">{{ merge_item_2.product.title | escape }}</p>
                  <p class="lusena-upsell-card__bn-have-status">W koszyku</p>
                </div>
              </div>
              <div class="lusena-upsell-card__bn-bottom">
                <div class="lusena-upsell-card__bn-pricing">
                  <span class="lusena-upsell-card__bn-price-label">Za oba produkty:</span>
                  <span class="lusena-upsell-card__bn-price">{{ merge_bundle_price | money_without_trailing_zeros }}</span>
                  <span class="lusena-upsell-card__bn-was">{{ merge_original_cents | money_without_trailing_zeros }}</span>
                </div>
                <button type="button"
                        class="lusena-btn lusena-btn--outline lusena-btn--size-xs"
                        data-bundle-nudge-action>
                  <span class="lusena-btn__content">Zamień na zestaw</span>
                  <span class="loading__spinner hidden">
                    <span class="lusena-btn__loading-dots" aria-hidden="true">
                      <span></span><span></span><span></span>
                    </span>
                  </span>
                </button>
              </div>
            </div>
          </div>
        {%- endif -%}

        {%- unless show_merge -%}
        {%- if upsell_product_1 != blank -%}
          {%- assign upsell_is_bundle = false -%}
          {%- if upsell_product_1.metafields.lusena.bundle_original_price != blank -%}
            {%- assign upsell_is_bundle = true -%}
          {%- endif -%}
          {%- liquid
            comment
              Color-matched variant selection:
              1. Find upsell product's color option position
              2. Match trigger product's color — pick that variant
              3. Fallback: highest-inventory available variant
              4. Last resort: first available variant
            endcomment
            assign upsell_variant_1 = nil
            assign upsell_color_option_pos = 0
            assign upsell_color_label = ''

            if upsell_product_1.options_with_values != blank
              for option in upsell_product_1.options_with_values
                assign opt_name_down = option.name | downcase
                assign is_color_opt = false
                if opt_name_down contains 'color'
                  assign is_color_opt = true
                else
                  if opt_name_down contains 'colour'
                    assign is_color_opt = true
                  else
                    if opt_name_down contains 'kolor'
                      assign is_color_opt = true
                    endif
                  endif
                endif
                if is_color_opt
                  assign upsell_color_option_pos = forloop.index
                  break
                endif
              endfor
            endif

            if trigger_color != blank and upsell_color_option_pos > 0
              for variant in upsell_product_1.variants
                if variant.available
                  assign variant_color = ''
                  if upsell_color_option_pos == 1
                    assign variant_color = variant.option1
                  elsif upsell_color_option_pos == 2
                    assign variant_color = variant.option2
                  elsif upsell_color_option_pos == 3
                    assign variant_color = variant.option3
                  endif
                  if variant_color == trigger_color
                    assign upsell_variant_1 = variant
                    break
                  endif
                endif
              endfor
            endif

            if upsell_variant_1 == nil
              assign best_inv_qty = -1
              for variant in upsell_product_1.variants
                if variant.available
                  if variant.inventory_quantity > best_inv_qty
                    assign best_inv_qty = variant.inventory_quantity
                    assign upsell_variant_1 = variant
                  endif
                endif
              endfor
            endif

            if upsell_variant_1 == nil
              assign upsell_variant_1 = upsell_product_1.selected_or_first_available_variant
            endif

            if upsell_color_option_pos > 0
              if upsell_color_option_pos == 1
                assign upsell_color_label = upsell_variant_1.option1
              elsif upsell_color_option_pos == 2
                assign upsell_color_label = upsell_variant_1.option2
              elsif upsell_color_option_pos == 3
                assign upsell_color_label = upsell_variant_1.option3
              endif
            endif

            assign upsell_display_title = upsell_product_1.title
            assign upsell_display_color = upsell_color_label
            assign upsell_display_price = upsell_variant_1.price | money_without_trailing_zeros
            assign upsell_is_cross_sell = false
            if upsell_product_1.handle == 'silk-scrunchie' and settings.lusena_cart_cross_sell_price != blank
              assign upsell_is_cross_sell = true
              assign upsell_original_price = upsell_variant_1.price | money_without_trailing_zeros
              assign upsell_display_price = settings.lusena_cart_cross_sell_price | money_without_trailing_zeros
            endif
          -%}
          <div class="lusena-cart-drawer__upsell" data-cart-upsell-zone aria-live="polite">
            <p class="lusena-cart-drawer__upsell-label">
              {%- if upsell_is_bundle -%}Korzystniej w zestawie{%- else -%}Pasuje do{%- endif -%}
            </p>

            {%- if upsell_is_bundle -%}
              {%- comment -%} Bundle two-tile card {%- endcomment -%}
              {%- assign nudge_map = upsell_product_1.metafields.lusena.bundle_nudge_map.value -%}
              {%- assign nudge_entry = nudge_map[trigger_product.handle] -%}
              {%- assign added_label = nudge_entry.label | default: nudge_entry -%}
              {%- assign added_component = all_products[nudge_entry.handle] -%}
              {%- assign bundle_price_cents = upsell_variant_1.price -%}
              {%- assign original_total_cents = upsell_product_1.metafields.lusena.bundle_original_price.value | times: 100 -%}
              {%- assign savings_cents = original_total_cents | minus: bundle_price_cents -%}
              {%- assign incremental_cents = bundle_price_cents | minus: trigger_item.variant.price -%}

              {%- liquid
                assign sb_options = upsell_variant_1.metafields.simple_bundles.variant_options.value
                assign nudge_prop_map = ''
                if sb_options != blank
                  for opt in sb_options
                    assign opt_product = opt.optionName | split: ' - Color' | first | split: ' - ' | first
                    assign opt_clean = opt_product
                    assign dim_parts = opt_product | split: '×'
                    if dim_parts.size > 1
                      assign opt_words = opt_product | split: ' '
                      assign opt_clean = ''
                      for w in opt_words
                        assign w_dim = w | split: '×' | size
                        if w_dim > 1
                          break
                        endif
                        if opt_clean == ''
                          assign opt_clean = w
                        else
                          assign opt_clean = opt_clean | append: ' ' | append: w
                        endif
                      endfor
                    endif

                    assign outer_idx = forloop.index
                    assign same_total = 0
                    assign same_so_far = 0
                    for check in sb_options
                      assign check_name = check.optionName | split: ' - Color' | first | split: ' - ' | first
                      if check_name == opt_product
                        assign same_total = same_total | plus: 1
                        if forloop.index <= outer_idx
                          assign same_so_far = same_so_far | plus: 1
                        endif
                      endif
                    endfor
                    if same_total > 1
                      assign opt_clean = opt_clean | append: ' ' | append: same_so_far
                    endif

                    assign opt_vals_raw = opt.optionValues | split: ', '
                    assign opt_vals_json = ''
                    for v in opt_vals_raw
                      if opt_vals_json == ''
                        assign opt_vals_json = '"' | append: v | append: '"'
                      else
                        assign opt_vals_json = opt_vals_json | append: ',"' | append: v | append: '"'
                      endif
                    endfor
                    assign entry = '{"key":"' | append: opt_clean | append: '","values":[' | append: opt_vals_json | append: ']}'
                    if nudge_prop_map == ''
                      assign nudge_prop_map = entry
                    else
                      assign nudge_prop_map = nudge_prop_map | append: ',' | append: entry
                    endif
                  endfor
                  assign nudge_prop_map = '[' | append: nudge_prop_map | append: ']'
                endif
              -%}

              <div class="lusena-upsell-card"
                   data-bundle-nudge
                   data-bundle-variant-id="{{ upsell_variant_1.id }}"
                   data-replace-key="{{ trigger_item.key | escape }}"
                   {%- if trigger_color != blank %} data-trigger-color="{{ trigger_color | escape }}"{% endif -%}
                   {%- if nudge_prop_map != blank %} data-property-map="{{ nudge_prop_map | escape }}"{% endif -%}
                   aria-label="Propozycja zestawu">
                <p class="lusena-upsell-card__bn-headline">
                  Dołącz {{ added_label }} i zaoszczędź {{ savings_cents | money_without_trailing_zeros }}
                </p>
                <div class="lusena-upsell-card__bn-tiles">
                  <div class="lusena-upsell-card__bn-have">
                    <div class="lusena-upsell-card__bn-have-img">
                      {%- if trigger_product.featured_image -%}
                        <img
                          src="{{ trigger_product.featured_image | image_url: width: 120 }}"
                          alt="{{ trigger_product.featured_image.alt | escape }}"
                          loading="lazy"
                          width="38"
                          height="{{ 38 | divided_by: trigger_product.featured_image.aspect_ratio | ceil }}"
                        >
                      {%- endif -%}
                      <span class="lusena-upsell-card__bn-check" aria-hidden="true">
                        {% render 'lusena-icon', name: 'check', stroke_width: 3 %}
                      </span>
                    </div>
                    <p class="lusena-upsell-card__bn-have-name">{{ trigger_product.title | escape }}</p>
                    <p class="lusena-upsell-card__bn-have-status">W koszyku</p>
                  </div>
                  <span class="lusena-upsell-card__bn-plus" aria-hidden="true">+</span>
                  <div class="lusena-upsell-card__bn-add">
                    <div class="lusena-upsell-card__bn-add-img">
                      {%- assign add_tile_image = added_component.featured_image | default: upsell_product_1.featured_image -%}
                      {%- if add_tile_image -%}
                        <img
                          src="{{ add_tile_image | image_url: width: 240 }}"
                          alt="{{ add_tile_image.alt | escape }}"
                          loading="lazy"
                          width="56"
                          height="{{ 56 | divided_by: add_tile_image.aspect_ratio | ceil }}"
                        >
                      {%- endif -%}
                    </div>
                    {%- assign tile_label = nudge_entry.tile_label | default: added_component.title | default: added_label -%}
                    <p class="lusena-upsell-card__bn-add-name">{{ tile_label | escape }}</p>
                  </div>
                </div>
                <div class="lusena-upsell-card__bn-bottom">
                  <div class="lusena-upsell-card__bn-pricing">
                    <span class="lusena-upsell-card__bn-price-label">Za oba produkty:</span>
                    <span class="lusena-upsell-card__bn-price">{{ bundle_price_cents | money_without_trailing_zeros }}</span>
                    <span class="lusena-upsell-card__bn-was">{{ original_total_cents | money_without_trailing_zeros }}</span>
                  </div>
                  <button type="button"
                          class="lusena-btn lusena-btn--outline lusena-btn--size-xs"
                          data-bundle-nudge-action>
                    <span class="lusena-btn__content">Dołącz do zestawu</span>
                    <span class="loading__spinner hidden">
                      <span class="lusena-btn__loading-dots" aria-hidden="true">
                        <span></span><span></span><span></span>
                      </span>
                    </span>
                  </button>
                </div>
              </div>

            {%- else -%}
              {%- comment -%} Cross-sell card (horizontal) {%- endcomment -%}
              <div class="lusena-upsell-card">
                <div class="lusena-upsell-card__xs-row">
                  <div class="lusena-upsell-card__xs-img">
                    {%- if upsell_product_1.featured_image -%}
                      <img
                        src="{{ upsell_product_1.featured_image | image_url: width: 240 }}"
                        alt="{{ upsell_product_1.featured_image.alt | escape }}"
                        loading="lazy"
                        width="56"
                        height="{{ 56 | divided_by: upsell_product_1.featured_image.aspect_ratio | ceil }}"
                      >
                    {%- endif -%}
                  </div>
                  <div class="lusena-upsell-card__xs-info">
                    <p class="lusena-upsell-card__xs-title">{{ upsell_display_title | escape }}</p>
                    {%- if upsell_is_cross_sell -%}
                      <p class="lusena-upsell-card__xs-msg">Taniej w komplecie</p>
                    {%- endif -%}
                    {%- if upsell_display_color != blank -%}
                      <p class="lusena-upsell-card__xs-color">
                        Kolor: <span>{{ upsell_display_color | escape }}</span>
                      </p>
                    {%- endif -%}
                  </div>
                </div>
                <div class="lusena-upsell-card__xs-bottom">
                  <p class="lusena-upsell-card__xs-price">
                    {{ upsell_display_price | escape }}
                    {%- if upsell_is_cross_sell -%}
                      <span class="lusena-upsell-card__xs-compare">{{ upsell_original_price }}</span>
                    {%- endif -%}
                  </p>
                  <product-form class="product-form" data-hide-errors="true" data-cart-upsell>
                    {%- form 'product',
                      upsell_product_1,
                      id: 'CartDrawer-Upsell-Form-1',
                      class: 'form',
                      novalidate: 'novalidate',
                      data-type: 'add-to-cart-form'
                    -%}
                      <input type="hidden" name="id" value="{{ upsell_variant_1.id }}">
                      <button type="submit" class="lusena-btn lusena-btn--outline lusena-btn--size-xs">
                        <span class="lusena-btn__content">Dodaj</span>
                        <span class="loading__spinner hidden">
                          <span class="lusena-btn__loading-dots" aria-hidden="true">
                            <span></span><span></span><span></span>
                          </span>
                        </span>
                      </button>
                    {%- endform -%}
                  </product-form>
                </div>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
        {%- endunless -%}

        <div
          class="lusena-cart-drawer__upsell-success hidden"
          data-cart-upsell-success
          aria-live="polite"
        >
          {% render 'lusena-icon', name: 'check', class: 'lusena-icon-md', stroke_width: 2 %}
          <span class="lusena-cart-drawer__upsell-success-text">Dodano do koszyka</span>
        </div>

        </div>
      {%- endif -%}

      {%- if cart != empty -%}
        <div class="lusena-cart-drawer__footer">
          <div class="lusena-cart-drawer__total">
            <span class="lusena-cart-drawer__total-label">Suma</span>
            <span class="lusena-cart-drawer__total-value">{{ cart.total_price | money_without_trailing_zeros }}</span>
          </div>

          {%- if settings.lusena_enable_free_shipping_progress and free_shipping_threshold > 0 -%}
            <div class="lusena-cart-drawer__shipping">
              <div class="lusena-cart-drawer__shipping-msg">
                {% if free_shipping_remaining == 0 %}
                  {% render 'lusena-icon', name: 'truck', class: 'lusena-icon-sm lusena-shrink-0', stroke_width: 2 %}
                  <span class="lusena-cart-drawer__shipping-text">
                    <span class="lusena-cart-drawer__shipping-text--qualified">Masz darmow&#261; dostaw&#281;!</span>
                  </span>
                {% else %}
                  {% render 'lusena-icon', name: 'truck', class: 'lusena-icon-sm lusena-shrink-0', stroke_width: 2 %}
                  <span class="lusena-cart-drawer__shipping-text">
                    Brakuje Ci <span class="lusena-cart-drawer__shipping-text--amount">{{ free_shipping_remaining | money_without_trailing_zeros }}</span> do darmowej dostawy
                  </span>
                {% endif %}
              </div>
              <div class="lusena-cart-drawer__shipping-track">
                <span
                  class="lusena-cart-drawer__shipping-fill{% if free_shipping_remaining == 0 %} lusena-cart-drawer__shipping-fill--qualified{% endif %}"
                  style="width: {{ free_shipping_progress_for_style }}%;"
                ></span>
              </div>
            </div>
          {%- endif -%}

          <button
            type="button"
            data-lusena-drawer-checkout
            class="lusena-btn lusena-btn--primary lusena-btn--size-lg lusena-btn--full-width"
          >
            <span class="lusena-btn__content">Przejd&#378; do kasy</span>
            <span class="loading__spinner hidden">
              <span class="lusena-btn__loading-text">Przekierowuj&#281;...</span>
            </span>
          </button>
          <div class="lusena-cart-drawer__trust">
            {% render 'lusena-icon', name: 'shield-check', class: 'lusena-icon-sm lusena-shrink-0', stroke_width: 2 %}
            <span class="lusena-cart-drawer__trust-text">60 dni na zwrot &middot; Bezpieczna p&#322;atno&#347;&#263;</span>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</cart-drawer>

<script>
  (() => {
    const drawer = document.querySelector('cart-drawer');
    if (!drawer) return;
    const upsellAddedKey = 'lusena-cart-upsell-added';
    const upsellPendingTimeoutMs = 10000;
    let upsellSuccessHideTimer;
    let pendingUpsellVariantId = '';
    let pendingUpsellTimer;

    const readUpsellAddedFlag = () => {
      try {
        return window.sessionStorage.getItem(upsellAddedKey) === '1';
      } catch (error) {
        return false;
      }
    };

    const writeUpsellAddedFlag = () => {
      try {
        window.sessionStorage.setItem(upsellAddedKey, '1');
      } catch (error) {}
    };

    const clearUpsellAddedFlag = () => {
      try {
        window.sessionStorage.removeItem(upsellAddedKey);
      } catch (error) {}
    };

    const showUpsellSuccess = () => {
      const successEl = drawer.querySelector('[data-cart-upsell-success]');
      const upsellZoneEl = drawer.querySelector('[data-cart-upsell-zone]');
      if (!successEl) return;
      if (upsellZoneEl) {
        upsellZoneEl.classList.add('hidden');
      }
      successEl.classList.remove('hidden');
      successEl.classList.add('flex');
      window.clearTimeout(upsellSuccessHideTimer);
      upsellSuccessHideTimer = window.setTimeout(() => {
        successEl.classList.add('hidden');
        successEl.classList.remove('flex');
        if (upsellZoneEl) {
          upsellZoneEl.classList.remove('hidden');
        }
      }, 2200);
    };

    const flushUpsellSuccess = () => {
      if (readUpsellAddedFlag() == false) return;
      clearUpsellAddedFlag();
      showUpsellSuccess();
    };

    const normalizeVariantId = (value) => {
      if (value == null) return '';
      return String(value);
    };

    const clearPendingUpsell = () => {
      pendingUpsellVariantId = '';
      if (pendingUpsellTimer) {
        window.clearTimeout(pendingUpsellTimer);
        pendingUpsellTimer = undefined;
      }
    };

    const markPendingUpsell = (variantId) => {
      pendingUpsellVariantId = normalizeVariantId(variantId);
      if (pendingUpsellTimer) {
        window.clearTimeout(pendingUpsellTimer);
      }
      pendingUpsellTimer = window.setTimeout(() => {
        clearPendingUpsell();
      }, upsellPendingTimeoutMs);
    };

    const enableItemLoading = (triggerEl) => {
      const itemEl = triggerEl ? triggerEl.closest('[data-cart-item]') : null;
      if (!itemEl) return null;
      itemEl.classList.add('lusena-cart-drawer__item--loading');
      itemEl.querySelectorAll('button').forEach(b => { b.disabled = true; });
      return itemEl;
    };

    const disableItemLoading = (itemEl) => {
      if (!itemEl) return;
      itemEl.classList.remove('lusena-cart-drawer__item--loading');
      itemEl.querySelectorAll('button').forEach(b => { b.disabled = false; });
      const minusBtn = itemEl.querySelector('[data-cart-delta="-1"]');
      const qtyEl = itemEl.querySelector('[data-cart-qty]');
      if (minusBtn && qtyEl && parseInt(qtyEl.textContent || '1', 10) <= 1) {
        minusBtn.disabled = true;
      }
    };

    const updateLine = async (triggerEl, key, quantity) => {
      if (!window.fetch || !window.routes?.cart_change_url) return;
      if (typeof fetchConfig !== 'function') return;

      const itemEl = enableItemLoading(triggerEl);

      const formData = new FormData();
      formData.append('id', key);
      formData.append('quantity', quantity);

      if (typeof drawer.getSectionsToRender === 'function') {
        formData.append(
          'sections',
          drawer.getSectionsToRender().map((section) => section.id)
        );
        formData.append('sections_url', window.location.pathname);
      }

      if (typeof drawer.setActiveElement === 'function' && triggerEl) {
        drawer.setActiveElement(triggerEl);
      }

      const config = fetchConfig('javascript');
      config.headers['X-Requested-With'] = 'XMLHttpRequest';
      delete config.headers['Content-Type'];
      config.body = formData;

      try {
        const response = await fetch(window.routes.cart_change_url, config);
        if (!response.ok) {
          throw new Error(`Cart change failed: ${response.status}`);
        }
        const state = await response.json();

        if (typeof drawer.renderContents === 'function') {
          drawer.renderContents(state);
          flushUpsellSuccess();
        }
        // Notify cart page (and any other subscriber) that the cart changed
        if (typeof publish === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
          publish(PUB_SUB_EVENTS.cartUpdate, { source: 'cart-drawer', cartData: state });
        }
      } catch (err) {
        console.error('Cart drawer updateLine error:', err);
        disableItemLoading(itemEl);
      }
    };

    flushUpsellSuccess();

    // pubsub.js is loaded with defer — not available yet during inline script execution.
    // Wait for DOMContentLoaded so all deferred scripts (pubsub.js, constants.js) have run.
    const registerSubscribers = () => {
      if (typeof subscribe !== 'function' || typeof PUB_SUB_EVENTS === 'undefined') return;

      subscribe(PUB_SUB_EVENTS.cartUpdate, (event) => {
        if (!event || event.source !== 'product-form') return;
        if (pendingUpsellVariantId === '') return;

        const updatedVariantId = normalizeVariantId(event.productVariantId);
        if (updatedVariantId !== pendingUpsellVariantId) return;

        writeUpsellAddedFlag();
        clearPendingUpsell();
        window.setTimeout(() => {
          flushUpsellSuccess();
        }, 0);
      });

      subscribe(PUB_SUB_EVENTS.cartError, (event) => {
        if (!event || event.source !== 'product-form') return;
        if (pendingUpsellVariantId === '') return;

        const failedVariantId = normalizeVariantId(event.productVariantId);
        if (failedVariantId !== pendingUpsellVariantId) return;

        clearPendingUpsell();
        clearUpsellAddedFlag();
      });

      // Sync: re-render drawer when cart page (or any non-drawer source) changes the cart
      subscribe(PUB_SUB_EVENTS.cartUpdate, (event) => {
        if (!event || event.source === 'cart-drawer') return;
        if (event.source === 'product-form') return;

        fetch(`${routes.cart_url}?section_id=cart-drawer`)
          .then((r) => r.text())
          .then((html) => {
            const doc = new DOMParser().parseFromString(html, 'text/html');
            const fresh = doc.querySelector('#CartDrawer');
            const current = document.getElementById('CartDrawer');
            if (fresh && current) current.innerHTML = fresh.innerHTML;
            drawer.classList.toggle('is-empty', !doc.querySelector('[data-cart-item]'));
          })
          .catch(() => {});
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', registerSubscribers);
    } else {
      registerSubscribers();
    }

    drawer.addEventListener('submit', (event) => {
      const form = event.target.closest('form');
      if (!form) return;
      if (!form.closest('[data-cart-upsell]')) return;
      const variantInput = form.querySelector('[name="id"]');
      if (!variantInput) return;
      markPendingUpsell(variantInput.value);
    });

    // Bundle nudge: click handler using shared LusenaBundle.swap()
    var drawerSwapInProgress = false;
    drawer.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-bundle-nudge-action]');
      if (!btn) return;
      if (drawerSwapInProgress) return;

      var nudge = btn.closest('[data-bundle-nudge]');
      if (!nudge) return;

      drawerSwapInProgress = true;
      btn.disabled = true;
      btn.classList.add('loading');
      var spinner = btn.querySelector('.loading__spinner');
      if (spinner) spinner.classList.remove('hidden');

      // Lock all cart rows to prevent concurrent mutations during swap
      var allItems = drawer.querySelectorAll('[data-cart-item]');
      allItems.forEach(function(el) {
        el.classList.add('lusena-cart-drawer__item--loading');
        el.querySelectorAll('button').forEach(function(b) { b.disabled = true; });
      });

      var sections = drawer.getSectionsToRender().map(function(s) { return s.id || s.section; });
      var swapOpts = { sections: sections, sectionsUrl: window.location.pathname };

      // Merge path: pre-filled properties + multiple replace keys
      var removeKeys;
      if (nudge.dataset.replaceKeys) {
        removeKeys = JSON.parse(nudge.dataset.replaceKeys);
        if (nudge.dataset.properties) {
          try { swapOpts.properties = JSON.parse(nudge.dataset.properties); } catch(e) {}
        }
      } else {
        // Existing nudge path: single replace key + color matching
        removeKeys = [nudge.dataset.replaceKey];
        var triggerColor = nudge.dataset.triggerColor;
        var propertyMapRaw = nudge.dataset.propertyMap;
        if (triggerColor && propertyMapRaw) {
          try {
            var components = JSON.parse(propertyMapRaw);
            var props = {};
            var selectionParts = [];

            // Detect multi-pack: all components have identical value lists
            var isMultiPack = components.length > 1 && components.every(function(c) {
              return c.values.join(',') === components[0].values.join(',');
            });

            if (isMultiPack) {
              // Distribute unique colors: trigger first, then remaining unused
              var usedColors = [];
              components.forEach(function(comp, idx) {
                var color;
                if (idx === 0) {
                  color = comp.values.indexOf(triggerColor) !== -1 ? triggerColor : comp.values[0];
                } else {
                  color = comp.values.find(function(v) { return usedColors.indexOf(v) === -1; });
                  if (!color) color = comp.values[0];
                }
                usedColors.push(color);
                props[comp.key] = color;
                selectionParts.push(color);
              });
            } else {
              // Complementary: match trigger color per component (fallback to first available)
              components.forEach(function(comp) {
                var color = comp.values.indexOf(triggerColor) !== -1 ? triggerColor : comp.values[0];
                props[comp.key] = color;
                selectionParts.push(color);
              });
            }

            props['_bundle_selection'] = selectionParts.join(' <> ');
            swapOpts.properties = props;
          } catch (e) { /* ignore parse errors */ }
        }
      }

      LusenaBundle.swap(nudge.dataset.bundleVariantId, removeKeys, swapOpts)
        .then(function(state) {
          drawerSwapInProgress = false;
          drawer.renderContents(state);
          if (typeof publish === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
            publish(PUB_SUB_EVENTS.cartUpdate, { source: 'cart-drawer', cartData: state });
          }
          // Direct cart page sync (belt-and-suspenders — don't rely solely on pubsub)
          var cartItemsEl = document.querySelector('cart-items');
          if (cartItemsEl && typeof cartItemsEl.onCartUpdate === 'function') {
            cartItemsEl.onCartUpdate();
          }
        })
        .catch(function(err) {
          console.error('Bundle swap failed:', err);
          drawerSwapInProgress = false;
          allItems.forEach(function(el) {
            el.classList.remove('lusena-cart-drawer__item--loading');
            el.querySelectorAll('button').forEach(function(b) { b.disabled = false; });
          });
          btn.disabled = false;
          btn.classList.remove('loading');
          if (spinner) spinner.classList.add('hidden');
          var textEl = btn.querySelector('.lusena-btn__content');
          if (textEl) {
            var orig = textEl.textContent;
            textEl.textContent = 'Coś poszło nie tak';
            setTimeout(function() { textEl.textContent = orig; }, 3000);
          }
        });
    });

    const normalizePath = (value) => {
      if (!value) return '/';
      if (value.length > 1 && value.endsWith('/')) {
        return value.slice(0, -1);
      }
      return value;
    };

    drawer.addEventListener('click', (event) => {
      const itemLink = event.target.closest('[data-cart-item-link]');
      if (!itemLink) return;

      if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0) return;
      if (itemLink.target === '_blank' || itemLink.hasAttribute('download')) return;

      const itemUrl = new URL(itemLink.href, window.location.origin);
      const currentUrl = new URL(window.location.href);

      if (normalizePath(itemUrl.pathname) !== normalizePath(currentUrl.pathname)) return;

      event.preventDefault();
      drawer.close();
    });

    drawer.addEventListener('click', (event) => {
      const removeBtn = event.target.closest('[data-cart-remove]');
      const qtyBtn = event.target.closest('[data-cart-delta]');
      if (!removeBtn && !qtyBtn) return;

      const itemEl = event.target.closest('[data-cart-item]');
      if (!itemEl) return;

      const key = itemEl.getAttribute('data-key');
      if (!key) return;

      if (removeBtn) {
        updateLine(removeBtn, key, 0);
        return;
      }

      const qtyEl = itemEl.querySelector('[data-cart-qty]');
      const currentQty = parseInt(qtyEl?.textContent || '1', 10);
      const delta = parseInt(qtyBtn.getAttribute('data-cart-delta') || '0', 10);
      const nextQty = Math.max(0, currentQty + delta);

      if (nextQty === currentQty) return;
      updateLine(qtyBtn, key, nextQty);
    });

    /* ── Checkout button: loading animation + navigate ── */
    const CHECKOUT_HOLD_MS = 400;
    const checkoutUrl = window.routes?.checkout_url || '/checkout';

    drawer.addEventListener('click', (event) => {
      const btn = event.target.closest('[data-lusena-drawer-checkout]');
      if (!btn) return;
      if (btn.classList.contains('loading')) return;

      btn.classList.add('loading');
      btn.setAttribute('aria-busy', 'true');
      const spinner = btn.querySelector('.loading__spinner');
      if (spinner) spinner.classList.remove('hidden');

      setTimeout(() => {
        window.location.href = checkoutUrl;
      }, CHECKOUT_HOLD_MS);
    });

    window.addEventListener('pageshow', (event) => {
      if (!event.persisted) return;
      const btn = drawer.querySelector('[data-lusena-drawer-checkout].loading');
      if (!btn) return;
      btn.classList.remove('loading');
      btn.removeAttribute('aria-busy');
      const spinner = btn.querySelector('.loading__spinner');
      if (spinner) spinner.classList.add('hidden');
    });
  })();
</script>

{% stylesheet %}
  .lusena-cart-drawer .lusena-cart-drawer__item {
    align-items: center;
  }
  .lusena-cart-drawer__item-properties {
    margin-top: 0.4rem;
  }
  .lusena-cart-drawer__item-property {
    font-size: 1.2rem;
    line-height: 1.4;
    color: var(--lusena-text-2);
    margin: 0;
  }
  .lusena-cart-drawer__item-property-label {
    font-weight: 500;
    color: var(--lusena-text-1);
  }
{% endstylesheet %}
